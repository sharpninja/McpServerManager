{
  "name": "fwh-mcp-todo",
  "displayName": "McpServer MCP Todo",
  "description": "Displays TODO items from the FunWasHad MCP server. Double-click to open in editor as markdown; save pushes updates to MCP.",
  "version": "0.8.1",
  "publisher": "FunWasHad",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:FunWasHad.sln"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "McpServer MCP Todo",
      "properties": {
        "fwhMcpTodo.mcpBaseUrl": {
          "type": "string",
          "default": "http://localhost:7147",
          "description": "Base URL of the MCP server (e.g. http://localhost:7147)."
        }
      }
    },
    "commands": [
      {
        "command": "fwhMcpTodo.newTodo",
        "title": "New Todo",
        "icon": "$(add)"
      },
      {
        "command": "fwhMcpTodo.refresh",
        "title": "Refresh list"
      },
      {
        "command": "fwhMcpTodo.filters",
        "title": "Filters…"
      },
      {
        "command": "fwhMcpTodo.filterByPriority",
        "title": "Filter by priority (All/High/Medium/Low)"
      },
      {
        "command": "fwhMcpTodo.filterByText",
        "title": "Filter by text"
      },
      {
        "command": "fwhMcpTodo.clearFilters",
        "title": "Clear filters"
      },
      {
        "command": "fwhMcpTodo.openInEditor",
        "title": "Open",
        "icon": "$(go-to-file)"
      },
      {
        "command": "fwhMcpTodo.status",
        "title": "Status",
        "icon": "$(info)"
      },
      {
        "command": "fwhMcpTodo.implement",
        "title": "Implement",
        "icon": "$(play)"
      },
      {
        "command": "fwhMcpTodo.plan",
        "title": "Plan",
        "icon": "$(tasklist)"
      },
      {
        "command": "fwhMcpTodo.copyId",
        "title": "McpServer MCP Todo: Copy ID to clipboard"
      },
      {
        "command": "fwhMcpTodo.showOutput",
        "title": "McpServer MCP Todo: Show output log"
      },
      {
        "command": "fwhMcpTodo.stop",
        "title": "Stop",
        "icon": "$(debug-stop)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "fwhMcpTodo",
          "title": "MCP Todo",
          "icon": "$(list-flat)"
        }
      ]
    },
    "views": {
      "fwhMcpTodo": [
        {
          "type": "webview",
          "id": "fwhMcpTodo.filters",
          "name": "Filters"
        },
        {
          "id": "fwhMcpTodo.todoList",
          "name": "Todo List"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "fwhMcpTodo.newTodo",
          "when": "view == fwhMcpTodo.todoList",
          "group": "navigation",
          "icon": "$(add)"
        },
        {
          "command": "fwhMcpTodo.refresh",
          "when": "view == fwhMcpTodo.todoList",
          "group": "navigation",
          "icon": "$(refresh)"
        },
        {
          "command": "fwhMcpTodo.filters",
          "when": "view == fwhMcpTodo.todoList",
          "group": "filter",
          "icon": "$(filter)"
        },
        {
          "command": "fwhMcpTodo.stop",
          "when": "view == fwhMcpTodo.todoList && fwhMcpTodo.copilotRunning",
          "group": "navigation",
          "icon": "$(debug-stop)"
        },
        {
          "command": "fwhMcpTodo.filterByPriority",
          "when": "view == fwhMcpTodo.todoList",
          "group": "filter"
        },
        {
          "command": "fwhMcpTodo.filterByText",
          "when": "view == fwhMcpTodo.todoList",
          "group": "filter"
        },
        {
          "command": "fwhMcpTodo.clearFilters",
          "when": "view == fwhMcpTodo.todoList",
          "group": "filter"
        }
      ],
      "view/item/context": [
        {
          "command": "fwhMcpTodo.openInEditor",
          "when": "view == fwhMcpTodo.todoList && viewItem == todoItem",
          "group": "todo@1"
        },
        {
          "command": "fwhMcpTodo.status",
          "when": "view == fwhMcpTodo.todoList && viewItem == todoItem",
          "group": "todo@2"
        },
        {
          "command": "fwhMcpTodo.implement",
          "when": "view == fwhMcpTodo.todoList && viewItem == todoItem",
          "group": "todo@3"
        },
        {
          "command": "fwhMcpTodo.plan",
          "when": "view == fwhMcpTodo.todoList && viewItem == todoItem",
          "group": "todo@4"
        },
        {
          "command": "fwhMcpTodo.copyId",
          "when": "view == fwhMcpTodo.todoList && viewItem == todoItem",
          "group": "other@1"
        },
        {
          "command": "fwhMcpTodo.refresh",
          "when": "view == fwhMcpTodo.todoList",
          "group": "other@2"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test out/test/todoLifecycle.integration.test.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "~5.6.0"
  },
  "dependencies": {
    "fwh-copilot-client": "file:McpServer-copilot-client-0.1.5.tgz"
  },
  "bundledDependencies": [
    "fwh-copilot-client"
  ]
}
