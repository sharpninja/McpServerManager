<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:McpServerManager.Core.ViewModels"
        xmlns:models="using:McpServerManager.Core.Models"
        xmlns:conv="using:McpServerManager.Core.Converters"
        xmlns:beh="using:McpServerManager.Core.Behaviors"
        xmlns:md="clr-namespace:Markdown.Avalonia;assembly=Markdown.Avalonia"
        x:Class="McpServerManager.Desktop.Views.ChatWindow"
        x:DataType="vm:ChatWindowViewModel"
        Title="AI Assistant"
        Width="500" Height="550"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/avalonia-logo.ico"
        Background="{DynamicResource ThemeBackgroundBrush}"
        FontSize="14">

    <Window.Resources>
        <conv:RoleToBrushConverter x:Key="RoleToBrush"/>
        <conv:RoleToVisibilityConverter x:Key="RoleToVisibility"/>
    </Window.Resources>

    <Grid x:Name="ChatMainGrid" Background="{DynamicResource ThemeBackgroundBrush}" Margin="8">
        <Border Grid.Row="0" Classes="phone-toolbar-card" Padding="8,6" Margin="0,0,0,6">
            <Grid ColumnDefinitions="Auto, *, Auto, Auto">
                <SelectableTextBlock Grid.Column="0" Text="Model:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableModels}" SelectedItem="{Binding SelectedModel}"
                          MinWidth="180" HorizontalAlignment="Left" FontSize="14"/>
                <Button Grid.Column="2" Command="{Binding OpenAgentConfigCommand}" Margin="8,0,0,0" ToolTip.Tip="Open agent config in default editor">
                    <TextBlock Text="Agent config" FontSize="12"/>
                </Button>
                <Button Grid.Column="3" Command="{Binding OpenPromptTemplatesCommand}" Margin="4,0,0,0" ToolTip.Tip="Open prompt templates in default editor">
                    <TextBlock Text="Prompts" FontSize="12"/>
                </Button>
            </Grid>
        </Border>
        <Expander Grid.Row="1" x:Name="PromptTemplatesExpander" Header="Prompt templates" IsExpanded="True"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                  Background="{DynamicResource StatusBarBrush}" Padding="8,6" BorderBrush="{DynamicResource ItemBorderBrush}" BorderThickness="1"
                  MinHeight="40">
            <Grid RowDefinitions="Auto, *">
                <SelectableTextBlock Grid.Row="0" Text="Click to fill input, double-click to send." FontSize="12" Classes="subtle-text" Margin="0,0,0,4"/>
                <ListBox Grid.Row="1" ItemsSource="{Binding PromptTemplates}" Margin="0" Padding="0"
                         Background="Transparent"
                         BorderThickness="0"
                         beh:TappedBehavior.Command="{Binding PopulatePromptCommand}"
                         beh:DoubleTappedBehavior.Command="{Binding SubmitPromptCommand}">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="models:PromptTemplate">
                            <Border Margin="2" Padding="4" Background="Transparent">
                                <SelectableTextBlock Text="{Binding Name}" FontSize="14"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Expander>
        <GridSplitter Grid.Row="2" x:Name="ChatTemplateSplitter" Classes="phone-splitter" ResizeDirection="Rows" Height="4"/>
        <Border Grid.Row="3" Classes="phone-card" Padding="6" Margin="0,6,0,6">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      x:Name="MessageScroll">
            <ItemsControl ItemsSource="{Binding Messages}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:ChatMessage">
                        <Border Margin="2" Padding="4" CornerRadius="4"
                                Background="{Binding Role, Converter={StaticResource RoleToBrush}}">
                            <StackPanel Spacing="4">
                                <SelectableTextBlock FontWeight="SemiBold" FontSize="14" Classes="subtle-text"
                                           Text="{Binding Role}"/>
                                <SelectableTextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="16"
                                           IsVisible="{Binding Role, Converter={StaticResource RoleToVisibility}, ConverterParameter=user}"/>
                                <md:MarkdownScrollViewer Markdown="{Binding Text}" Margin="0"
                                           IsVisible="{Binding Role, Converter={StaticResource RoleToVisibility}, ConverterParameter=assistant}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        </Border>
        <Border Grid.Row="4" Classes="phone-toolbar-card" Padding="8">
            <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                <TextBox Grid.Row="0" Grid.Column="0" Text="{Binding CurrentInput}" Watermark="Ask about your logs..."
                         MinHeight="36" Margin="0,0,8,0" FontSize="14"
                         beh:KeyDownBehavior.Key="Return"
                         beh:KeyDownBehavior.Command="{Binding SendCommand}"/>
                <Button Grid.Row="0" Grid.Column="1" Content="Send" Command="{Binding SendCommand}"
                        IsEnabled="{Binding !IsLoading}" MinWidth="70" FontSize="14"/>
                <SelectableTextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" IsVisible="{Binding IsLoading}"
                           Text="Thinking…" Classes="subtle-text" FontSize="14" Margin="0,4,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
