<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:McpServerManager.Core.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:McpServerManager.UI.Core.Models"
             xmlns:jsonModels="using:McpServerManager.UI.Core.Models.Json"
             xmlns:conv="using:McpServerManager.Core.Converters"
             xmlns:beh="using:McpServerManager.Core.Behaviors"
             xmlns:md="clr-namespace:Markdown.Avalonia;assembly=Markdown.Avalonia"
             xmlns:ctxt="clr-namespace:ColorTextBlock.Avalonia;assembly=ColorTextBlock.Avalonia"
             xmlns:avedit="https://github.com/avaloniaui/avaloniaedit"
             xmlns:views="using:McpServerManager.Desktop.Views"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="McpServerManager.Desktop.Views.McpServerManagerView"
             x:Name="ContentRoot"
             x:DataType="vm:MainWindowViewModel">

    <UserControl.Resources>
        <conv:PathToWslConverter x:Key="PathToWsl"/>
        <conv:EqualityToBrushConverter x:Key="EqualityToBrush"/>
        <conv:EmptyStringToAllConverter x:Key="EmptyStringToAll"/>
        <conv:FileNodeToArchiveVisibleConverter x:Key="FileNodeToArchiveVisible"/>
        <FontFamily x:Key="MarkdownCodeFontFamily">Cascadia Code, Monospace</FontFamily>
    </UserControl.Resources>
    <UserControl.Styles>
        <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CCode">
            <Setter Property="MonospaceFontFamily" Value="{StaticResource MarkdownCodeFontFamily}"/>
        </Style>
        <Style Selector=".Markdown_Avalonia_MarkdownViewer TextBlock.CodeBlock">
            <Setter Property="FontFamily" Value="{StaticResource MarkdownCodeFontFamily}"/>
        </Style>
        <Style Selector=".Markdown_Avalonia_MarkdownViewer .CodeBlock avedit|TextEditor">
            <Setter Property="FontFamily" Value="{StaticResource MarkdownCodeFontFamily}"/>
        </Style>
    </UserControl.Styles>

    <Grid x:Name="MainGrid" ColumnDefinitions="300, 4, *" RowDefinitions="*, 4, 150" Background="{DynamicResource ThemeBackgroundBrush}" Margin="8">
        <!-- Tree View -->
        <Border Grid.Column="0" Grid.Row="0" Classes="phone-card" Padding="4">
        <TreeView x:Name="TreePanel"
                  ItemsSource="{Binding Nodes}" SelectedItem="{Binding SelectedNode}"
                  Background="Transparent"
                  BorderThickness="0"
                  VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <TreeView.ItemTemplate>
                <TreeDataTemplate ItemsSource="{Binding Children}" DataType="models:FileNode">
                    <TextBlock Text="{Binding Name}"/>
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
            <TreeView.ItemContainerTheme>
                <ControlTheme TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}" x:DataType="models:FileNode">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    <Setter Property="ContextMenu">
                        <Setter.Value>
                            <ContextMenu x:CompileBindings="False">
                                <MenuItem Header="Open"
                                          Command="{Binding DataContext.OpenTreeItemCommand, ElementName=ContentRoot}"
                                          CommandParameter="{Binding}"/>
                                <MenuItem Header="Archive"
                                          Command="{Binding DataContext.ArchiveTreeItemCommand, ElementName=ContentRoot}"
                                          CommandParameter="{Binding}"
                                          IsVisible="{Binding Converter={StaticResource FileNodeToArchiveVisible}}"/>
                            </ContextMenu>
                        </Setter.Value>
                    </Setter>
                </ControlTheme>
            </TreeView.ItemContainerTheme>
        </TreeView>
        </Border>

        <!-- Splitter 1 -->
        <GridSplitter x:Name="Splitter1" Grid.Column="0" Grid.Row="1" ResizeDirection="Rows" Classes="phone-splitter"/>

        <!-- History Panel -->
        <Border x:Name="HistoryPanel" Grid.Column="0" Grid.Row="2" Classes="phone-card" Padding="4">
            <ListBox ItemsSource="{Binding ChangeLog}" Background="Transparent"/>
        </Border>

        <!-- Splitter 2 -->
        <GridSplitter x:Name="Splitter2" Grid.Column="1" Grid.Row="0" Grid.RowSpan="3" ResizeDirection="Columns" Classes="phone-splitter"/>

        <!-- Viewer Panel -->
        <Grid x:Name="ViewerPanel" Grid.Column="2" Grid.Row="0" Grid.RowSpan="3" RowDefinitions="Auto, *">
             <!-- Navigation Toolbar -->
             <Border Grid.Row="0" Classes="phone-toolbar-card" Padding="6" Margin="0,0,0,6">
             <Grid ColumnDefinitions="Auto, Auto, Auto, Auto, *">
                <Button Grid.Column="0" Command="{Binding NavigateBackCommand}" Margin="0,0,5,0" Width="30" ToolTip.Tip="Back">
                    <PathIcon Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" Width="10" Height="10"/>
                </Button>
                <Button Grid.Column="1" Command="{Binding NavigateForwardCommand}" Margin="0,0,5,0" Width="30" ToolTip.Tip="Forward">
                    <PathIcon Data="M4,11V13H16L10.5,18.5L11.92,19.92L19.84,12L11.92,4.08L10.5,5.5L16,11H4Z" Width="10" Height="10"/>
                </Button>
                <Button Grid.Column="2" Command="{Binding RefreshCommand}" Margin="0,0,5,0" Width="30" ToolTip.Tip="Refresh">
                    <PathIcon Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" Width="10" Height="10"/>
                </Button>
                <Button Grid.Column="3" Command="{Binding OpenChatWindowCommand}" Margin="0,0,5,0" ToolTip.Tip="AI Assistant">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <PathIcon Data="M12,2C6.48,2 2,6.48 2,12s4.48,10 10,10 10,-4.48 10,-10S17.52,2 12,2zM12,20c-4.41,0 -8,-3.59 -8,-8s3.59,-8 8,-8 8,3.59 8,8 -3.59,8 -8,8zM12.5,7H11v6l5.25,3.15 0.75,-1.23 -4.5,-2.67z" Width="14" Height="14"/>
                        <SelectableTextBlock Text="AI" VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                </Button>
                <TextBox Grid.Column="4" Text="{Binding SelectedNodePathDisplay, Mode=OneWay, Converter={StaticResource PathToWsl}}" IsReadOnly="True" VerticalContentAlignment="Center"/>
             </Grid>
             </Border>

             <!-- Markdown View -->
             <Border Grid.Row="1" Classes="phone-card" BorderBrush="{DynamicResource ItemBorderBrush}" BorderThickness="1" Margin="0" Padding="6" IsVisible="{Binding IsMarkdownVisible}">
                <Grid x:Name="MarkdownContentGrid" RowDefinitions="Auto, *">
                    <Border Grid.Row="0">
                    <SelectableTextBlock Text="Loading…" IsVisible="{Binding ShowMarkdownLoadingPlaceholder}"
                               VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{DynamicResource SubtleForeground}" Margin="12"/>
                    </Border>
                    <Border Grid.Row="1" IsVisible="{Binding IsPreviewOpenedInBrowser}" Padding="0">
                        <Grid RowDefinitions="Auto, *">
                            <Border Grid.Row="0" Padding="8,6" BorderBrush="{DynamicResource EntryBorderBrush}" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Open HTML preview in browser" Command="{Binding OpenPreviewInBrowserCommand}"/>
                                    <Button Content="Show raw text" Command="{Binding ToggleShowRawMarkdownCommand}"/>
                                    <Button Content="Archive" Command="{Binding ArchiveCommand}"/>
                                </StackPanel>
                            </Border>
                            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <Grid>
                                    <md:MarkdownScrollViewer x:Name="MarkdownViewer" Margin="12" IsVisible="{Binding ShowRenderedMarkdown}"
                                                             Markdown="{Binding CurrentPreviewMarkdownText}">
                                        <md:MarkdownScrollViewer.Resources>
                                            <FontFamily x:Key="MarkdownCodeFontFamily">Cascadia Code, Monospace</FontFamily>
                                        </md:MarkdownScrollViewer.Resources>
                                        <md:MarkdownScrollViewer.Styles>
                                            <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CCode">
                                                <Setter Property="MonospaceFontFamily" Value="{StaticResource MarkdownCodeFontFamily}"/>
                                            </Style>
                                            <Style Selector=".Markdown_Avalonia_MarkdownViewer TextBlock.CodeBlock">
                                                <Setter Property="FontFamily" Value="{StaticResource MarkdownCodeFontFamily}"/>
                                            </Style>
                                            <Style Selector=".Markdown_Avalonia_MarkdownViewer .CodeBlock avedit|TextEditor">
                                                <Setter Property="FontFamily" Value="{StaticResource MarkdownCodeFontFamily}"/>
                                            </Style>
                                        </md:MarkdownScrollViewer.Styles>
                                    </md:MarkdownScrollViewer>
                                    <TextBox Grid.Row="0" Margin="12" IsReadOnly="True" Text="{Binding CurrentPreviewMarkdownText}" TextWrapping="Wrap" IsVisible="{Binding ShowMarkdownAsRawText}" Background="Transparent" BorderThickness="0" FontFamily="{StaticResource MarkdownCodeFontFamily}"/>
                                </Grid>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
             </Border>

             <!-- JSON Tree View -->
             <Border Grid.Row="1" Classes="phone-card" BorderBrush="{DynamicResource ItemBorderBrush}" BorderThickness="1" Margin="0" Padding="6" IsVisible="{Binding IsJsonVisible}"
                     VerticalAlignment="Stretch" HorizontalAlignment="Stretch" MinHeight="320">
                <Grid x:Name="JsonViewerGrid" RowDefinitions="Auto, Auto, 200, 4, *"
                      VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                    <!-- Summary -->
                    <Border Grid.Row="0" Padding="8" Margin="0,0,0,4">
                        <ItemsControl ItemsSource="{Binding JsonLogSummary.SummaryLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="2" Padding="4" Background="Transparent">
                                        <SelectableTextBlock Text="{Binding}" FontSize="14"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                    <!-- Search -->
                    <Grid Grid.Row="1" ColumnDefinitions="Auto, *" Margin="0,0,0,4">
                        <SelectableTextBlock Grid.Column="0" Text="Search:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1" Text="{Binding SearchQuery}" PlaceholderText="Request ID, text, model, timestamp..."/>
                    </Grid>
                    <!-- Search results index -->
                    <Border Grid.Row="2" MinHeight="80" BorderBrush="{DynamicResource SearchBorderBrush}" BorderThickness="0,0,0,1" Padding="4" Margin="0,0,0,4">
                        <Grid RowDefinitions="Auto, Auto, *">
                            <SelectableTextBlock Grid.Row="0" Text="Search index (double-click to open request)" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                            <Border Grid.Row="1" BorderBrush="{DynamicResource EntryBorderBrush}" BorderThickness="0,0,0,1" Padding="0" Margin="0,0,0,0">
                                <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="250,*,100,100,130" Margin="4,2">
                                    <SelectableTextBlock Grid.Row="0" Grid.Column="0" Text="Request ID" FontWeight="SemiBold" FontSize="13" FontFamily="Consolas, Monospace" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <SelectableTextBlock Grid.Row="0" Grid.Column="1" Text="Display" FontWeight="SemiBold" FontSize="13" FontFamily="Consolas, Monospace" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <SelectableTextBlock Grid.Row="0" Grid.Column="2" Text="Model" FontWeight="SemiBold" FontSize="13" FontFamily="Consolas, Monospace" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <SelectableTextBlock Grid.Row="0" Grid.Column="3" Text="Agent" FontWeight="SemiBold" FontSize="13" FontFamily="Consolas, Monospace" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <SelectableTextBlock Grid.Row="0" Grid.Column="4" Text="Timestamp" FontWeight="SemiBold" FontSize="13" FontFamily="Consolas, Monospace" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="1" Grid.Column="0" ItemsSource="{Binding DistinctRequestIds}" SelectedItem="{Binding RequestIdFilter}" FontSize="12" FontFamily="Consolas, Monospace" Margin="0,2,8,0">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <SelectableTextBlock Text="{Binding Converter={StaticResource EmptyStringToAll}}" FontFamily="Consolas, Monospace" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding DistinctDisplayTexts}" SelectedItem="{Binding DisplayFilter}" FontSize="12" FontFamily="Consolas, Monospace" Margin="0,2,8,0">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <SelectableTextBlock Text="{Binding Converter={StaticResource EmptyStringToAll}}" FontFamily="Consolas, Monospace" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" MaxWidth="400"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <ComboBox Grid.Row="1" Grid.Column="2" ItemsSource="{Binding DistinctModels}" SelectedItem="{Binding ModelFilter}" FontSize="12" FontFamily="Consolas, Monospace" Margin="0,2,8,0">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <SelectableTextBlock Text="{Binding Converter={StaticResource EmptyStringToAll}}" FontFamily="Consolas, Monospace" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <ComboBox Grid.Row="1" Grid.Column="3" ItemsSource="{Binding DistinctAgents}" SelectedItem="{Binding AgentFilter}" FontSize="12" FontFamily="Consolas, Monospace" Margin="0,2,8,0">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <SelectableTextBlock Text="{Binding Converter={StaticResource EmptyStringToAll}}" FontFamily="Consolas, Monospace" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <ComboBox Grid.Row="1" Grid.Column="4" ItemsSource="{Binding DistinctTimestamps}" SelectedItem="{Binding TimestampFilter}" FontSize="12" FontFamily="Consolas, Monospace" Margin="0,2,0,0">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <SelectableTextBlock Text="{Binding Converter={StaticResource EmptyStringToAll}}" FontFamily="Consolas, Monospace" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="SearchIndexList" ItemsSource="{Binding FilteredSearchTurns}" x:CompileBindings="False">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Spacing="0"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="jsonModels:SearchableTurn">
                                            <Border BorderBrush="{DynamicResource EntryBorderBrush}" BorderThickness="0,0,0,1" Margin="2" Padding="4"
                                                    beh:TappedBehavior.Command="{Binding DataContext.SearchRowTappedCommand, ElementName=ContentRoot}"
                                                    beh:TappedBehavior.CommandParameter="{Binding}"
                                                    beh:DoubleTappedBehavior.Command="{Binding DataContext.SearchRowDoubleTappedCommand, ElementName=ContentRoot}"
                                                    beh:DoubleTappedBehavior.CommandParameter="{Binding}">
                                                <Border.Background>
                                                    <MultiBinding Converter="{StaticResource EqualityToBrush}">
                                                        <Binding Path="."/>
                                                        <Binding Path="DataContext.SelectedSearchTurn" ElementName="ContentRoot"/>
                                                    </MultiBinding>
                                                </Border.Background>
                                                <Grid ColumnDefinitions="250,*,100,100,130" Margin="0">
                                                    <SelectableTextBlock Grid.Column="0" Text="{Binding RequestId}" FontFamily="Consolas, Monospace" FontSize="13" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <SelectableTextBlock Grid.Column="1" Text="{Binding DisplayText}" FontFamily="Consolas, Monospace" FontSize="13" TextWrapping="Wrap" VerticalAlignment="Top" Margin="0,0,8,0"/>
                                                    <SelectableTextBlock Grid.Column="2" Text="{Binding Model}" FontFamily="Consolas, Monospace" FontSize="13" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <SelectableTextBlock Grid.Column="3" Text="{Binding Agent}" FontFamily="Consolas, Monospace" FontSize="13" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <SelectableTextBlock Grid.Column="4" Text="{Binding TimestampDisplay}" FontFamily="Consolas, Monospace" FontSize="13" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    <!-- Splitter between search index and JSON tree -->
                    <GridSplitter Grid.Row="3" ResizeDirection="Rows" Classes="phone-splitter" Height="4"/>
                    <!-- Tree -->
                    <Border Grid.Row="4" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" MinHeight="180">
                        <TreeView x:Name="JsonTreeView" ItemsSource="{Binding JsonTree}" SelectedItem="{Binding SelectedJsonNode}"
                                  VerticalAlignment="Stretch" HorizontalAlignment="Stretch" MinHeight="180">
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate ItemsSource="{Binding Children}" DataType="jsonModels:JsonTreeNode">
                                    <StackPanel Orientation="Horizontal" Spacing="5" Background="Transparent" x:CompileBindings="False"
                                                beh:DoubleTappedBehavior.Command="{Binding DataContext.JsonNodeDoubleTappedCommand, ElementName=ContentRoot}"
                                                beh:DoubleTappedBehavior.CommandParameter="{Binding}">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{DynamicResource JsonKeyBrush}"/>
                                        <TextBlock Text=":" Foreground="{DynamicResource SubtleForeground}"/>
                                        <TextBlock Text="{Binding Value}" Foreground="{DynamicResource JsonValueBrush}"/>
                                        <TextBlock Text="{Binding Type}" Foreground="{DynamicResource SubtleForeground}" FontStyle="Italic" FontSize="12" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    </StackPanel>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                            <TreeView.ItemContainerTheme>
                                <ControlTheme TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}" x:DataType="jsonModels:JsonTreeNode">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                </ControlTheme>
                            </TreeView.ItemContainerTheme>
                        </TreeView>
                    </Border>
                </Grid>
             </Border>

             <!-- Request Details View -->
             <Border Grid.Row="1" Classes="phone-card" BorderBrush="{DynamicResource ItemBorderBrush}" BorderThickness="1" Margin="0" Padding="6" IsVisible="{Binding IsRequestDetailsVisible}">
                <Grid RowDefinitions="Auto, *">
                    <Border Grid.Row="0" Classes="phone-toolbar-card" Padding="6" Margin="0,0,0,6">
                    <Grid ColumnDefinitions="Auto, Auto, Auto, *" VerticalAlignment="Center">
                        <Button Grid.Column="0" Content="← Back to List" Command="{Binding CloseRequestDetailsCommand}" Margin="0,0,10,0"/>
                        <Button Grid.Column="1" Content="← Previous" Command="{Binding NavigateToPreviousRequestCommand}" Margin="0,0,10,0"/>
                        <Button Grid.Column="2" Content="Next →" Command="{Binding NavigateToNextRequestCommand}" Margin="0,0,10,0"/>
                    </Grid>
                    </Border>
                    <Border Grid.Row="1">
                    <views:RequestDetailsView DataContext="{Binding SelectedUnifiedTurn}"/>
                    </Border>
                </Grid>
             </Border>

        </Grid>

    </Grid>

</UserControl>

