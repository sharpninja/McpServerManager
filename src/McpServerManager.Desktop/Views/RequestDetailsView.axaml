<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:McpServer.UI.Core.Models.Json;assembly=McpServer.UI.Core"
             xmlns:conv="clr-namespace:McpServerManager.Core.Converters;assembly=McpServerManager.Core"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="McpServerManager.Desktop.Views.RequestDetailsView"
             x:DataType="models:UnifiedRequestEntry">

  <UserControl.Resources>
      <conv:ObjectToJsonConverter x:Key="ObjectToJson"/>
      <conv:CountToVisibilityConverter x:Key="CountToVisibility"/>
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="Expander">
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0,2"/>
      <Setter Property="IsExpanded" Value="True"/>
    </Style>
    <Style Selector="Expander /template/ Border#ExpanderContent">
      <Setter Property="Padding" Value="4"/>
    </Style>
  </UserControl.Styles>

  <ScrollViewer Background="{DynamicResource ThemeBackgroundBrush}">
    <StackPanel Spacing="8" Margin="8">
      <!-- Header -->
      <Grid ColumnDefinitions="*, Auto">
        <StackPanel Grid.Column="0">
          <SelectableTextBlock Text="{Binding QueryTitle}" FontSize="20" FontWeight="Bold" TextWrapping="Wrap" />
          <SelectableTextBlock Text="{Binding RequestId}" FontSize="14" Foreground="{DynamicResource SubtleForeground}" />
        </StackPanel>
        <SelectableTextBlock Grid.Column="1" Text="{Binding TimestampLocalDisplay}" FontSize="14" Foreground="{DynamicResource SubtleForeground}" />
      </Grid>

      <!-- Metadata Badges -->
      <WrapPanel Orientation="Horizontal">
        <WrapPanel.Styles>
          <Style Selector="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="{DynamicResource BadgeBrush}"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
          </Style>
          <Style Selector="SelectableTextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="Black"/>
          </Style>
        </WrapPanel.Styles>

        <Border><SelectableTextBlock Text="{Binding Model}" /></Border>
        <Border IsVisible="{Binding ModelProvider, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <SelectableTextBlock Text="{Binding ModelProvider}" />
        </Border>
        <Border IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <SelectableTextBlock Text="{Binding Status}" />
        </Border>
        <Border><SelectableTextBlock Text="{Binding TokenCount, StringFormat='Tokens: {0}'}" /></Border>
        <Border IsVisible="{Binding IsPremium}"><SelectableTextBlock Text="Premium" Foreground="DarkGoldenrod"/></Border>
        <Border IsVisible="{Binding Score, Converter={x:Static ObjectConverters.IsNotNull}}">
            <SelectableTextBlock Text="{Binding Score, StringFormat='Score: {0}'}" />
        </Border>
      </WrapPanel>

      <Border Classes="phone-divider" />

      <!-- Query -->
      <Expander Header="Query" IsExpanded="True" HorizontalAlignment="Stretch">
        <Border BorderBrush="{DynamicResource ItemBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10" Background="{DynamicResource ContentBgBrush}">
          <SelectableTextBlock Text="{Binding QueryText}" TextWrapping="Wrap" FontFamily="Consolas, Monospace" Foreground="Black" />
        </Border>
      </Expander>

      <!-- Interpretation -->
      <Expander Header="Interpretation" IsExpanded="True" HorizontalAlignment="Stretch" IsVisible="{Binding Interpretation, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <Border BorderBrush="{DynamicResource ItemBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10" Background="{DynamicResource InterpretationBgBrush}">
          <SelectableTextBlock Text="{Binding Interpretation}" TextWrapping="Wrap" FontFamily="Segoe UI, Sans-Serif" Foreground="Black" />
        </Border>
      </Expander>

      <!-- Response -->
      <Expander Header="Response" IsExpanded="True" HorizontalAlignment="Stretch">
        <Border BorderBrush="{DynamicResource ItemBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10" Background="{DynamicResource ContentBgBrush}">
          <SelectableTextBlock Text="{Binding Response}" TextWrapping="Wrap" FontFamily="Consolas, Monospace" Foreground="Black" />
        </Border>
      </Expander>

      <Expander Header="{Binding ProcessingDialog.Count, StringFormat='Processing Dialog ({0})'}" IsExpanded="True" HorizontalAlignment="Stretch">
          <Border BorderBrush="{DynamicResource ItemBorderBrush}" BorderThickness="1" CornerRadius="6" Background="{DynamicResource ThemeBackgroundBrush}" Padding="12" MinHeight="80">
              <Grid>
                  <SelectableTextBlock Text="No processing dialog recorded." Foreground="{DynamicResource SubtleForeground}" FontStyle="Italic" HorizontalAlignment="Center" VerticalAlignment="Center"
                             IsVisible="{Binding ProcessingDialog, Converter={StaticResource CountToVisibility}, ConverterParameter='Invert'}"/>
                  <StackPanel IsVisible="{Binding ProcessingDialog, Converter={StaticResource CountToVisibility}}">
                      <Border BorderBrush="{DynamicResource EntryBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,4" Margin="0,0,0,6">
                          <Grid ColumnDefinitions="160,90,100,*">
                              <SelectableTextBlock Grid.Column="0" Text="Timestamp" FontFamily="Consolas, Monospace" FontSize="14" FontWeight="SemiBold"/>
                              <SelectableTextBlock Grid.Column="1" Text="Role" FontFamily="Consolas, Monospace" FontSize="14" FontWeight="SemiBold"/>
                              <SelectableTextBlock Grid.Column="2" Text="Category" FontFamily="Consolas, Monospace" FontSize="14" FontWeight="SemiBold"/>
                              <SelectableTextBlock Grid.Column="3" Text="Content" FontFamily="Consolas, Monospace" FontSize="14" FontWeight="SemiBold" Margin="4,0"/>
                          </Grid>
                      </Border>
                      <ItemsControl ItemsSource="{Binding ProcessingDialog}">
                          <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                  <StackPanel Spacing="4"/>
                              </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                              <DataTemplate DataType="models:UnifiedProcessingDialogItem">
                                  <Border BorderBrush="{DynamicResource EntryBorderBrush}" BorderThickness="0,0,0,1" Margin="2" Padding="4">
                                      <Grid ColumnDefinitions="160,90,100,*">
                                          <SelectableTextBlock Grid.Column="0" Text="{Binding TimestampDisplay}" FontFamily="Consolas, Monospace" FontSize="13"/>
                                          <SelectableTextBlock Grid.Column="1" Text="{Binding Role}" FontFamily="Consolas, Monospace" FontSize="13"/>
                                          <SelectableTextBlock Grid.Column="2" Text="{Binding Category}" FontFamily="Consolas, Monospace" FontSize="13"/>
                                          <SelectableTextBlock Grid.Column="3" Text="{Binding Content}" FontFamily="Consolas, Monospace" FontSize="13" TextWrapping="Wrap" Margin="4,0"/>
                                      </Grid>
                                  </Border>
                              </DataTemplate>
                          </ItemsControl.ItemTemplate>
                      </ItemsControl>
                  </StackPanel>
              </Grid>
          </Border>
      </Expander>

      <!-- Actions -->
      <Expander Header="{Binding Actions.Count, StringFormat='Actions ({0})'}" IsExpanded="True" HorizontalAlignment="Stretch">
          <Border BorderBrush="{DynamicResource ItemBorderBrush}" BorderThickness="1" CornerRadius="6" Background="{DynamicResource ThemeBackgroundBrush}" Padding="12" MinHeight="80">
              <Grid>
                  <SelectableTextBlock Text="No actions recorded." Foreground="{DynamicResource SubtleForeground}" FontStyle="Italic" HorizontalAlignment="Center" VerticalAlignment="Center"
                             IsVisible="{Binding Actions, Converter={StaticResource CountToVisibility}, ConverterParameter='Invert'}"/>
                  <StackPanel IsVisible="{Binding Actions, Converter={StaticResource CountToVisibility}}">
                      <Border BorderBrush="{DynamicResource EntryBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,4" Margin="0,0,0,6">
                          <Grid ColumnDefinitions="40,100,*,90,120">
                              <SelectableTextBlock Grid.Column="0" Text="#" FontFamily="Consolas, Monospace" FontSize="14" FontWeight="SemiBold"/>
                              <SelectableTextBlock Grid.Column="1" Text="Type" FontFamily="Consolas, Monospace" FontSize="14" FontWeight="SemiBold"/>
                              <SelectableTextBlock Grid.Column="2" Text="Description" FontFamily="Consolas, Monospace" FontSize="14" FontWeight="SemiBold" Margin="4,0"/>
                              <SelectableTextBlock Grid.Column="3" Text="Status" FontFamily="Consolas, Monospace" FontSize="14" FontWeight="SemiBold"/>
                              <SelectableTextBlock Grid.Column="4" Text="File Path" FontFamily="Consolas, Monospace" FontSize="14" FontWeight="SemiBold"/>
                          </Grid>
                      </Border>
                      <ItemsControl ItemsSource="{Binding Actions}">
                          <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                  <StackPanel Spacing="4"/>
                              </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                              <DataTemplate DataType="models:UnifiedAction">
                                  <Border BorderBrush="{DynamicResource EntryBorderBrush}" BorderThickness="0,0,0,1" Margin="2" Padding="4">
                                      <Grid ColumnDefinitions="40,100,*,90,120">
                                          <SelectableTextBlock Grid.Column="0" Text="{Binding Order}" FontFamily="Consolas, Monospace" FontSize="14"/>
                                          <SelectableTextBlock Grid.Column="1" Text="{Binding Type}" FontFamily="Consolas, Monospace" FontSize="14" TextWrapping="Wrap"/>
                                          <SelectableTextBlock Grid.Column="2" Text="{Binding Description}" FontFamily="Consolas, Monospace" FontSize="14" TextWrapping="Wrap" Margin="4,0"/>
                                          <SelectableTextBlock Grid.Column="3" Text="{Binding Status}" FontFamily="Consolas, Monospace" FontSize="14"/>
                                          <SelectableTextBlock Grid.Column="4" Text="{Binding FilePath}" FontFamily="Consolas, Monospace" FontSize="14" TextWrapping="Wrap"/>
                                      </Grid>
                                  </Border>
                              </DataTemplate>
                          </ItemsControl.ItemTemplate>
                      </ItemsControl>
                  </StackPanel>
              </Grid>
          </Border>
      </Expander>

      <!-- Context -->
      <Expander Header="Context" IsExpanded="True" HorizontalAlignment="Stretch">
        <ItemsControl ItemsSource="{Binding ContextList}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Margin="2" Padding="4" Background="Transparent">
                <SelectableTextBlock Text="{Binding}" FontSize="14" TextWrapping="Wrap"/>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Expander>

      <!-- Tags/Notes -->
      <Expander Header="Tags &amp; Notes" IsExpanded="True" HorizontalAlignment="Stretch">
        <StackPanel Spacing="5">
            <SelectableTextBlock Text="{Binding FailureNote, StringFormat='Failure Note: {0}'}"
                       IsVisible="{Binding FailureNote, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       Foreground="Red"/>
            <ItemsControl ItemsSource="{Binding Tags}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Spacing="5" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                   <Border Margin="2" Padding="4" Background="Transparent">
                     <SelectableTextBlock Text="{Binding}" FontSize="14" TextWrapping="Wrap"/>
                   </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
      </Expander>

      <!-- Original JSON -->
      <Expander Header="Original JSON" IsExpanded="True" HorizontalAlignment="Stretch" x:CompileBindings="False">
          <StackPanel Spacing="6" HorizontalAlignment="Stretch">
            <Button Content="Copy" Command="{Binding DataContext.CopyOriginalJsonCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}" HorizontalAlignment="Right"/>
            <Border BorderBrush="{DynamicResource ItemBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10" Background="{DynamicResource ContentBgBrush}" HorizontalAlignment="Stretch">
              <SelectableTextBlock Text="{Binding OriginalEntry, Converter={StaticResource ObjectToJson}}"
                                 TextWrapping="Wrap" FontFamily="Consolas, Monospace" Foreground="Black" HorizontalAlignment="Stretch"/>
            </Border>
          </StackPanel>
      </Expander>

    </StackPanel>
  </ScrollViewer>
</UserControl>

