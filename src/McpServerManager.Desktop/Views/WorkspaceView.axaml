<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:McpServerManager.Core.ViewModels"
             xmlns:avedit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="McpServerManager.Desktop.Views.WorkspaceView"
             x:Name="WorkspaceRoot"
             x:DataType="vm:WorkspaceViewModel">

  <Grid RowDefinitions="Auto,Auto,Auto,*" Background="{DynamicResource ThemeBackgroundBrush}" Margin="8">
    <Border Grid.Row="0" Classes="phone-toolbar-card" Padding="8" Margin="0,0,0,6">
    <StackPanel Orientation="Horizontal" Spacing="6">
      <Button Content="+ New" Command="{Binding NewWorkspaceCommand}" Padding="8,4"/>
      <Button Content="Refresh" Command="{Binding RefreshCommand}" Padding="8,4"/>
      <Button Content="Reload" Command="{Binding OpenSelectedWorkspaceCommand}" Padding="8,4"/>
      <Button Content="Copy Key" Command="{Binding CopySelectedKeyCommand}" Padding="8,4"/>
      <Button Content="Status" Command="{Binding GetSelectedStatusCommand}" Padding="8,4"/>
      <Button Content="Health" Command="{Binding CheckSelectedWorkspaceHealthCommand}" Padding="8,4"/>
      <Button Content="Init" Command="{Binding InitSelectedWorkspaceCommand}" Padding="8,4"/>
      <Button Content="Start" Command="{Binding StartSelectedWorkspaceCommand}" Padding="8,4"/>
      <Button Content="Stop" Command="{Binding StopSelectedWorkspaceCommand}" Padding="8,4"/>
      <Button Content="Delete" Command="{Binding DeleteSelectedCommand}" Padding="8,4"/>
    </StackPanel>
    </Border>

    <Border Grid.Row="1" Classes="phone-toolbar-card" Padding="8" Margin="0,0,0,6">
    <Grid ColumnDefinitions="*,Auto">
      <TextBox Grid.Column="0"
               Text="{Binding FilterText, Mode=TwoWay}"
               Watermark="Filter workspaces..."/>
      <Button Grid.Column="1"
              Content="Clear"
              Command="{Binding ClearFiltersCommand}"
              Margin="4,0,0,0"
              Padding="8,4"/>
    </Grid>
    </Border>

    <Border Grid.Row="2" Classes="phone-outline-card" Padding="8,6" Margin="0,0,0,6">
      <SelectableTextBlock Text="{Binding StatusText}" FontSize="12" Classes="subtle-text"/>
    </Border>

    <Grid x:Name="ContentGrid" Grid.Row="3"
          ColumnDefinitions="1*,4,2*" RowDefinitions="*">
      <Border x:Name="ListPanel" Grid.Column="0" Classes="phone-card" Padding="4">
        <ListBox ItemsSource="{Binding FilteredItems}"
                 SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                 Margin="0"
                 Background="Transparent"
                 BorderThickness="0">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:WorkspaceListEntry">
              <Border Padding="4" Margin="2" CornerRadius="4" Background="Transparent">
                <StackPanel Spacing="1">
                    <TextBlock Text="{Binding Key}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Title}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Subtitle}"
                               FontSize="11"
                               Foreground="{DynamicResource SubtleForeground}"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>

      <GridSplitter x:Name="WorkspaceSplitter"
                    Grid.Column="1"
                    Classes="phone-splitter"
                    ResizeDirection="Columns"/>

      <Border x:Name="EditorPanel" Grid.Column="2" Classes="phone-card" Padding="8">
        <Grid RowDefinitions="Auto,Auto,220,8,*">
          <Border Grid.Row="0" Classes="phone-toolbar-card" Padding="8" Margin="0,0,0,6">
          <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="6">
            <StackPanel Grid.Column="0" Spacing="2">
              <SelectableTextBlock Text="Global Prompt Template" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding GlobalPromptStatusText}" FontSize="11" Foreground="{DynamicResource SubtleForeground}"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Load" Command="{Binding LoadGlobalPromptCommand}" Padding="10,4"/>
            <Button Grid.Column="2" Content="Save" Command="{Binding SaveGlobalPromptCommand}" Padding="10,4"/>
            <Button Grid.Column="3" Content="Reset" Command="{Binding ResetGlobalPromptCommand}" Padding="10,4"/>
            <Button Grid.Column="4" Content="Reload" Command="{Binding LoadGlobalPromptCommand}" Padding="10,4"/>
          </Grid>
          </Border>

          <TextBlock Grid.Row="1"
                     Text="Default template applied to workspaces without a workspace-specific prompt."
                     FontSize="11"
                     Foreground="{DynamicResource SubtleForeground}"
                     Margin="0,4,0,4"
                     TextWrapping="Wrap"/>

          <Border Grid.Row="2"
                  BorderBrush="{DynamicResource ItemBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="6">
            <avedit:TextEditor x:Name="GlobalPromptEditor"
                               FontFamily="Cascadia Code,Consolas,Menlo,monospace"
                               FontSize="13"
                               ShowLineNumbers="True"
                               WordWrap="True"/>
          </Border>

          <Border Grid.Row="3"
                  Height="1"
                  Background="{DynamicResource DividerBrush}"
                  Margin="0,3,0,4"/>

          <ScrollViewer Grid.Row="4">
            <StackPanel Spacing="8">
              <SelectableTextBlock Text="{Binding EditorModeText}" FontWeight="SemiBold"/>

              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Key"/>
                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding EditorKey}"
                         IsReadOnly="True"/>

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Name"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EditorName, Mode=TwoWay}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Workspace Path"/>
                <TextBox Grid.Row="2" Grid.Column="1"
                         Text="{Binding EditorWorkspacePath, Mode=TwoWay}"
                         IsReadOnly="{Binding IsEditingExisting}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Todo Path"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding EditorTodoPath, Mode=TwoWay}"/>

                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Data Directory"/>
                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding EditorDataDirectory, Mode=TwoWay}"/>

                <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="Tunnel Provider"/>
                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding EditorTunnelProvider, Mode=TwoWay}"/>

                <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Text="Run As"/>
                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding EditorRunAs, Mode=TwoWay}"/>

                <TextBlock Grid.Row="7" Grid.Column="0" VerticalAlignment="Center" Text="Is Primary"/>
                <CheckBox Grid.Row="7" Grid.Column="1"
                          IsChecked="{Binding EditorIsPrimary, Mode=TwoWay}"
                          VerticalAlignment="Center"/>

                <TextBlock Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" Text="Is Enabled"/>
                <CheckBox Grid.Row="8" Grid.Column="1"
                          IsChecked="{Binding EditorIsEnabled, Mode=TwoWay}"
                          VerticalAlignment="Center"/>
              </Grid>

              <SelectableTextBlock Text="Workspace Prompt Template" FontWeight="SemiBold"/>
              <TextBlock Text="Leave blank to inherit the global prompt template."
                         FontSize="11"
                         Foreground="{DynamicResource SubtleForeground}"
                         TextWrapping="Wrap"/>
              <Border BorderBrush="{DynamicResource ItemBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="6">
                <avedit:TextEditor x:Name="WorkspacePromptEditor"
                                   Height="220"
                                   FontFamily="Cascadia Code,Consolas,Menlo,monospace"
                                   FontSize="13"
                                   ShowLineNumbers="True"
                                   WordWrap="True"/>
              </Border>

              <SelectableTextBlock Text="Status Prompt Override" FontWeight="SemiBold"/>
              <TextBlock Text="Optional workspace-specific override for status generation. Leave blank to inherit."
                         FontSize="11"
                         Foreground="{DynamicResource SubtleForeground}"
                         TextWrapping="Wrap"/>
              <Border BorderBrush="{DynamicResource ItemBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="6">
                <avedit:TextEditor x:Name="WorkspaceStatusPromptEditor"
                                   Height="160"
                                   FontFamily="Cascadia Code,Consolas,Menlo,monospace"
                                   FontSize="13"
                                   ShowLineNumbers="True"
                                   WordWrap="True"/>
              </Border>

              <SelectableTextBlock Text="Implement Prompt Override" FontWeight="SemiBold"/>
              <TextBlock Text="Optional workspace-specific override for implement generation. Leave blank to inherit."
                         FontSize="11"
                         Foreground="{DynamicResource SubtleForeground}"
                         TextWrapping="Wrap"/>
              <Border BorderBrush="{DynamicResource ItemBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="6">
                <avedit:TextEditor x:Name="WorkspaceImplementPromptEditor"
                                   Height="160"
                                   FontFamily="Cascadia Code,Consolas,Menlo,monospace"
                                   FontSize="13"
                                   ShowLineNumbers="True"
                                   WordWrap="True"/>
              </Border>

              <SelectableTextBlock Text="Plan Prompt Override" FontWeight="SemiBold"/>
              <TextBlock Text="Optional workspace-specific override for plan generation. Leave blank to inherit."
                         FontSize="11"
                         Foreground="{DynamicResource SubtleForeground}"
                         TextWrapping="Wrap"/>
              <Border BorderBrush="{DynamicResource ItemBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="6">
                <avedit:TextEditor x:Name="WorkspacePlanPromptEditor"
                                   Height="160"
                                   FontFamily="Cascadia Code,Consolas,Menlo,monospace"
                                   FontSize="13"
                                   ShowLineNumbers="True"
                                   WordWrap="True"/>
              </Border>

              <TextBlock Text="{Binding ProcessStatusText}" TextWrapping="Wrap" Foreground="{DynamicResource SubtleForeground}"/>

              <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Content="Save" Command="{Binding SaveEditorCommand}" Padding="12,4"/>
                <Button Content="Reload Selected" Command="{Binding OpenSelectedWorkspaceCommand}" Padding="12,4"/>
                <Button Content="New Draft" Command="{Binding NewWorkspaceCommand}" Padding="12,4"/>
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>
