<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:McpServerManager.Core.ViewModels"
             xmlns:avedit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             mc:Ignorable="d"
             d:DesignWidth="900"
             d:DesignHeight="600"
             x:Class="McpServerManager.Desktop.Views.AgentsReadmeView"
             x:DataType="vm:MainWindowViewModel">
  <Grid RowDefinitions="Auto,Auto,Auto,*" Background="{DynamicResource ThemeBackgroundBrush}" Margin="8">
    <Border Grid.Row="0" Classes="phone-toolbar-card" Padding="8" Margin="0,0,0,6">
      <StackPanel Spacing="2">
        <SelectableTextBlock Text="AGENTS-README-FIRST.yaml" FontWeight="SemiBold" FontSize="14"/>
        <TextBlock Text="{Binding AgentsReadmeStatusText}" FontSize="12" Classes="subtle-text" TextWrapping="Wrap"/>
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Margin="4,0,4,4"
            Padding="4"
            BorderBrush="{DynamicResource SystemBaseMediumLowColor}"
            BorderThickness="1"
            CornerRadius="4"
            Classes="phone-card">
      <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
        <TextBlock Grid.Column="0" Text="Path" VerticalAlignment="Top" FontWeight="SemiBold"/>
        <SelectableTextBlock Grid.Column="1"
                             Text="{Binding AgentsReadmeFilePath}"
                             TextWrapping="Wrap"
                             ToolTip.Tip="{Binding AgentsReadmeFilePath}"/>
      </Grid>
    </Border>

    <Border Grid.Row="2" Classes="phone-outline-card" Padding="8,6" Margin="0,0,0,6">
      <Grid ColumnDefinitions="Auto,*,Auto,*"
            ColumnSpacing="8">
        <TextBlock Grid.Column="0" Text="File Timestamp" VerticalAlignment="Center" FontWeight="SemiBold"/>
        <SelectableTextBlock Grid.Column="1"
                             Text="{Binding AgentsReadmeFileTimestampText}"
                             VerticalAlignment="Center"
                             Classes="subtle-text"/>
        <TextBlock Grid.Column="2" Text="Loaded (Local)" VerticalAlignment="Center" FontWeight="SemiBold"/>
        <SelectableTextBlock Grid.Column="3"
                             Text="{Binding AgentsReadmeLoadedAtLocalText}"
                             VerticalAlignment="Center"
                             Classes="subtle-text"/>
      </Grid>
    </Border>

    <Border Grid.Row="3"
            Margin="0"
            Classes="phone-card"
            Padding="6">
      <avedit:TextEditor x:Name="AgentsReadmeEditor"
                         IsReadOnly="True"
                         ShowLineNumbers="True"
                         WordWrap="False"
                         FontFamily="Cascadia Code,Consolas,Menlo,monospace"
                         FontSize="13"/>
    </Border>
  </Grid>
</UserControl>
