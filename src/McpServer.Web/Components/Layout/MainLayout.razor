@inherits LayoutComponentBase
@inject WorkspaceAutoSelector WorkspaceAutoSelector
@inject BackendConnectionMonitor ConnectionMonitor
@inject WebVoiceConversationViewModel AgentChatViewModel
@implements IDisposable

<div class="d-flex flex-column" style="min-height: 100vh">
    <header class="Header app-header-sticky">
        <div class="Header-item">
            <a href="/" class="Header-link f4 d-flex flex-items-center">
                <OcticonIcon Name="server" Class="mr-2" />
                <span class="text-bold">McpServer</span>
            </a>
        </div>
        <div class="Header-item">
            <nav class="header-nav" aria-label="Main navigation">
                <NavMenu />
            </nav>
        </div>
        <div class="Header-item Header-item--full"></div>
        <div class="Header-item">
            @if (!_isConnected)
            {
                <span class="Label Label--danger mr-2" title="@_lastError">
                    <OcticonIcon Name="alert" Class="mr-1" />Disconnected
                </span>
            }
        </div>
        <div class="Header-item">
            <button type="button"
                    class="btn btn-sm"
                    id="agent-chat-launch"
                    aria-controls="agent-chat-flyout"
                    aria-expanded="@_isAgentChatOpen"
                    @onclick="ToggleAgentChat">
                Agent Chat
            </button>
        </div>
        <div class="Header-item">
            <AuthorizeView>
                <Authorized>
                    <span class="color-fg-on-emphasis mr-2">@context.User.Identity?.Name</span>
                    <a class="Header-link" href="/logout">Sign out</a>
                </Authorized>
                <NotAuthorized>
                    <a class="Header-link" href="/login">Sign in</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </header>

    @if (!_isConnected)
    {
        <div class="flash flash-error" role="alert">
            <OcticonIcon Name="alert" Class="mr-2" />
            <strong>Backend unavailable</strong> — Cannot reach the MCP server at the configured address. Retrying automatically&hellip;
            @if (!string.IsNullOrWhiteSpace(_lastError))
            {
                <span class="text-small ml-2">(@_lastError)</span>
            }
        </div>
    }

    <div class="app-shell flex-1 @(_isAgentChatOpen && _isAgentChatInline ? "app-shell--with-inline-chat" : null)">
        <main class="app-content flex-1">
            @Body
        </main>

        <AgentChatFlyout ViewModel="AgentChatViewModel"
                         IsOpen="@_isAgentChatOpen"
                         IsInline="@_isAgentChatInline"
                         OnClose="CloseAgentChatAsync"
                         OnInlineModeChanged="SetAgentChatInlineModeAsync" />
    </div>
</div>

@code {
    private bool _isConnected = true;
    private string? _lastError;
    private bool _isAgentChatOpen;
    private bool _isAgentChatInline;

    protected override async Task OnInitializedAsync()
    {
        ConnectionMonitor.PropertyChanged += OnConnectionChanged;
        ConnectionMonitor.Start();
        await WorkspaceAutoSelector.EnsureWorkspaceSelectedAsync().ConfigureAwait(true);
        _isConnected = ConnectionMonitor.IsConnected;
        _lastError = ConnectionMonitor.LastError;
    }

    private void OnConnectionChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e)
    {
        if (e.PropertyName is nameof(BackendConnectionMonitor.IsConnected)
            or nameof(BackendConnectionMonitor.LastError))
        {
            _isConnected = ConnectionMonitor.IsConnected;
            _lastError = ConnectionMonitor.LastError;
            InvokeAsync(StateHasChanged);
        }
    }

    private void ToggleAgentChat()
    {
        _isAgentChatOpen = !_isAgentChatOpen;
    }

    private Task CloseAgentChatAsync()
    {
        _isAgentChatOpen = false;
        return Task.CompletedTask;
    }

    private Task SetAgentChatInlineModeAsync(bool isInline)
    {
        _isAgentChatInline = isInline;
        return Task.CompletedTask;
    }

    public void Dispose()
    {
        ConnectionMonitor.PropertyChanged -= OnConnectionChanged;
    }
}
