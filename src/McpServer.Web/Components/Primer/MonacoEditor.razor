@using BlazorMonaco
@using BlazorMonaco.Editor

<div style="height: @(Height)px; position: relative;">
    <StandaloneCodeEditor @ref="_editor"
                          Id="@_elementId"
                          ConstructionOptions="GetOptions"
                          OnDidInit="OnEditorInit"
                          OnDidChangeModelContent="OnContentChanged"
                          CssClass="monaco-editor-container" />
</div>

@code {
    private StandaloneCodeEditor _editor = null!;
    private readonly string _elementId = $"monaco-{Guid.NewGuid():N}";
    private bool _suppressChange;
    private bool _editorReady;

    /// <summary>Editor content value.</summary>
    [Parameter]
    public string? Value { get; set; }

    /// <summary>Callback invoked when editor content changes.</summary>
    [Parameter]
    public EventCallback<string> ValueChanged { get; set; }

    /// <summary>Editor language mode.</summary>
    [Parameter]
    public string Language { get; set; } = "markdown";

    /// <summary>Whether the editor is read-only.</summary>
    [Parameter]
    public bool ReadOnly { get; set; }

    /// <summary>Editor height in pixels.</summary>
    [Parameter]
    public int Height { get; set; } = 600;

    private StandaloneEditorConstructionOptions GetOptions(StandaloneCodeEditor editor) => new()
    {
        Value = Value ?? string.Empty,
        Language = Language,
        ReadOnly = ReadOnly,
        Theme = "vs",
        AutomaticLayout = true,
        Minimap = new EditorMinimapOptions { Enabled = false },
        WordWrap = "on",
        ScrollBeyondLastLine = false,
        FontSize = 14,
        Padding = new EditorPaddingOptions { Top = 8, Bottom = 8 },
        LineNumbers = "on",
    };

    private Task OnEditorInit()
    {
        _editorReady = true;
        return Task.CompletedTask;
    }

    /// <inheritdoc />
    protected override async Task OnParametersSetAsync()
    {
        if (!_editorReady)
            return;

        try
        {
            var current = await _editor.GetValue().ConfigureAwait(true);
            if (!string.Equals(current, Value, StringComparison.Ordinal))
            {
                _suppressChange = true;
                await _editor.SetValue(Value ?? string.Empty).ConfigureAwait(true);
                _suppressChange = false;
            }
        }
        catch
        {
            // Editor not yet initialized or circuit disconnected.
        }
    }

    private async Task OnContentChanged(ModelContentChangedEvent e)
    {
        if (_suppressChange)
            return;

        var value = await _editor.GetValue().ConfigureAwait(true);
        await ValueChanged.InvokeAsync(value).ConfigureAwait(true);
    }
}
