@page "/todos"
@inherits McpServer.Web.Components.UiDispatcherComponentBase

@inject TodoListViewModel ViewModel
@inject WebCommandTarget CommandTarget

<PageTitle>Todo List</PageTitle>

<h1 class="h2 mb-3">Todo List</h1>

<form method="get" class="Box p-3 mb-3">
    <div class="d-flex flex-wrap gap-3">
        <label class="d-flex flex-column">
            <span class="text-small color-fg-muted">Section</span>
            <input class="form-control" name="section" value="@Section" />
        </label>
        <label class="d-flex flex-column">
            <span class="text-small color-fg-muted">Priority</span>
            <input class="form-control" name="priority" value="@Priority" />
        </label>
        <label class="d-flex flex-column">
            <span class="text-small color-fg-muted">Done</span>
            <select class="form-select" name="done">
                <option value="">All</option>
                <option value="true" selected="@(Done == true)">Done</option>
                <option value="false" selected="@(Done != true)">Open</option>
            </select>
        </label>
        <div class="d-flex flex-items-end">
            <button class="btn btn-primary" type="submit">Apply</button>
        </div>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
{
    <PrimerFlash Variant="danger" Title="Failed to load todos">@ViewModel.ErrorMessage</PrimerFlash>
}
else if (ViewModel.IsLoading)
{
    <p class="color-fg-muted">Loading todos...</p>
}
else if (ViewModel.Items.Count == 0)
{
    <PrimerBlankslate Heading="No todo items found" Description="Try changing the filters or create new TODO items." />
}
else
{
    @foreach (var group in GroupByPriority(ViewModel.Items))
    {
        <div class="mb-4">
            <h3 class="h4 mb-2">
                <PrimerLabel Scheme="@GetPriorityScheme(group.Key)" Text="@group.Key" />
                <span class="color-fg-muted f5 ml-2">(@group.Count())</span>
            </h3>
            <PrimerDataTable TItem="TodoListItem" Items="@(new System.Collections.ObjectModel.ObservableCollection<TodoListItem>(group))" ColumnCount="5" Class="Table--full-width" style="width:100%; table-layout:fixed;">
                <HeaderTemplate>
                    <tr>
                        <th style="width:15%">ID</th>
                        <th style="width:45%">Title</th>
                        <th style="width:15%">Section</th>
                        <th style="width:10%">Status</th>
                        <th style="width:15%"></th>
                    </tr>
                </HeaderTemplate>
                <RowTemplate Context="item">
                    <td><code>@item.Id</code></td>
                    <td>@item.Title</td>
                    <td>@item.Section</td>
                    <td>
                        <PrimerLabel Scheme="@(item.Done ? "success" : "attention")" Text="@(item.Done ? "Done" : "Open")" />
                    </td>
                    <td><a class="btn btn-sm" href="@GetTodoDetailHref(item.Id)">Details</a></td>
                </RowTemplate>
            </PrimerDataTable>
        </div>
    }
}

@code {
    [SupplyParameterFromQuery]
    public string? Section { get; set; }

    [SupplyParameterFromQuery]
    public string? Priority { get; set; }

    [SupplyParameterFromQuery]
    public bool? Done { get; set; }

    private string? _lastQueryKey;

    protected override async Task OnParametersSetAsync()
    {
        var queryKey = $"{Section}|{Priority}|{Done}";
        if (string.Equals(queryKey, _lastQueryKey, StringComparison.Ordinal))
            return;

        _lastQueryKey = queryKey;
        var loadTask = CommandTarget.RunAsync(async () =>
        {
            ViewModel.Section = Section;
            ViewModel.Priority = Priority;
            ViewModel.Done = Done ?? false;
            await ViewModel.LoadAsync().ConfigureAwait(true);
        });

        while (!ViewModel.IsLoading && !loadTask.IsCompleted)
            await Task.Yield();

        if (ViewModel.IsLoading)
            await RefreshUiAsync();

        await loadTask.ConfigureAwait(true);
    }

    private string GetTodoDetailHref(string id)
    {
        var qs = BuildFilterQueryString();
        return string.IsNullOrEmpty(qs)
            ? $"/todos/{Uri.EscapeDataString(id)}"
            : $"/todos/{Uri.EscapeDataString(id)}?{qs}";
    }

    private string BuildFilterQueryString()
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(Section)) parts.Add($"section={Uri.EscapeDataString(Section)}");
        if (!string.IsNullOrWhiteSpace(Priority)) parts.Add($"priority={Uri.EscapeDataString(Priority)}");
        if (Done.HasValue) parts.Add($"done={Done.Value.ToString().ToLowerInvariant()}");
        return string.Join("&", parts);
    }

    private static readonly string[] PriorityOrder = ["critical", "high", "medium", "low"];

    private static IEnumerable<IGrouping<string, TodoListItem>> GroupByPriority(
        IEnumerable<TodoListItem> items)
        => items
            .OrderBy(i => i.Id, StringComparer.OrdinalIgnoreCase)
            .GroupBy(i => i.Priority ?? "low")
            .OrderBy(g => Array.IndexOf(PriorityOrder, g.Key.ToLowerInvariant()) is var idx && idx < 0 ? int.MaxValue : idx);

    private static string GetPriorityScheme(string priority)
        => priority.ToLowerInvariant() switch
        {
            "critical" => "danger",
            "high" => "attention",
            "medium" => "done",
            "low" => "default",
            _ => "default",
        };
}

