@page "/todos/{TodoId}"

@inject TodoDetailViewModel ViewModel
@inject TodoListViewModel ListViewModel
@inject IAuthorizationPolicyService AuthPolicy
@inject WebCommandTarget CommandTarget

<PageTitle>Todo Detail</PageTitle>

<div class="detail-layout">
    <aside class="detail-sidebar">
        <div class="sidebar-header">Todos</div>
        @foreach (var group in GroupByPriority(ListViewModel.Items))
        {
            <div class="sidebar-group-header color-fg-muted f6 text-uppercase px-3 pt-2 pb-1">@group.Key</div>
            @foreach (var item in group)
            {
                <a class="sidebar-item @(string.Equals(item.Id, TodoId, StringComparison.Ordinal) ? "active" : "")"
                   href="/todos/@Uri.EscapeDataString(item.Id)">
                    <span class="text-bold">@item.Id</span>
                    <br /><span class="color-fg-muted f6">@item.Title</span>
                </a>
            }
        }
    </aside>

    <div class="detail-main">
        <DetailItemToolbar Items="GetNavigationItems()"
                           CurrentKey="@TodoId"
                           ItemTypeLabel="Todo"
                           AriaLabel="Todo item navigation" />

        @if (string.IsNullOrWhiteSpace(TodoId))
        {
            <PrimerBlankslate Heading="No todo selected" Description="Choose a TODO from the sidebar." />
        }
        else if (!string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
        {
            <PrimerFlash Variant="danger" Title="Failed to load todo">@ViewModel.ErrorMessage</PrimerFlash>
        }
        else if (ViewModel.IsBusy && ViewModel.Detail is null)
        {
            <p class="color-fg-muted">Loading todo details...</p>
        }
        else if (ViewModel.Detail is null)
        {
            <PrimerBlankslate Heading="Todo not found" Description="The requested TODO item could not be found." />
        }
        else
        {
            @if (!string.IsNullOrWhiteSpace(ViewModel.MutationMessage))
            {
                <PrimerFlash Variant="success" Title="Success">@ViewModel.MutationMessage</PrimerFlash>
            }

            @if (!string.IsNullOrWhiteSpace(ViewModel.PromptErrorMessage))
            {
                <PrimerFlash Variant="danger" Title="Prompt generation failed">@ViewModel.PromptErrorMessage</PrimerFlash>
            }

            <div class="Box detail-card-section">
                <div class="Box-header detail-card-section__header">
                    <button type="button"
                            class="detail-card-expander"
                            aria-expanded="@IsSectionExpanded(EditorSectionKey).ToString().ToLowerInvariant()"
                            @onclick='() => ToggleSection(EditorSectionKey)'>
                        <span class="h3 mb-0">@ViewModel.Detail.Id — @ViewModel.Detail.Title</span>
                        <span class="detail-card-expander__icon" aria-hidden="true">@GetSectionIcon(EditorSectionKey)</span>
                    </button>
                    <div class="detail-card-expander__actions">
                        @if (CanEdit)
                        {
                            <button class="btn btn-primary btn-sm" @onclick="SaveAsync" disabled="@ViewModel.IsBusy">
                                <OcticonIcon Name="check-circle" Size="16" /> Save
                            </button>
                            @if (!ViewModel.EditorDone)
                            {
                                <button class="btn btn-sm" @onclick="MarkDoneAsync" disabled="@ViewModel.IsBusy">
                                    <OcticonIcon Name="check" Size="16" /> Done
                                </button>
                            }
                            <button class="btn btn-danger btn-sm" @onclick="DeleteAsync" disabled="@ViewModel.IsBusy">
                                <OcticonIcon Name="trash" Size="16" /> Delete
                            </button>
                        }
                        <button class="btn btn-sm" @onclick="GenerateStatusPromptAsync" disabled="@ViewModel.IsBusy"
                                aria-label="Generate Copilot Status prompt">
                            <OcticonIcon Name="pulse" Size="16" /> Copilot Status
                        </button>
                        <button class="btn btn-sm" @onclick="GeneratePlanPromptAsync" disabled="@ViewModel.IsBusy"
                                aria-label="Generate Copilot Plan prompt">
                            <OcticonIcon Name="checklist" Size="16" /> Copilot Plan
                        </button>
                        <button class="btn btn-sm" @onclick="GenerateImplementAsync" disabled="@ViewModel.IsBusy"
                                aria-label="Generate Copilot Implementation prompt">
                            <OcticonIcon Name="code" Size="16" /> Copilot Implementation
                        </button>
                    </div>
                </div>
                @if (IsSectionExpanded(EditorSectionKey))
                {
                    <div class="Box-body p-0">
                        <MonacoEditor @bind-Value="ViewModel.EditorMarkdownText"
                                      Language="markdown"
                                      ReadOnly="@(!CanEdit)"
                                      Height="600" />
                    </div>
                }
            </div>

            @if (ViewModel.PromptOutput is { } output)
            {
                <div class="Box detail-card-section" id="prompt-output-panel">
                    <div class="Box-header detail-card-section__header">
                        <button type="button"
                                class="detail-card-expander"
                                aria-expanded="@IsSectionExpanded(PromptSectionKey).ToString().ToLowerInvariant()"
                                @onclick='() => ToggleSection(PromptSectionKey)'>
                            <span class="h4 mb-0">
                                Copilot Prompt — @output.PromptType
                                <span class="color-fg-muted f6 ml-2">(@output.TodoId)</span>
                            </span>
                            <span class="detail-card-expander__icon" aria-hidden="true">@GetSectionIcon(PromptSectionKey)</span>
                        </button>
                        <div class="detail-card-expander__actions">
                            <button class="btn btn-sm" @onclick="ClearPromptOutput" aria-label="Clear prompt output">
                                <OcticonIcon Name="x" Size="16" /> Clear
                            </button>
                        </div>
                    </div>
                    @if (IsSectionExpanded(PromptSectionKey))
                    {
                        <div class="Box-body">
                            <pre class="f6 overflow-auto" style="white-space: pre-wrap; max-height: 400px;"
                                 id="prompt-output-text">@output.Text</pre>
                        </div>
                    }
                </div>
            }

            @if (ViewModel.IsPromptBusy)
            {
                <p class="color-fg-muted" id="prompt-generating-indicator">Generating prompt...</p>
            }
        }
    </div>
</div>

@code {
    [Parameter]
    public string TodoId { get; set; } = string.Empty;

    private string? _loadedId;
    private HashSet<string> _expandedSections = CreateDefaultExpandedSections();

    private const string EditorSectionKey = "editor";
    private const string PromptSectionKey = "prompt";

    private bool CanEdit => AuthPolicy.CanExecuteAction(McpServerManager.UI.Core.Authorization.McpActionKeys.TodoUpdate);

    private static readonly string[] PriorityOrder = ["critical", "high", "medium", "low"];

    private static IEnumerable<IGrouping<string, TodoListItem>> GroupByPriority(
        IEnumerable<TodoListItem> items)
        => items
            .OrderBy(i => i.Id, StringComparer.OrdinalIgnoreCase)
            .GroupBy(i => i.Priority ?? "low")
            .OrderBy(g => Array.IndexOf(PriorityOrder, g.Key.ToLowerInvariant()) is var idx && idx < 0 ? int.MaxValue : idx);

    private IReadOnlyList<DetailNavigationItem> GetNavigationItems()
        => GroupByPriority(ListViewModel.Items)
            .SelectMany(static group => group)
            .Select(item => new DetailNavigationItem(
                item.Id,
                $"/todos/{Uri.EscapeDataString(item.Id)}",
                item.Id,
                item.Title))
            .ToArray();

    protected override async Task OnParametersSetAsync()
    {
        if (ListViewModel.Items.Count == 0)
        {
            await CommandTarget.RunAsync(async () =>
            {
                ListViewModel.Done = false;
                await ListViewModel.LoadAsync().ConfigureAwait(true);
            }).ConfigureAwait(true);
        }

        if (string.Equals(_loadedId, TodoId, StringComparison.Ordinal))
            return;

        _loadedId = TodoId;
        await CommandTarget.RunAsync(async () =>
        {
            ViewModel.TodoId = TodoId;
            await ViewModel.LoadAsync().ConfigureAwait(true);
        }).ConfigureAwait(true);
        ResetExpandedSections();
    }

    private async Task SaveAsync()
    {
        await CommandTarget.RunAsync(async () =>
        {
            ViewModel.ApplyMarkdownToEditor();
            await ViewModel.SaveAsync().ConfigureAwait(true);
            await ListViewModel.LoadAsync().ConfigureAwait(true);
        }).ConfigureAwait(true);
    }

    private async Task DeleteAsync()
    {
        await CommandTarget.RunAsync(async () =>
        {
            await ViewModel.DeleteAsync().ConfigureAwait(true);
            await ListViewModel.LoadAsync().ConfigureAwait(true);
        }).ConfigureAwait(true);
    }

    private async Task MarkDoneAsync()
    {
        await CommandTarget.RunAsync(async () =>
        {
            await ViewModel.MarkDoneAsync().ConfigureAwait(true);
            await ListViewModel.LoadAsync().ConfigureAwait(true);
        }).ConfigureAwait(true);
    }

    private Task GenerateStatusPromptAsync()
        => RunPromptGenerationAsync(() => ViewModel.GenerateStatusPromptAsync());

    private Task GeneratePlanPromptAsync()
        => RunPromptGenerationAsync(() => ViewModel.GeneratePlanPromptAsync());

    private Task GenerateImplementAsync()
        => RunPromptGenerationAsync(() => ViewModel.GenerateImplementPromptAsync());

    private void ClearPromptOutput()
    {
        ViewModel.PromptOutput = null;
        ViewModel.PromptErrorMessage = null;
        _expandedSections.Remove(PromptSectionKey);
    }

    private async Task RunPromptGenerationAsync(Func<Task> generator)
    {
        await CommandTarget.RunAsync(generator).ConfigureAwait(true);
        if (ViewModel.PromptOutput is not null)
        {
            _expandedSections.Add(PromptSectionKey);
        }
    }

    private bool IsSectionExpanded(string section)
        => _expandedSections.Contains(section);

    private void ToggleSection(string section)
    {
        if (!_expandedSections.Add(section))
        {
            _expandedSections.Remove(section);
        }
    }

    private void ResetExpandedSections()
        => _expandedSections = CreateDefaultExpandedSections();

    private static HashSet<string> CreateDefaultExpandedSections()
        => new(StringComparer.Ordinal)
        {
            EditorSectionKey
        };

    private string GetSectionIcon(string section)
        => IsSectionExpanded(section) ? "▾" : "▸";
}
