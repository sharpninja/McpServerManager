@page "/templates"

@inject TemplateListViewModel ViewModel

<PageTitle>Template List</PageTitle>

<h1 class="h2 mb-3">Template List</h1>

<form method="get" class="Box p-3 mb-3">
    <div class="d-flex flex-wrap gap-3">
        <label class="d-flex flex-column">
            <span class="text-small color-fg-muted">Category</span>
            <input class="form-control" name="category" value="@Category" />
        </label>
        <label class="d-flex flex-column">
            <span class="text-small color-fg-muted">Tag</span>
            <input class="form-control" name="tag" value="@Tag" />
        </label>
        <label class="d-flex flex-column flex-1">
            <span class="text-small color-fg-muted">Keyword</span>
            <input class="form-control" name="keyword" value="@Keyword" />
        </label>
        <div class="d-flex flex-items-end">
            <button class="btn btn-primary" type="submit">Apply</button>
        </div>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
{
    <PrimerFlash Variant="danger" Title="Failed to load templates">@ViewModel.ErrorMessage</PrimerFlash>
}
else if (ViewModel.IsLoading)
{
    <p class="color-fg-muted">Loading templates...</p>
}
else if (ViewModel.Items.Count == 0)
{
    <PrimerBlankslate Heading="No templates found" Description="No templates matched the current filter." />
}
else
{
    <PrimerDataTable TItem="TemplateListItem" Items="ViewModel.Items" ColumnCount="6" Class="Table--full-width">
        <HeaderTemplate>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Category</th>
                <th>Tags</th>
                <th>Description</th>
                <th></th>
            </tr>
        </HeaderTemplate>
        <RowTemplate Context="item">
            <td><code>@item.Id</code></td>
            <td>@item.Title</td>
            <td>@item.Category</td>
            <td>@string.Join(", ", item.Tags)</td>
            <td>@(item.Description ?? string.Empty)</td>
            <td>
                <div class="d-flex gap-1">
                    <a class="btn btn-sm" href="@GetDetailHref(item.Id)">Details</a>
                    <a class="btn btn-sm" href="@GetTestHref(item.Id)">Test</a>
                </div>
            </td>
        </RowTemplate>
    </PrimerDataTable>
}

@code {
    [SupplyParameterFromQuery]
    public string? Category { get; set; }

    [SupplyParameterFromQuery]
    public string? Tag { get; set; }

    [SupplyParameterFromQuery]
    public string? Keyword { get; set; }

    private string? _lastQueryKey;

    protected override async Task OnParametersSetAsync()
    {
        var queryKey = $"{Category}|{Tag}|{Keyword}";
        if (string.Equals(queryKey, _lastQueryKey, StringComparison.Ordinal))
            return;

        _lastQueryKey = queryKey;
        ViewModel.Category = Category;
        ViewModel.Tag = Tag;
        ViewModel.Keyword = Keyword;
        await ViewModel.LoadAsync().ConfigureAwait(true);
    }

    private static string GetDetailHref(string templateId)
        => $"/templates/{Uri.EscapeDataString(templateId)}";

    private static string GetTestHref(string templateId)
        => $"/templates/test?templateId={Uri.EscapeDataString(templateId)}";
}

