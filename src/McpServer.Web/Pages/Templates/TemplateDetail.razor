@page "/templates/{TemplateId}"

@inject TemplateDetailViewModel ViewModel
@inject TemplateListViewModel ListViewModel
@inject IAuthorizationPolicyService AuthPolicy
@inject WebCommandTarget CommandTarget

<PageTitle>Template Detail</PageTitle>

<div class="detail-layout">
    <aside class="detail-sidebar">
        <div class="sidebar-header">Templates</div>
        @foreach (var item in ListViewModel?.Items ?? [])
        {
            <a class="sidebar-item @(string.Equals(item.Id, TemplateId, StringComparison.Ordinal) ? "active" : "")"
               href="@GetDetailHref(item.Id)">
                <span class="color-fg-muted f6">@item.Category</span>
                <br />@item.Title
            </a>
        }
    </aside>

    <div class="detail-main">
        @if (string.IsNullOrWhiteSpace(TemplateId))
        {
            <PrimerBlankslate Heading="No template selected" Description="Choose a template from the sidebar." />
        }
        else if (!string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
        {
            <PrimerFlash Variant="danger" Title="Failed to load template">@ViewModel.ErrorMessage</PrimerFlash>
        }
        else if (ViewModel.IsBusy)
        {
            <p class="color-fg-muted">Loading template details...</p>
        }
        else if (ViewModel.Detail is null)
        {
            <PrimerBlankslate Heading="Template not found" Description="The requested template could not be loaded." />
        }
        else
        {
            @if (!string.IsNullOrWhiteSpace(ViewModel.StatusMessage) && ViewModel.StatusMessage.Contains("Saved", StringComparison.OrdinalIgnoreCase))
            {
                <PrimerFlash Variant="success" Title="Success">@ViewModel.StatusMessage</PrimerFlash>
            }

            <div class="Box mb-3">
                <div class="Box-header d-flex flex-justify-between flex-items-center">
                    <h2 class="h3 mb-0">@ViewModel.Detail.Title</h2>
                    @if (CanEdit)
                    {
                        <div class="d-flex gap-2">
                            <button class="btn btn-primary btn-sm" @onclick="SaveAsync" disabled="@ViewModel.IsBusy">Save</button>
                            <button class="btn btn-danger btn-sm" @onclick="DeleteAsync" disabled="@ViewModel.IsBusy">Delete</button>
                        </div>
                    }
                </div>
                <div class="Box-body">
                    <div class="d-flex flex-wrap gap-3" style="display: grid !important; grid-template-columns: 1fr 1fr; gap: 16px;">
                        <div>
                            <label class="text-small text-bold d-block">ID</label>
                            <code>@ViewModel.Detail.Id</code>
                        </div>
                        <div>
                            <label class="text-small text-bold d-block">Title</label>
                            @if (CanEdit)
                            {
                                <input class="form-control width-full" @bind="ViewModel.EditorTitle" />
                            }
                            else
                            {
                                <span>@ViewModel.Detail.Title</span>
                            }
                        </div>
                        <div>
                            <label class="text-small text-bold d-block">Category</label>
                            @if (CanEdit)
                            {
                                <input class="form-control width-full" @bind="ViewModel.EditorCategory" />
                            }
                            else
                            {
                                <span>@ViewModel.Detail.Category</span>
                            }
                        </div>
                        <div>
                            <label class="text-small text-bold d-block">Engine</label>
                            @if (CanEdit)
                            {
                                <input class="form-control width-full" @bind="ViewModel.EditorEngine" />
                            }
                            else
                            {
                                <span>@ViewModel.Detail.Engine</span>
                            }
                        </div>
                        <div>
                            <label class="text-small text-bold d-block">Tags</label>
                            @if (CanEdit)
                            {
                                <input class="form-control width-full" placeholder="tag1, tag2, tag3" @bind="ViewModel.EditorTags" />
                            }
                            else
                            {
                                <span>@string.Join(", ", ViewModel.Detail.Tags)</span>
                            }
                        </div>
                        <div>
                            <label class="text-small text-bold d-block">Description</label>
                            @if (CanEdit)
                            {
                                <textarea class="form-control width-full" rows="3" @bind="ViewModel.EditorDescription"></textarea>
                            }
                            else
                            {
                                <span>@(ViewModel.Detail.Description ?? "(none)")</span>
                            }
                        </div>
                    </div>
                    <div class="mt-3">
                        <a class="btn btn-sm" href="@GetTestHref(ViewModel.Detail.Id)">Test this template</a>
                    </div>
                </div>
            </div>

            <div class="Box mb-3">
                <div class="Box-header">
                    <h3 class="h4 mb-0">Variables</h3>
                </div>
                <div class="Box-body">
                    @if (ViewModel.Detail.Variables.Count == 0)
                    {
                        <p class="color-fg-muted mb-0">No variables declared.</p>
                    }
                    else
                    {
                        <PrimerDataTable TItem="TemplateVariableDetail" Items="ViewModel.Detail.Variables" ColumnCount="5" Class="Table--full-width">
                            <HeaderTemplate>
                                <tr>
                                    <th>Name</th>
                                    <th>Required</th>
                                    <th>Description</th>
                                    <th>Example</th>
                                    <th>Default</th>
                                </tr>
                            </HeaderTemplate>
                            <RowTemplate Context="variable">
                                <td><code>@variable.Name</code></td>
                                <td>@(variable.Required ? "Yes" : "No")</td>
                                <td>@(variable.Description ?? string.Empty)</td>
                                <td><code>@(variable.Example ?? string.Empty)</code></td>
                                <td><code>@(variable.DefaultValue ?? string.Empty)</code></td>
                            </RowTemplate>
                        </PrimerDataTable>
                    }
                </div>
            </div>

            <div class="Box mb-3">
                <div class="Box-header">
                    <h3 class="h4 mb-0">Template Content</h3>
                </div>
                <div class="Box-body p-0">
                    <MonacoEditor @bind-Value="ViewModel.EditorContent"
                                  Language="handlebars"
                                  ReadOnly="@(!CanEdit)"
                                  Height="500" />
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public string TemplateId { get; set; } = string.Empty;

    [SupplyParameterFromQuery]
    public string? Category { get; set; }

    [SupplyParameterFromQuery]
    public string? Tag { get; set; }

    [SupplyParameterFromQuery]
    public string? Keyword { get; set; }

    private string? _loadedTemplateId;
    private string? _lastFilterKey;
    private bool CanEdit => AuthPolicy.CanExecuteAction(McpServer.UI.Core.Authorization.McpActionKeys.TemplateUpdate);

    protected override async Task OnParametersSetAsync()
    {
        var filterKey = $"{Category}|{Tag}|{Keyword}";
        if (!string.Equals(filterKey, _lastFilterKey, StringComparison.Ordinal))
        {
            _lastFilterKey = filterKey;
            await CommandTarget.RunAsync(async () =>
            {
                ListViewModel.Category = Category;
                ListViewModel.Tag = Tag;
                ListViewModel.Keyword = Keyword;
                await ListViewModel.LoadAsync().ConfigureAwait(true);
            }).ConfigureAwait(true);
        }

        if (string.Equals(_loadedTemplateId, TemplateId, StringComparison.Ordinal))
            return;

        _loadedTemplateId = TemplateId;
        await CommandTarget.RunAsync(async () =>
        {
            await ViewModel.LoadAsync(TemplateId).ConfigureAwait(true);
            ViewModel.PopulateEditorFromDetail();
        }).ConfigureAwait(true);
    }

    private async Task SaveAsync() => await CommandTarget.RunAsync(() => ViewModel.SaveAsync()).ConfigureAwait(true);

    private async Task DeleteAsync() => await CommandTarget.RunAsync(() => ViewModel.DeleteAsync()).ConfigureAwait(true);

    private string GetDetailHref(string templateId)
    {
        var qs = BuildFilterQueryString();
        return string.IsNullOrEmpty(qs)
            ? $"/templates/{Uri.EscapeDataString(templateId)}"
            : $"/templates/{Uri.EscapeDataString(templateId)}?{qs}";
    }

    private static string GetTestHref(string templateId)
        => $"/templates/test?templateId={Uri.EscapeDataString(templateId)}";

    private string BuildFilterQueryString()
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(Category)) parts.Add($"category={Uri.EscapeDataString(Category)}");
        if (!string.IsNullOrWhiteSpace(Tag)) parts.Add($"tag={Uri.EscapeDataString(Tag)}");
        if (!string.IsNullOrWhiteSpace(Keyword)) parts.Add($"keyword={Uri.EscapeDataString(Keyword)}");
        return string.Join("&", parts);
    }
}

