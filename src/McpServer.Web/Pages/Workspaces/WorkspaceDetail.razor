@page "/workspaces/detail"

@inject WorkspaceDetailViewModel ViewModel
@inject WorkspaceListViewModel ListViewModel
@inject IAuthorizationPolicyService AuthPolicy
@inject WebCommandTarget CommandTarget

<PageTitle>Workspace Detail</PageTitle>

<div class="detail-layout">
    <aside class="detail-sidebar">
        <div class="sidebar-header">Workspaces</div>
        @foreach (var ws in ListViewModel.Workspaces)
        {
            <a class="sidebar-item @(string.Equals(ws.WorkspacePath, WorkspacePath, StringComparison.OrdinalIgnoreCase) ? "active" : "")"
               href="/workspaces/detail?path=@Uri.EscapeDataString(ws.WorkspacePath)">
                <span class="color-fg-muted f6">@(ws.IsPrimary ? "Primary" : ws.IsEnabled ? "Enabled" : "Disabled")</span>
                <br />@ws.Name
            </a>
        }
    </aside>

    <div class="detail-main">

@if (string.IsNullOrWhiteSpace(WorkspacePath))
{
    <PrimerBlankslate Heading="No workspace selected" Description="Choose a workspace from the workspace list to view details." />
}
else if (!string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
{
    <PrimerFlash Variant="danger" Title="Failed to load workspace">@ViewModel.ErrorMessage</PrimerFlash>
}
else if (ViewModel.IsBusy)
{
    <p class="color-fg-muted">Loading workspace details...</p>
}
else if (ViewModel.Detail is null)
{
    <PrimerBlankslate Heading="Workspace not found" Description="The requested workspace could not be loaded." />
}
else
{
    @if (!string.IsNullOrWhiteSpace(ViewModel.MutationMessage))
    {
        <PrimerFlash Variant="@(ViewModel.MutationMessage.Contains("failed", StringComparison.OrdinalIgnoreCase) ? "danger" : "success")" Title="Result">@ViewModel.MutationMessage</PrimerFlash>
    }

    <div class="Box mb-3">
        <div class="Box-header d-flex flex-justify-between flex-items-center">
            <h2 class="h3 mb-0">@ViewModel.Detail.Name</h2>
            @if (CanEdit)
            {
                <div class="d-flex gap-2">
                    <button class="btn btn-primary btn-sm" @onclick="SaveAsync" disabled="@ViewModel.IsBusy">Save</button>
                    <button class="btn btn-danger btn-sm" @onclick="DeleteAsync" disabled="@ViewModel.IsBusy">Delete</button>
                </div>
            }
        </div>
        <div class="Box-body">
            <div class="d-flex flex-column gap-3">
                <div>
                    <label class="text-small text-bold d-block">Path</label>
                    <code>@ViewModel.Detail.WorkspacePath</code>
                </div>
                <div>
                    <label class="text-small text-bold d-block">Name</label>
                    @if (CanEdit)
                    {
                        <input class="form-control" @bind="ViewModel.EditorName" />
                    }
                    else
                    {
                        <span>@ViewModel.Detail.Name</span>
                    }
                </div>
                <div>
                    <label class="text-small text-bold d-block">Todo Path</label>
                    @if (CanEdit)
                    {
                        <input class="form-control" @bind="ViewModel.EditorTodoPath" />
                    }
                    else
                    {
                        <code>@ViewModel.Detail.TodoPath</code>
                    }
                </div>
                <div>
                    <label class="text-small text-bold d-block">Data Directory</label>
                    @if (CanEdit)
                    {
                        <input class="form-control" @bind="ViewModel.EditorDataDirectory" />
                    }
                    else
                    {
                        <span>@(ViewModel.Detail.DataDirectory ?? "(not set)")</span>
                    }
                </div>
                <div>
                    <label class="text-small text-bold d-block">Tunnel Provider</label>
                    @if (CanEdit)
                    {
                        <input class="form-control" @bind="ViewModel.EditorTunnelProvider" />
                    }
                    else
                    {
                        <span>@(ViewModel.Detail.TunnelProvider ?? "(not set)")</span>
                    }
                </div>
                <div>
                    <label class="text-small text-bold d-block">Run As</label>
                    @if (CanEdit)
                    {
                        <input class="form-control" @bind="ViewModel.EditorRunAs" />
                    }
                    else
                    {
                        <span>@(ViewModel.Detail.RunAs ?? "(not set)")</span>
                    }
                </div>
                <div class="d-flex gap-4">
                    <div>
                        <label class="text-small text-bold d-block">Enabled</label>
                        @if (CanEdit)
                        {
                            <label class="d-flex flex-items-center gap-2">
                                <input type="checkbox" @bind="ViewModel.EditorIsEnabled" /> Enabled
                            </label>
                        }
                        else
                        {
                            <span>@(ViewModel.Detail.IsEnabled ? "Yes" : "No")</span>
                        }
                    </div>
                    <div>
                        <label class="text-small text-bold d-block">Primary</label>
                        @if (CanEdit)
                        {
                            <label class="d-flex flex-items-center gap-2">
                                <input type="checkbox" @bind="ViewModel.EditorIsPrimary" /> Primary
                            </label>
                        }
                        else
                        {
                            <span>@(ViewModel.Detail.IsPrimary ? "Yes" : "No")</span>
                        }
                    </div>
                </div>
                <div>
                    <label class="text-small text-bold d-block">Created</label>
                    <span>@ViewModel.Detail.DateTimeCreated.ToLocalTime().ToString("g")</span>
                </div>
                <div>
                    <label class="text-small text-bold d-block">Modified</label>
                    <span>@ViewModel.Detail.DateTimeModified.ToLocalTime().ToString("g")</span>
                </div>
            </div>
        </div>
    </div>

    <div class="Box mb-3">
        <div class="Box-header"><h3 class="h4 mb-0">Policy</h3></div>
        <div class="Box-body">
            <div class="d-flex flex-column gap-2">
                <div>
                    <strong>Banned Licenses</strong>
                    @RenderStringList(ViewModel.Detail.BannedLicenses)
                </div>
                <div>
                    <strong>Banned Countries</strong>
                    @RenderStringList(ViewModel.Detail.BannedCountriesOfOrigin)
                </div>
                <div>
                    <strong>Banned Organizations</strong>
                    @RenderStringList(ViewModel.Detail.BannedOrganizations)
                </div>
                <div>
                    <strong>Banned Individuals</strong>
                    @RenderStringList(ViewModel.Detail.BannedIndividuals)
                </div>
            </div>
        </div>
    </div>

    @if (CanEdit)
    {
        <div class="d-flex gap-2 mb-3">
            <button class="btn btn-primary" @onclick="SaveAsync" disabled="@ViewModel.IsBusy">Save</button>
            <button class="btn btn-danger" @onclick="DeleteAsync" disabled="@ViewModel.IsBusy">Delete</button>
        </div>
    }
}
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "path")]
    public string? WorkspacePath { get; set; }

    private string? _loadedPath;
    private bool CanEdit => AuthPolicy.CanExecuteAction(McpServer.UI.Core.Authorization.McpActionKeys.WorkspaceUpdate);

    protected override async Task OnInitializedAsync()
    {
        if (ListViewModel.Workspaces.Count == 0)
        {
            await CommandTarget.RunAsync(() => ListViewModel.LoadAsync()).ConfigureAwait(true);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (string.Equals(_loadedPath, WorkspacePath, StringComparison.Ordinal))
            return;

        _loadedPath = WorkspacePath;
        if (string.IsNullOrWhiteSpace(WorkspacePath))
            return;

        await CommandTarget.RunAsync(async () =>
        {
            ViewModel.WorkspacePath = WorkspacePath;
            await ViewModel.LoadAsync().ConfigureAwait(true);
        }).ConfigureAwait(true);
    }

    private async Task SaveAsync() => await CommandTarget.RunAsync(() => ViewModel.SaveAsync()).ConfigureAwait(true);

    private async Task DeleteAsync() => await CommandTarget.RunAsync(() => ViewModel.DeleteAsync()).ConfigureAwait(true);

    private static RenderFragment RenderStringList(IReadOnlyList<string> values) => builder =>
    {
        if (values.Count == 0)
        {
            builder.OpenElement(0, "p");
            builder.AddAttribute(1, "class", "color-fg-muted mb-0");
            builder.AddContent(2, "None");
            builder.CloseElement();
            return;
        }

        builder.OpenElement(3, "ul");
        builder.AddAttribute(4, "class", "mb-0");
        for (var i = 0; i < values.Count; i++)
        {
            builder.OpenElement(10 + i, "li");
            builder.AddContent(20 + i, values[i]);
            builder.CloseElement();
        }

        builder.CloseElement();
    };
}

