@page "/workspaces"

@inject WorkspaceListViewModel ViewModel
@inject WorkspaceContextViewModel WorkspaceContext

<PageTitle>Workspace List</PageTitle>

<div class="d-flex flex-items-center flex-justify-between mb-3">
    <h1 class="h2">Workspace List</h1>
    @if (!string.IsNullOrWhiteSpace(WorkspaceContext.ActiveWorkspacePath))
    {
        <span class="text-small color-fg-muted d-flex flex-items-center">
            <OcticonIcon Name="check-circle" Size="16" Class="color-fg-success mr-1" />
            Active: <strong class="ml-1">@ActiveWorkspaceName</strong>
        </span>
    }
</div>

@if (!string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
{
    <PrimerFlash Variant="danger" Title="Failed to load workspaces">@ViewModel.ErrorMessage</PrimerFlash>
}
else if (ViewModel.IsLoading)
{
    <p class="color-fg-muted">Loading workspaces...</p>
}
else if (ViewModel.Workspaces.Count == 0)
{
    <PrimerBlankslate Heading="No workspaces found" Description="No workspace records were returned by the server." />
}
else
{
    <PrimerDataTable TItem="WorkspaceSummary"
                     Items="ViewModel.Workspaces"
                     ColumnCount="6"
                     Class="Table--full-width"
                     RowClass="GetRowClass">
        <HeaderTemplate>
            <tr>
                <th></th>
                <th>Name</th>
                <th>Path</th>
                <th>Enabled</th>
                <th>Primary</th>
                <th></th>
            </tr>
        </HeaderTemplate>
        <RowTemplate Context="item">
            <td style="width:32px">
                @if (IsActive(item.WorkspacePath))
                {
                    <OcticonIcon Name="check-circle" Size="16" Class="color-fg-success" AriaLabel="Active workspace" />
                }
            </td>
            <td>@item.Name</td>
            <td><code>@item.WorkspacePath</code></td>
            <td>
                <PrimerLabel Scheme="@(item.IsEnabled ? "success" : "attention")" Text="@(item.IsEnabled ? "Yes" : "No")" />
            </td>
            <td>
                <PrimerLabel Scheme="@(item.IsPrimary ? "done" : "default")" Text="@(item.IsPrimary ? "Primary" : "Secondary")" />
            </td>
            <td class="text-right">
                @if (IsActive(item.WorkspacePath))
                {
                    <span class="btn btn-sm btn-primary disabled" aria-disabled="true">Selected</span>
                }
                else
                {
                    <button class="btn btn-sm" @onclick="() => SelectWorkspace(item.WorkspacePath)">Select</button>
                }
                <a class="btn btn-sm ml-1" href="@GetWorkspaceDetailHref(item.WorkspacePath)">Details</a>
            </td>
        </RowTemplate>
    </PrimerDataTable>
}

@code {
    protected override async Task OnInitializedAsync()
    {
        await ViewModel.LoadAsync().ConfigureAwait(true);
    }

    private bool IsActive(string workspacePath)
        => string.Equals(WorkspaceContext.ActiveWorkspacePath, workspacePath, StringComparison.OrdinalIgnoreCase);

    private string? GetRowClass(WorkspaceSummary item)
        => IsActive(item.WorkspacePath) ? "active-workspace-row" : null;

    private string? ActiveWorkspaceName =>
        ViewModel.Workspaces
            .FirstOrDefault(w => IsActive(w.WorkspacePath))
            ?.Name ?? WorkspaceContext.ActiveWorkspacePath;

    private void SelectWorkspace(string workspacePath)
    {
        WorkspaceContext.ActiveWorkspacePath = workspacePath;
        StateHasChanged();
    }

    private static string GetWorkspaceDetailHref(string workspacePath)
        => $"/workspaces/detail?path={Uri.EscapeDataString(workspacePath)}";
}
