@page "/sessions"

@inject SessionLogListViewModel ViewModel
@inject WebCommandTarget CommandTarget

<PageTitle>Session Logs</PageTitle>

<h1 class="h2 mb-3">Session Logs</h1>

<form method="get" class="Box p-3 mb-3">
    <div class="d-flex flex-wrap gap-3">
        <label class="d-flex flex-column">
            <span class="text-small color-fg-muted">Agent</span>
            <input class="form-control" name="agent" value="@Agent" />
        </label>
        <label class="d-flex flex-column">
            <span class="text-small color-fg-muted">Model</span>
            <input class="form-control" name="model" value="@Model" />
        </label>
        <label class="d-flex flex-column flex-1">
            <span class="text-small color-fg-muted">Text</span>
            <input class="form-control" name="text" value="@Text" />
        </label>
        <div class="d-flex flex-items-end">
            <button class="btn btn-primary" type="submit">Apply</button>
        </div>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
{
    <PrimerFlash Variant="danger" Title="Failed to load session logs">@ViewModel.ErrorMessage</PrimerFlash>
}
else if (ViewModel.IsLoading)
{
    <p class="color-fg-muted">Loading session logs...</p>
}
else if (ViewModel.Items.Count == 0)
{
    <PrimerBlankslate Heading="No session logs found" Description="No logs matched the current filter." />
}
else
{
    <p class="color-fg-muted">Showing @ViewModel.Items.Count of @ViewModel.TotalCount logs.</p>
    <PrimerDataTable TItem="SessionLogSummary" Items="ViewModel.Items" ColumnCount="6" Class="Table--full-width">
        <HeaderTemplate>
            <tr>
                <th>Session ID</th>
                <th>Title</th>
                <th>Agent</th>
                <th>Status</th>
                <th>Last Updated</th>
                <th></th>
            </tr>
        </HeaderTemplate>
        <RowTemplate Context="item">
            <td><code>@item.SessionId</code></td>
            <td>@item.Title</td>
            <td>@item.SourceType</td>
            <td>
                <PrimerLabel Scheme="@(string.Equals(item.Status, "completed", StringComparison.OrdinalIgnoreCase) ? "success" : "attention")"
                             Text="@item.Status" />
            </td>
            <td>@FormatTimestamp(item.LastUpdated)</td>
            <td><a class="btn btn-sm" href="@GetDetailHref(item.SessionId)">Details</a></td>
        </RowTemplate>
    </PrimerDataTable>
}

@code {
    [SupplyParameterFromQuery]
    public string? Agent { get; set; }

    [SupplyParameterFromQuery]
    public string? Model { get; set; }

    [SupplyParameterFromQuery]
    public string? Text { get; set; }

    private string? _lastQueryKey;

    protected override async Task OnParametersSetAsync()
    {
        var queryKey = $"{Agent}|{Model}|{Text}";
        if (string.Equals(queryKey, _lastQueryKey, StringComparison.Ordinal))
            return;

        _lastQueryKey = queryKey;
        await CommandTarget.RunAsync(async () =>
        {
            ViewModel.Agent = Agent;
            ViewModel.Model = Model;
            ViewModel.Text = Text;
            ViewModel.Limit = 50;
            ViewModel.Offset = 0;
            await ViewModel.LoadAsync().ConfigureAwait(true);
        }).ConfigureAwait(true);
    }

    private string GetDetailHref(string sessionId)
    {
        var qs = BuildFilterQueryString();
        return string.IsNullOrEmpty(qs)
            ? $"/sessions/{Uri.EscapeDataString(sessionId)}"
            : $"/sessions/{Uri.EscapeDataString(sessionId)}?{qs}";
    }

    private string BuildFilterQueryString()
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(Agent)) parts.Add($"agent={Uri.EscapeDataString(Agent)}");
        if (!string.IsNullOrWhiteSpace(Model)) parts.Add($"model={Uri.EscapeDataString(Model)}");
        if (!string.IsNullOrWhiteSpace(Text)) parts.Add($"text={Uri.EscapeDataString(Text)}");
        return string.Join("&", parts);
    }

    private static string FormatTimestamp(string? value)
        => DateTimeOffset.TryParse(value, out var dto) ? dto.ToLocalTime().ToString("g") : value ?? "(unknown)";
}

