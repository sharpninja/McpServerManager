@page "/sessions/{SessionId}"

@inject SessionLogDetailViewModel ViewModel
@inject SessionLogListViewModel ListViewModel

<PageTitle>Session Log Detail</PageTitle>

<div class="detail-layout">
    <aside class="detail-sidebar">
        <div class="sidebar-header">Sessions</div>
        @foreach (var item in ListViewModel?.Items ?? [])
        {
            <a class="sidebar-item @(string.Equals(item.SessionId, SessionId, StringComparison.Ordinal) ? "active" : "")"
               href="@GetDetailHref(item.SessionId)">
                <span class="color-fg-muted f6">@item.SourceType · @item.Status</span>
                <br />@item.Title
            </a>
        }
    </aside>

    <div class="detail-main">
        @if (string.IsNullOrWhiteSpace(SessionId))
        {
            <PrimerBlankslate Heading="No session selected" Description="Open this page from the sidebar." />
        }
        else if (!string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
        {
            <PrimerFlash Variant="danger" Title="Failed to load session">@ViewModel.ErrorMessage</PrimerFlash>
        }
        else if (ViewModel.IsBusy)
        {
            <p class="color-fg-muted">Loading session details...</p>
        }
        else if (ViewModel.Detail is null)
        {
            <PrimerBlankslate Heading="Session not found" Description="The requested session could not be located." />
        }
        else
        {
            <div class="Box mb-3">
                <div class="Box-header">
                    <h2 class="h3 mb-0">@ViewModel.Detail.Title</h2>
                </div>
                <div class="Box-body">
                    <div class="session-entry-meta-grid">
                        <div><span class="color-fg-muted f6">Session ID</span><div><code>@ViewModel.Detail.SessionId</code></div></div>
                        <div><span class="color-fg-muted f6">Source Type</span><div>@ViewModel.Detail.SourceType</div></div>
                        <div><span class="color-fg-muted f6">Status</span><div>@ViewModel.Detail.Status</div></div>
                        <div><span class="color-fg-muted f6">Model</span><div>@(ViewModel.Detail.Model ?? "(not set)")</div></div>
                        <div><span class="color-fg-muted f6">Started</span><div>@FormatTimestamp(ViewModel.Detail.Started)</div></div>
                        <div><span class="color-fg-muted f6">Last Updated</span><div>@FormatTimestamp(ViewModel.Detail.LastUpdated)</div></div>
                        <div><span class="color-fg-muted f6">Entry Count</span><div>@ViewModel.Detail.EntryCount</div></div>
                        <div><span class="color-fg-muted f6">Total Tokens</span><div>@(ViewModel.Detail.TotalTokens?.ToString() ?? "(unknown)")</div></div>
                        <div><span class="color-fg-muted f6">Cursor Session Label</span><div>@(ViewModel.Detail.CursorSessionLabel ?? "(none)")</div></div>
                    </div>
                </div>
            </div>

            @if (ViewModel.Detail.Entries.Count == 0)
            {
                <PrimerBlankslate Heading="No entries" Description="This session does not have request entries." />
            }
            else
            {
                <div class="Box mb-3">
                    <div class="Box-header">
                        <h3 class="h4 mb-0">Entries</h3>
                    </div>
                    <PrimerDataTable TItem="McpServer.UI.Core.Messages.SessionLogEntryDetail"
                                     Items="ViewModel.Detail.Entries"
                                     ColumnCount="6"
                                     Class="Table--full-width"
                                     RowClass="GetEntryRowClass"
                                     style="width:100%; table-layout:fixed;">
                        <HeaderTemplate>
                            <tr>
                                <th style="width:56px;">#</th>
                                <th>Title</th>
                                <th style="width:180px;">Request ID</th>
                                <th style="width:100px;">Status</th>
                                <th style="width:140px;">Timestamp</th>
                                <th style="width:90px;"></th>
                            </tr>
                        </HeaderTemplate>
                        <RowTemplate Context="entry">
                            <td>@(GetEntryIndex(entry) + 1)</td>
                            <td>
                                <span class="dashboard-link-truncate" title="@GetEntryHeading(entry)">
                                    @GetEntryHeading(entry)
                                </span>
                            </td>
                            <td><code>@entry.RequestId</code></td>
                            <td>@(entry.Status ?? "(unknown)")</td>
                            <td>@FormatTimestamp(entry.Timestamp)</td>
                            <td class="text-right">
                                <button class="btn btn-sm" @onclick="() => SelectEntry(GetEntryIndex(entry))">Details</button>
                            </td>
                        </RowTemplate>
                    </PrimerDataTable>
                </div>

                @if (SelectedEntry is not null)
                {
                    <div class="d-flex flex-wrap flex-items-center gap-2 mb-2 session-entry-controls">
                        <button class="btn btn-sm" @onclick="SelectPreviousEntry" disabled="@(!CanSelectPrevious)">Previous</button>
                        <button class="btn btn-sm" @onclick="SelectNextEntry" disabled="@(!CanSelectNext)">Next</button>
                        <span class="color-fg-muted f6">Entry @(_selectedEntryIndex + 1) of @ViewModel.Detail.Entries.Count</span>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mb-3 session-entry-controls">
                        <button class="@GetEntryViewButtonClass("overview")" @onclick='() => SetEntryView("overview")'>Overview</button>
                        <button class="@GetEntryViewButtonClass("query")" @onclick='() => SetEntryView("query")'>Query</button>
                        <button class="@GetEntryViewButtonClass("response")" @onclick='() => SetEntryView("response")'>Response</button>
                        <button class="@GetEntryViewButtonClass("dialog")" @onclick='() => SetEntryView("dialog")'>Processing Dialog</button>
                        <button class="@GetEntryViewButtonClass("actions")" @onclick='() => SetEntryView("actions")'>Actions</button>
                    </div>

                    <div class="Box mb-3">
                        <div class="Box-header">
                            <h3 class="h4 mb-0">Entry Details · @GetEntryHeading(SelectedEntry)</h3>
                        </div>
                        <div class="Box-body">
                            @if (string.Equals(_entryView, "overview", StringComparison.Ordinal))
                            {
                                <div class="session-entry-meta-grid">
                                    <div><span class="color-fg-muted f6">Request ID</span><div><code>@SelectedEntry.RequestId</code></div></div>
                                    <div><span class="color-fg-muted f6">Status</span><div>@(SelectedEntry.Status ?? "(unknown)")</div></div>
                                    <div><span class="color-fg-muted f6">Timestamp</span><div>@FormatTimestamp(SelectedEntry.Timestamp)</div></div>
                                    <div><span class="color-fg-muted f6">Model</span><div>@(SelectedEntry.Model ?? "(unknown)")</div></div>
                                    <div><span class="color-fg-muted f6">Provider</span><div>@(SelectedEntry.ModelProvider ?? "(unknown)")</div></div>
                                    <div><span class="color-fg-muted f6">Tokens</span><div>@(SelectedEntry.TokenCount?.ToString() ?? "(unknown)")</div></div>
                                    <div><span class="color-fg-muted f6">Processing Dialog</span><div>@SelectedEntry.ProcessingDialog.Count</div></div>
                                    <div><span class="color-fg-muted f6">Actions</span><div>@SelectedEntry.Actions.Count</div></div>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(SelectedEntry.Interpretation))
                                {
                                    <div class="mt-3">
                                        <span class="color-fg-muted f6">Interpretation</span>
                                        <pre class="session-entry-text mt-1">@SelectedEntry.Interpretation</pre>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(SelectedEntry.FailureNote))
                                {
                                    <div class="mt-3">
                                        <span class="color-fg-muted f6">Failure Note</span>
                                        <pre class="session-entry-text mt-1">@SelectedEntry.FailureNote</pre>
                                    </div>
                                }
                            }
                            else if (string.Equals(_entryView, "query", StringComparison.Ordinal))
                            {
                                @if (string.IsNullOrWhiteSpace(SelectedEntry.QueryText))
                                {
                                    <p class="color-fg-muted mb-0">No query text for this entry.</p>
                                }
                                else
                                {
                                    <pre class="session-entry-text mb-0">@SelectedEntry.QueryText</pre>
                                }
                            }
                            else if (string.Equals(_entryView, "response", StringComparison.Ordinal))
                            {
                                @if (string.IsNullOrWhiteSpace(SelectedEntry.Response))
                                {
                                    <p class="color-fg-muted mb-0">No response content for this entry.</p>
                                }
                                else
                                {
                                    <pre class="session-entry-text mb-0">@SelectedEntry.Response</pre>
                                }
                            }
                            else if (string.Equals(_entryView, "dialog", StringComparison.Ordinal))
                            {
                                @if (SelectedEntry.ProcessingDialog.Count == 0)
                                {
                                    <p class="color-fg-muted mb-0">No processing dialog for this entry.</p>
                                }
                                else
                                {
                                    <PrimerDataTable TItem="McpServer.UI.Core.Messages.SessionLogDialogDetail"
                                                     Items="SelectedEntry.ProcessingDialog"
                                                     ColumnCount="4"
                                                     Class="Table--full-width"
                                                     style="width:100%; table-layout:fixed;">
                                        <HeaderTemplate>
                                            <tr>
                                                <th style="width:140px;">Timestamp</th>
                                                <th style="width:100px;">Role</th>
                                                <th style="width:120px;">Category</th>
                                                <th>Content</th>
                                            </tr>
                                        </HeaderTemplate>
                                        <RowTemplate Context="dialog">
                                            <td>@FormatTimestamp(dialog.Timestamp)</td>
                                            <td>@(dialog.Role ?? "(unknown)")</td>
                                            <td>@(dialog.Category ?? "(unknown)")</td>
                                            <td><span class="session-entry-dialog-content">@((dialog.Content ?? "(none)"))</span></td>
                                        </RowTemplate>
                                    </PrimerDataTable>
                                }
                            }
                            else if (string.Equals(_entryView, "actions", StringComparison.Ordinal))
                            {
                                @if (SelectedEntry.Actions.Count == 0)
                                {
                                    <p class="color-fg-muted mb-0">No actions for this entry.</p>
                                }
                                else
                                {
                                    <PrimerDataTable TItem="McpServer.UI.Core.Messages.SessionLogActionDetail"
                                                     Items="SelectedEntry.Actions"
                                                     ColumnCount="5"
                                                     Class="Table--full-width"
                                                     style="width:100%; table-layout:fixed;">
                                        <HeaderTemplate>
                                            <tr>
                                                <th style="width:56px;">#</th>
                                                <th style="width:120px;">Type</th>
                                                <th style="width:100px;">Status</th>
                                                <th>Description</th>
                                                <th style="width:180px;">File</th>
                                            </tr>
                                        </HeaderTemplate>
                                        <RowTemplate Context="action">
                                            <td>@action.Order</td>
                                            <td>@(action.Type ?? "(unknown)")</td>
                                            <td>@(action.Status ?? "(unknown)")</td>
                                            <td>@(action.Description ?? "(none)")</td>
                                            <td>@(action.FilePath ?? "(none)")</td>
                                        </RowTemplate>
                                    </PrimerDataTable>
                                }
                            }
                        </div>
                    </div>
                }
            }
        }
    </div>
</div>

@code {
    [Parameter]
    public string SessionId { get; set; } = string.Empty;

    [SupplyParameterFromQuery]
    public string? Agent { get; set; }

    [SupplyParameterFromQuery]
    public string? Model { get; set; }

    [SupplyParameterFromQuery]
    public string? Text { get; set; }

    private string? _loadedSessionId;
    private string? _lastFilterKey;
    private int _selectedEntryIndex;
    private string _entryView = "overview";

    protected override async Task OnParametersSetAsync()
    {
        var filterKey = $"{Agent}|{Model}|{Text}";
        if (!string.Equals(filterKey, _lastFilterKey, StringComparison.Ordinal))
        {
            _lastFilterKey = filterKey;
            ListViewModel.Agent = Agent;
            ListViewModel.Model = Model;
            ListViewModel.Text = Text;
            ListViewModel.Limit = 50;
            ListViewModel.Offset = 0;
            await ListViewModel.LoadAsync().ConfigureAwait(true);
        }

        if (string.Equals(_loadedSessionId, SessionId, StringComparison.Ordinal))
            return;

        _loadedSessionId = SessionId;
        ViewModel.SessionId = SessionId;
        await ViewModel.LoadAsync().ConfigureAwait(true);
        _selectedEntryIndex = 0;
        _entryView = "overview";
    }

    private static string GetEntryHeading(McpServer.UI.Core.Messages.SessionLogEntryDetail entry)
        => string.IsNullOrWhiteSpace(entry.QueryTitle) ? "Request Entry" : entry.QueryTitle;

    private McpServer.UI.Core.Messages.SessionLogEntryDetail? SelectedEntry
        => ViewModel.Detail is null || ViewModel.Detail.Entries.Count == 0 || _selectedEntryIndex < 0 || _selectedEntryIndex >= ViewModel.Detail.Entries.Count
            ? null
            : ViewModel.Detail.Entries[_selectedEntryIndex];

    private bool CanSelectPrevious => SelectedEntry is not null && _selectedEntryIndex > 0;

    private bool CanSelectNext => ViewModel.Detail is not null && SelectedEntry is not null && _selectedEntryIndex < ViewModel.Detail.Entries.Count - 1;

    private void SelectPreviousEntry()
    {
        if (CanSelectPrevious)
            _selectedEntryIndex--;
    }

    private void SelectNextEntry()
    {
        if (CanSelectNext)
            _selectedEntryIndex++;
    }

    private void SelectEntry(int index)
    {
        if (ViewModel.Detail is null || index < 0 || index >= ViewModel.Detail.Entries.Count)
            return;

        _selectedEntryIndex = index;
    }

    private int GetEntryIndex(McpServer.UI.Core.Messages.SessionLogEntryDetail entry)
    {
        if (ViewModel.Detail is null)
            return -1;

        for (var i = 0; i < ViewModel.Detail.Entries.Count; i++)
        {
            if (ReferenceEquals(ViewModel.Detail.Entries[i], entry))
                return i;
        }

        return -1;
    }

    private string? GetEntryRowClass(McpServer.UI.Core.Messages.SessionLogEntryDetail entry)
        => GetEntryIndex(entry) == _selectedEntryIndex ? "session-entry-row-selected" : null;

    private string GetEntryViewButtonClass(string view)
        => string.Equals(_entryView, view, StringComparison.Ordinal) ? "btn btn-sm btn-primary" : "btn btn-sm";

    private void SetEntryView(string view)
        => _entryView = view;

    private string GetDetailHref(string sessionId)
    {
        var qs = BuildFilterQueryString();
        return string.IsNullOrEmpty(qs)
            ? $"/sessions/{Uri.EscapeDataString(sessionId)}"
            : $"/sessions/{Uri.EscapeDataString(sessionId)}?{qs}";
    }

    private string BuildFilterQueryString()
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(Agent)) parts.Add($"agent={Uri.EscapeDataString(Agent)}");
        if (!string.IsNullOrWhiteSpace(Model)) parts.Add($"model={Uri.EscapeDataString(Model)}");
        if (!string.IsNullOrWhiteSpace(Text)) parts.Add($"text={Uri.EscapeDataString(Text)}");
        return string.Join("&", parts);
    }

    private static string FormatTimestamp(string? value)
        => DateTimeOffset.TryParse(value, out var dto) ? dto.ToLocalTime().ToString("g") : value ?? "(unknown)";
}

