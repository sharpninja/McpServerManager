@page "/sessions/{SessionId}"

@inject SessionLogDetailViewModel ViewModel
@inject SessionLogListViewModel ListViewModel
@inject WebCommandTarget CommandTarget

<PageTitle>Session Log Detail</PageTitle>

<div class="detail-layout">
    <aside class="detail-sidebar">
        <div class="sidebar-header">Sessions</div>
        @foreach (var item in ListViewModel?.Items ?? [])
        {
            <a class="sidebar-item @(string.Equals(item.SessionId, SessionId, StringComparison.Ordinal) ? "active" : "")"
               href="@GetDetailHref(item.SessionId)">
                <span class="color-fg-muted f6">@item.SourceType · @item.Status</span>
                <br />@item.Title
            </a>
        }
    </aside>

    <div class="detail-main">
        <DetailItemToolbar Items="GetNavigationItems()"
                           CurrentKey="@SessionId"
                           ItemTypeLabel="Session"
                           AriaLabel="Session item navigation" />

        @if (string.IsNullOrWhiteSpace(SessionId))
        {
            <PrimerBlankslate Heading="No session selected" Description="Open this page from the sidebar." />
        }
        else if (!string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
        {
            <PrimerFlash Variant="danger" Title="Failed to load session">@ViewModel.ErrorMessage</PrimerFlash>
        }
        else if (ViewModel.IsBusy)
        {
            <p class="color-fg-muted">Loading session details...</p>
        }
        else if (ViewModel.Detail is null)
        {
            <PrimerBlankslate Heading="Session not found" Description="The requested session could not be located." />
        }
        else
        {
            <div class="Box">
                <div class="Box-header">
                    <h2 class="h3 mb-0">@ViewModel.Detail.Title</h2>
                </div>
                <div class="Box-body">
                    <div class="detail-field-grid detail-field-grid--compact">
                        <div class="detail-field--wide"><span class="color-fg-muted f6">Session ID</span><div><code>@ViewModel.Detail.SessionId</code></div></div>
                        <div><span class="color-fg-muted f6">Source Type</span><div>@ViewModel.Detail.SourceType</div></div>
                        <div><span class="color-fg-muted f6">Status</span><div>@ViewModel.Detail.Status</div></div>
                        <div><span class="color-fg-muted f6">Model</span><div>@(ViewModel.Detail.Model ?? "(not set)")</div></div>
                        <div><span class="color-fg-muted f6">Started</span><div>@FormatTimestamp(ViewModel.Detail.Started)</div></div>
                        <div><span class="color-fg-muted f6">Last Updated</span><div>@FormatTimestamp(ViewModel.Detail.LastUpdated)</div></div>
                        <div><span class="color-fg-muted f6">Turn Count</span><div>@ViewModel.Detail.TurnCount</div></div>
                        <div><span class="color-fg-muted f6">Total Tokens</span><div>@(ViewModel.Detail.TotalTokens?.ToString() ?? "(unknown)")</div></div>
                        <div><span class="color-fg-muted f6">Cursor Session Label</span><div>@(ViewModel.Detail.CursorSessionLabel ?? "(none)")</div></div>
                    </div>
                </div>
            </div>

            @if (ViewModel.Detail.Turns.Count == 0)
            {
                <PrimerBlankslate Heading="No turns" Description="This session does not have request turns." />
            }
            else
            {
                <div class="Box">
                    <div class="Box-header">
                        <h3 class="h4 mb-0">Turns</h3>
                    </div>
                    <PrimerDataTable TItem="McpServer.UI.Core.Messages.SessionLogTurnDetail"
                                     Items="ViewModel.Detail.Turns"
                                     ColumnCount="6"
                                     Class="Table--full-width"
                                     RowClass="GetTurnRowClass"
                                     style="width:100%; table-layout:fixed;">
                        <HeaderTemplate>
                            <tr>
                                <th style="width:56px;">#</th>
                                <th>Title</th>
                                <th style="width:180px;">Request ID</th>
                                <th style="width:100px;">Status</th>
                                <th style="width:140px;">Timestamp</th>
                                <th style="width:90px;"></th>
                            </tr>
                        </HeaderTemplate>
                        <RowTemplate Context="turn">
                            <td>@(GetTurnIndex(turn) + 1)</td>
                            <td>
                                <span class="dashboard-link-truncate" title="@GetTurnHeading(turn)">
                                    @GetTurnHeading(turn)
                                </span>
                            </td>
                            <td><code>@turn.RequestId</code></td>
                            <td>@(turn.Status ?? "(unknown)")</td>
                            <td>@FormatTimestamp(turn.Timestamp)</td>
                            <td class="text-right">
                                <button class="btn btn-sm" @onclick="() => SelectTurn(GetTurnIndex(turn))">Details</button>
                            </td>
                        </RowTemplate>
                    </PrimerDataTable>
                </div>

                @if (SelectedTurn is not null)
                {
                    <div class="d-flex flex-wrap flex-items-center gap-2 mb-2 session-turn-controls">
                        <button class="btn btn-sm" @onclick="SelectPreviousTurn" disabled="@(!CanSelectPrevious)">Previous</button>
                        <button class="btn btn-sm" @onclick="SelectNextTurn" disabled="@(!CanSelectNext)">Next</button>
                        <span class="color-fg-muted f6">Turn @(_selectedTurnIndex + 1) of @ViewModel.Detail.Turns.Count</span>
                    </div>

                    <div class="session-turn-heading mb-3">
                        <h3 class="h4 mb-0">Turn Details · @GetTurnHeading(SelectedTurn)</h3>
                    </div>

                    <div class="Box session-turn-section">
                        <div class="Box-header">
                            <button type="button"
                                    class="session-turn-expander"
                                    aria-expanded="@IsTurnSectionExpanded(OverviewSectionKey).ToString().ToLowerInvariant()"
                                    @onclick='() => ToggleTurnSection(OverviewSectionKey)'>
                                <span>Overview</span>
                                <span class="session-turn-expander__icon" aria-hidden="true">@GetTurnSectionIcon(OverviewSectionKey)</span>
                            </button>
                        </div>
                        @if (IsTurnSectionExpanded(OverviewSectionKey))
                        {
                            <div class="Box-body">
                                <div class="detail-field-grid detail-field-grid--compact">
                                    <div class="detail-field--wide"><span class="color-fg-muted f6">Request ID</span><div><code>@SelectedTurn.RequestId</code></div></div>
                                    <div><span class="color-fg-muted f6">Status</span><div>@(SelectedTurn.Status ?? "(unknown)")</div></div>
                                    <div><span class="color-fg-muted f6">Timestamp</span><div>@FormatTimestamp(SelectedTurn.Timestamp)</div></div>
                                    <div><span class="color-fg-muted f6">Model</span><div>@(SelectedTurn.Model ?? "(unknown)")</div></div>
                                    <div><span class="color-fg-muted f6">Provider</span><div>@(SelectedTurn.ModelProvider ?? "(unknown)")</div></div>
                                    <div><span class="color-fg-muted f6">Tokens</span><div>@(SelectedTurn.TokenCount?.ToString() ?? "(unknown)")</div></div>
                                    <div><span class="color-fg-muted f6">Processing Dialog</span><div>@SelectedTurn.ProcessingDialog.Count</div></div>
                                    <div><span class="color-fg-muted f6">Actions</span><div>@SelectedTurn.Actions.Count</div></div>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(SelectedTurn.Interpretation))
                                {
                                    <div class="mt-3">
                                        <span class="color-fg-muted f6">Interpretation</span>
                                        <pre class="session-turn-text mt-1">@SelectedTurn.Interpretation</pre>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(SelectedTurn.FailureNote))
                                {
                                    <div class="mt-3">
                                        <span class="color-fg-muted f6">Failure Note</span>
                                        <pre class="session-turn-text mt-1">@SelectedTurn.FailureNote</pre>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="Box session-turn-section">
                        <div class="Box-header">
                            <button type="button"
                                    class="session-turn-expander"
                                    aria-expanded="@IsTurnSectionExpanded(QuerySectionKey).ToString().ToLowerInvariant()"
                                    @onclick='() => ToggleTurnSection(QuerySectionKey)'>
                                <span>Query</span>
                                <span class="session-turn-expander__icon" aria-hidden="true">@GetTurnSectionIcon(QuerySectionKey)</span>
                            </button>
                        </div>
                        @if (IsTurnSectionExpanded(QuerySectionKey))
                        {
                            <div class="Box-body">
                                @if (string.IsNullOrWhiteSpace(SelectedTurn.QueryText))
                                {
                                    <p class="color-fg-muted mb-0">No query text for this turn.</p>
                                }
                                else
                                {
                                    <pre class="session-turn-text mb-0">@SelectedTurn.QueryText</pre>
                                }
                            </div>
                        }
                    </div>

                    <div class="Box session-turn-section">
                        <div class="Box-header">
                            <button type="button"
                                    class="session-turn-expander"
                                    aria-expanded="@IsTurnSectionExpanded(ResponseSectionKey).ToString().ToLowerInvariant()"
                                    @onclick='() => ToggleTurnSection(ResponseSectionKey)'>
                                <span>Response</span>
                                <span class="session-turn-expander__icon" aria-hidden="true">@GetTurnSectionIcon(ResponseSectionKey)</span>
                            </button>
                        </div>
                        @if (IsTurnSectionExpanded(ResponseSectionKey))
                        {
                            <div class="Box-body">
                                @if (string.IsNullOrWhiteSpace(SelectedTurn.Response))
                                {
                                    <p class="color-fg-muted mb-0">No response content for this turn.</p>
                                }
                                else
                                {
                                    <pre class="session-turn-text mb-0">@SelectedTurn.Response</pre>
                                }
                            </div>
                        }
                    </div>

                    <div class="Box session-turn-section">
                        <div class="Box-header">
                            <button type="button"
                                    class="session-turn-expander"
                                    aria-expanded="@IsTurnSectionExpanded(DialogSectionKey).ToString().ToLowerInvariant()"
                                    @onclick='() => ToggleTurnSection(DialogSectionKey)'>
                                <span>Processing Dialog</span>
                                <span class="session-turn-expander__icon" aria-hidden="true">@GetTurnSectionIcon(DialogSectionKey)</span>
                            </button>
                        </div>
                        @if (IsTurnSectionExpanded(DialogSectionKey))
                        {
                            <div class="Box-body">
                                @if (SelectedTurn.ProcessingDialog.Count == 0)
                                {
                                    <p class="color-fg-muted mb-0">No processing dialog for this turn.</p>
                                }
                                else
                                {
                                    <PrimerDataTable TItem="McpServer.UI.Core.Messages.SessionLogDialogDetail"
                                                     Items="SelectedTurn.ProcessingDialog"
                                                     ColumnCount="4"
                                                     Class="Table--full-width"
                                                     style="width:100%; table-layout:fixed;">
                                        <HeaderTemplate>
                                            <tr>
                                                <th style="width:140px;">Timestamp</th>
                                                <th style="width:100px;">Role</th>
                                                <th style="width:120px;">Category</th>
                                                <th>Content</th>
                                            </tr>
                                        </HeaderTemplate>
                                        <RowTemplate Context="dialog">
                                            <td>@FormatTimestamp(dialog.Timestamp)</td>
                                            <td>@(dialog.Role ?? "(unknown)")</td>
                                            <td>@(dialog.Category ?? "(unknown)")</td>
                                            <td><span class="session-turn-dialog-content">@((dialog.Content ?? "(none)"))</span></td>
                                        </RowTemplate>
                                    </PrimerDataTable>
                                }
                            </div>
                        }
                    </div>

                    <div class="Box session-turn-section">
                        <div class="Box-header">
                            <button type="button"
                                    class="session-turn-expander"
                                    aria-expanded="@IsTurnSectionExpanded(ActionsSectionKey).ToString().ToLowerInvariant()"
                                    @onclick='() => ToggleTurnSection(ActionsSectionKey)'>
                                <span>Actions</span>
                                <span class="session-turn-expander__icon" aria-hidden="true">@GetTurnSectionIcon(ActionsSectionKey)</span>
                            </button>
                        </div>
                        @if (IsTurnSectionExpanded(ActionsSectionKey))
                        {
                            <div class="Box-body">
                                @if (SelectedTurn.Actions.Count == 0)
                                {
                                    <p class="color-fg-muted mb-0">No actions for this turn.</p>
                                }
                                else
                                {
                                    <PrimerDataTable TItem="McpServer.UI.Core.Messages.SessionLogActionDetail"
                                                     Items="SelectedTurn.Actions"
                                                     ColumnCount="5"
                                                     Class="Table--full-width"
                                                     style="width:100%; table-layout:fixed;">
                                        <HeaderTemplate>
                                            <tr>
                                                <th style="width:56px;">#</th>
                                                <th style="width:120px;">Type</th>
                                                <th style="width:100px;">Status</th>
                                                <th>Description</th>
                                                <th style="width:180px;">File</th>
                                            </tr>
                                        </HeaderTemplate>
                                        <RowTemplate Context="action">
                                            <td>@action.Order</td>
                                            <td>@(action.Type ?? "(unknown)")</td>
                                            <td>@(action.Status ?? "(unknown)")</td>
                                            <td>@(action.Description ?? "(none)")</td>
                                            <td>@(action.FilePath ?? "(none)")</td>
                                        </RowTemplate>
                                    </PrimerDataTable>
                                }
                            </div>
                        }
                    </div>
                }
            }
        }
    </div>
</div>

@code {
    [Parameter]
    public string SessionId { get; set; } = string.Empty;

    [SupplyParameterFromQuery]
    public string? Agent { get; set; }

    [SupplyParameterFromQuery]
    public string? Model { get; set; }

    [SupplyParameterFromQuery]
    public string? Text { get; set; }

    private string? _loadedSessionId;
    private string? _lastFilterKey;
    private int _selectedTurnIndex;
    private HashSet<string> _expandedTurnSections = CreateDefaultExpandedTurnSections();

    private const string OverviewSectionKey = "overview";
    private const string QuerySectionKey = "query";
    private const string ResponseSectionKey = "response";
    private const string DialogSectionKey = "dialog";
    private const string ActionsSectionKey = "actions";

    protected override async Task OnParametersSetAsync()
    {
        var filterKey = $"{Agent}|{Model}|{Text}";
        if (!string.Equals(filterKey, _lastFilterKey, StringComparison.Ordinal))
        {
            _lastFilterKey = filterKey;
            await CommandTarget.RunAsync(async () =>
            {
                ListViewModel.Agent = Agent;
                ListViewModel.Model = Model;
                ListViewModel.Text = Text;
                ListViewModel.Limit = 50;
                ListViewModel.Offset = 0;
                await ListViewModel.LoadAsync().ConfigureAwait(true);
            }).ConfigureAwait(true);
        }

        if (string.Equals(_loadedSessionId, SessionId, StringComparison.Ordinal))
            return;

        _loadedSessionId = SessionId;
        await CommandTarget.RunAsync(async () =>
        {
            ViewModel.SessionId = SessionId;
            await ViewModel.LoadAsync().ConfigureAwait(true);
        }).ConfigureAwait(true);
        _selectedTurnIndex = 0;
        ResetExpandedTurnSections();
    }

    private static string GetTurnHeading(McpServer.UI.Core.Messages.SessionLogTurnDetail turn)
        => string.IsNullOrWhiteSpace(turn.QueryTitle) ? "Turn" : turn.QueryTitle;

    private McpServer.UI.Core.Messages.SessionLogTurnDetail? SelectedTurn
        => ViewModel.Detail is null || ViewModel.Detail.Turns.Count == 0 || _selectedTurnIndex < 0 || _selectedTurnIndex >= ViewModel.Detail.Turns.Count
            ? null
            : ViewModel.Detail.Turns[_selectedTurnIndex];

    private bool CanSelectPrevious => SelectedTurn is not null && _selectedTurnIndex > 0;

    private bool CanSelectNext => ViewModel.Detail is not null && SelectedTurn is not null && _selectedTurnIndex < ViewModel.Detail.Turns.Count - 1;

    private void SelectPreviousTurn()
    {
        if (CanSelectPrevious)
        {
            _selectedTurnIndex--;
            ResetExpandedTurnSections();
        }
    }

    private void SelectNextTurn()
    {
        if (CanSelectNext)
        {
            _selectedTurnIndex++;
            ResetExpandedTurnSections();
        }
    }

    private void SelectTurn(int index)
    {
        if (ViewModel.Detail is null || index < 0 || index >= ViewModel.Detail.Turns.Count)
            return;

        _selectedTurnIndex = index;
        ResetExpandedTurnSections();
    }

    private int GetTurnIndex(McpServer.UI.Core.Messages.SessionLogTurnDetail turn)
    {
        if (ViewModel.Detail is null)
            return -1;

        for (var i = 0; i < ViewModel.Detail.Turns.Count; i++)
        {
            if (ReferenceEquals(ViewModel.Detail.Turns[i], turn))
                return i;
        }

        return -1;
    }

    private string? GetTurnRowClass(McpServer.UI.Core.Messages.SessionLogTurnDetail turn)
        => GetTurnIndex(turn) == _selectedTurnIndex ? "session-turn-row-selected" : null;

    private bool IsTurnSectionExpanded(string section)
        => _expandedTurnSections.Contains(section);

    private void ToggleTurnSection(string section)
    {
        if (!_expandedTurnSections.Add(section))
        {
            _expandedTurnSections.Remove(section);
        }
    }

    private void ResetExpandedTurnSections()
        => _expandedTurnSections = CreateDefaultExpandedTurnSections();

    private static HashSet<string> CreateDefaultExpandedTurnSections()
        => new(StringComparer.Ordinal)
        {
            OverviewSectionKey,
            QuerySectionKey,
            ResponseSectionKey,
            DialogSectionKey,
            ActionsSectionKey
        };

    private string GetTurnSectionIcon(string section)
        => IsTurnSectionExpanded(section) ? "▾" : "▸";

    private string GetDetailHref(string sessionId)
    {
        var qs = BuildFilterQueryString();
        return string.IsNullOrEmpty(qs)
            ? $"/sessions/{Uri.EscapeDataString(sessionId)}"
            : $"/sessions/{Uri.EscapeDataString(sessionId)}?{qs}";
    }

    private IReadOnlyList<DetailNavigationItem> GetNavigationItems()
        => (ListViewModel?.Items ?? [])
            .Select(item => new DetailNavigationItem(
                item.SessionId,
                GetDetailHref(item.SessionId),
                item.Title,
                $"{item.SourceType} · {item.Status}"))
            .ToArray();

    private string BuildFilterQueryString()
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(Agent)) parts.Add($"agent={Uri.EscapeDataString(Agent)}");
        if (!string.IsNullOrWhiteSpace(Model)) parts.Add($"model={Uri.EscapeDataString(Model)}");
        if (!string.IsNullOrWhiteSpace(Text)) parts.Add($"text={Uri.EscapeDataString(Text)}");
        return string.Join("&", parts);
    }

    private static string FormatTimestamp(string? value)
        => DateTimeOffset.TryParse(value, out var dto) ? dto.ToLocalTime().ToString("g") : value ?? "(unknown)";
}

