@page "/"
@page "/dashboard"

@inject DashboardViewModel ViewModel
@inject WorkspaceListViewModel WorkspaceListVm
@inject WorkspaceContextViewModel WorkspaceContext
@inject TodoListViewModel TodoListVm
@inject SessionLogListViewModel SessionLogListVm
@inject WebCommandTarget CommandTarget

<PageTitle>Dashboard</PageTitle>

<div class="d-flex flex-items-center flex-justify-between mb-3">
    <h1 class="h2 mb-0">Dashboard</h1>
    @if (!string.IsNullOrWhiteSpace(WorkspaceContext.ActiveWorkspacePath))
    {
        <span class="text-small color-fg-muted d-flex flex-items-center">
            <OcticonIcon Name="check-circle" Size="16" Class="color-fg-success mr-1" />
            Active: <strong class="ml-1">@ActiveWorkspaceName</strong>
        </span>
    }
</div>

@if (!string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
{
    <PrimerFlash Variant="danger" Title="Dashboard load failed">@ViewModel.ErrorMessage</PrimerFlash>
}
else if (ViewModel.IsLoading)
{
    <p class="color-fg-muted">Loading dashboard...</p>
}
else
{
    <div class="dashboard-metrics">
        <div class="Box p-3 dashboard-metric">
            <div class="h2 mb-1">@ViewModel.WorkspaceCount</div>
            <div class="color-fg-muted">Workspaces</div>
        </div>
        <div class="Box p-3 dashboard-metric">
            <div class="h2 mb-1">@ViewModel.TodoCount</div>
            <div class="color-fg-muted">Todos</div>
        </div>
        <div class="Box p-3 dashboard-metric">
            <div class="h2 mb-1">@ViewModel.SessionLogCount</div>
            <div class="color-fg-muted">Session logs</div>
        </div>
        <div class="Box p-3 dashboard-metric">
            <div class="h2 mb-1">@ViewModel.TemplateCount</div>
            <div class="color-fg-muted">Templates</div>
        </div>
    </div>

    <div class="mt-3">
        <PrimerLabel Scheme="@GetHealthScheme(ViewModel.HealthStatus)" Text="@($"Health: {ViewModel.HealthStatus}")" />
    </div>

    <div class="Box mt-4">
        <div class="Box-header d-flex flex-justify-between flex-items-center">
            <h2 class="h4 mb-0">Workspaces</h2>
            <a class="btn btn-sm" href="/workspaces">View all</a>
        </div>
        @if (WorkspaceListVm.Workspaces.Count == 0)
        {
            <div class="Box-body color-fg-muted">No workspaces found.</div>
        }
        else
        {
            <PrimerDataTable TItem="WorkspaceSummary"
                             Items="WorkspaceListVm.Workspaces"
                             ColumnCount="3"
                             Class="Table--full-width"
                             RowClass="GetWorkspaceRowClass"
                             style="width:100%; table-layout:fixed;">
                <HeaderTemplate>
                    <tr>
                        <th style="width:40px"></th>
                        <th>Workspace</th>
                        <th style="width:120px"></th>
                    </tr>
                </HeaderTemplate>
                <RowTemplate Context="ws">
                    <td>
                        @if (IsActive(ws.WorkspacePath))
                        {
                            <OcticonIcon Name="check-circle" Size="16" Class="color-fg-success" AriaLabel="Active workspace" />
                        }
                    </td>
                    <td>
                        <div class="dashboard-workspace-cell">
                            <span class="text-bold">@ws.Name</span>
                            <span class="dashboard-workspace-path color-fg-muted f6" title="@ws.WorkspacePath">@ws.WorkspacePath</span>
                        </div>
                    </td>
                    <td class="text-right">
                        @if (IsActive(ws.WorkspacePath))
                        {
                            <span class="btn btn-sm btn-primary disabled" aria-disabled="true">Selected</span>
                        }
                        else
                        {
                            <button class="btn btn-sm" @onclick="() => SelectWorkspace(ws.WorkspacePath)">Select</button>
                        }
                    </td>
                </RowTemplate>
            </PrimerDataTable>
        }
    </div>

    <div class="dashboard-panels mt-4">
        @* ── Open Todos ── *@
        <div class="Box">
            <div class="Box-header d-flex flex-justify-between flex-items-center">
                <h2 class="h4 mb-0">Open Todos</h2>
                <a class="btn btn-sm" href="/todos">View all</a>
            </div>
            @if (TodoListVm.IsLoading)
            {
                <div class="Box-body color-fg-muted">Loading...</div>
            }
            else if (TodoListVm.Items.Count == 0)
            {
                <div class="Box-body color-fg-muted">No open todos.</div>
            }
            else
            {
                <PrimerDataTable TItem="TodoListItem"
                                 Items="GetDashboardTodoItems()"
                                 ColumnCount="4"
                                 Class="Table--full-width"
                                 style="width:100%; table-layout:fixed;">
                    <HeaderTemplate>
                        <tr>
                            <th style="width:110px;">ID</th>
                            <th>Title</th>
                            <th style="width:100px;">Priority</th>
                            <th style="width:90px;"></th>
                        </tr>
                    </HeaderTemplate>
                    <RowTemplate Context="todo">
                        <td>
                            <a class="Link--primary" href="@GetTodoDetailHref(todo.Id)">
                                <code class="f6">@todo.Id</code>
                            </a>
                        </td>
                        <td>
                            <a class="Link--primary dashboard-link-truncate" href="@GetTodoDetailHref(todo.Id)" title="@todo.Title">
                                @todo.Title
                            </a>
                        </td>
                        <td>
                            <PrimerLabel Scheme="@GetPriorityScheme(todo.Priority)" Text="@todo.Priority" />
                        </td>
                        <td class="text-right">
                            <a class="btn btn-sm" href="@GetTodoDetailHref(todo.Id)">Details</a>
                        </td>
                    </RowTemplate>
                </PrimerDataTable>
                @if (TodoListVm.TotalCount > 10)
                {
                    <div class="Box-footer color-fg-muted f6">Showing 10 of @TodoListVm.TotalCount</div>
                }
            }
        </div>

        @* ── Recent Sessions ── *@
        <div class="Box">
            <div class="Box-header d-flex flex-justify-between flex-items-center">
                <h2 class="h4 mb-0">Recent Sessions</h2>
                <a class="btn btn-sm" href="/sessions">View all</a>
            </div>
            @if (SessionLogListVm.IsLoading)
            {
                <div class="Box-body color-fg-muted">Loading...</div>
            }
            else if (SessionLogListVm.Items.Count == 0)
            {
                <div class="Box-body color-fg-muted">No session logs.</div>
            }
            else
            {
                <PrimerDataTable TItem="SessionLogSummary"
                                 Items="GetDashboardSessionItems()"
                                 ColumnCount="3"
                                 Class="Table--full-width"
                                 style="width:100%; table-layout:fixed;">
                    <HeaderTemplate>
                        <tr>
                            <th>Session</th>
                            <th style="width:150px;">Updated</th>
                            <th style="width:90px;"></th>
                        </tr>
                    </HeaderTemplate>
                    <RowTemplate Context="log">
                        <td>
                            <a class="Link--primary dashboard-link-truncate" href="@GetSessionDetailHref(log.SessionId)" title="@log.Title">
                                @log.Title
                            </a>
                        </td>
                        <td>
                            <span class="color-fg-muted f6">@FormatTimestamp(log.LastUpdated)</span>
                        </td>
                        <td class="text-right">
                            <a class="btn btn-sm" href="@GetSessionDetailHref(log.SessionId)">Details</a>
                        </td>
                    </RowTemplate>
                </PrimerDataTable>
                @if (SessionLogListVm.TotalCount > 10)
                {
                    <div class="Box-footer color-fg-muted f6">Showing 10 of @SessionLogListVm.TotalCount</div>
                }
            }
        </div>
    </div>

}

@code {
    protected override async Task OnInitializedAsync()
    {
        await CommandTarget.RunAsync(async () =>
        {
            await ViewModel.LoadAsync().ConfigureAwait(true);
            await WorkspaceListVm.LoadAsync().ConfigureAwait(true);
        }).ConfigureAwait(true);
        await LoadWorkspaceDataAsync();
    }

    private async Task LoadWorkspaceDataAsync()
    {
        await CommandTarget.RunAsync(async () =>
        {
            TodoListVm.Done ??= false;
            SessionLogListVm.Limit = 50;
            SessionLogListVm.Offset = 0;
            await Task.WhenAll(
                TodoListVm.LoadAsync(),
                SessionLogListVm.LoadAsync()).ConfigureAwait(true);
        }).ConfigureAwait(true);
    }

    private static readonly string[] PriorityOrder = ["critical", "high", "medium", "low"];

    private IReadOnlyList<TodoListItem> GetDashboardTodoItems()
        => TodoListVm.Items
            .OrderBy(item => GetPriorityRank(item.Priority))
            .ThenBy(item => item.Id, StringComparer.OrdinalIgnoreCase)
            .Take(10)
            .ToList();

    private IReadOnlyList<SessionLogSummary> GetDashboardSessionItems()
        => SessionLogListVm.Items
            .Take(10)
            .ToList();

    private static int GetPriorityRank(string? priority)
    {
        var value = priority ?? "low";
        var index = Array.IndexOf(PriorityOrder, value.ToLowerInvariant());
        return index < 0 ? int.MaxValue : index;
    }

    private bool IsActive(string workspacePath)
        => string.Equals(WorkspaceContext.ActiveWorkspacePath, workspacePath, StringComparison.OrdinalIgnoreCase);

    private string? GetWorkspaceRowClass(WorkspaceSummary workspace)
        => IsActive(workspace.WorkspacePath) ? "active-workspace-row" : null;

    private string? ActiveWorkspaceName =>
        WorkspaceListVm.Workspaces
            .FirstOrDefault(w => IsActive(w.WorkspacePath))
            ?.Name ?? WorkspaceContext.ActiveWorkspacePath;

    private async Task SelectWorkspace(string workspacePath)
    {
        await CommandTarget.RunAsync(() => WorkspaceContext.ActiveWorkspacePath = workspacePath).ConfigureAwait(true);
        await LoadWorkspaceDataAsync();
    }

    private static string GetHealthScheme(string? status)
        => string.Equals(status, "healthy", StringComparison.OrdinalIgnoreCase) ? "success" : "attention";

    private static string GetPriorityScheme(string priority)
        => priority.ToLowerInvariant() switch
        {
            "critical" => "danger",
            "high" => "attention",
            "medium" => "done",
            "low" => "default",
            _ => "default",
        };

    private string GetTodoDetailHref(string id)
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(TodoListVm.Section)) parts.Add($"section={Uri.EscapeDataString(TodoListVm.Section)}");
        if (!string.IsNullOrWhiteSpace(TodoListVm.Priority)) parts.Add($"priority={Uri.EscapeDataString(TodoListVm.Priority)}");
        if (TodoListVm.Done.HasValue) parts.Add($"done={TodoListVm.Done.Value.ToString().ToLowerInvariant()}");
        var qs = string.Join("&", parts);
        var path = $"/todos/{Uri.EscapeDataString(id)}";
        return string.IsNullOrEmpty(qs) ? path : $"{path}?{qs}";
    }

    private string GetSessionDetailHref(string sessionId)
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(SessionLogListVm.Agent)) parts.Add($"agent={Uri.EscapeDataString(SessionLogListVm.Agent)}");
        if (!string.IsNullOrWhiteSpace(SessionLogListVm.Model)) parts.Add($"model={Uri.EscapeDataString(SessionLogListVm.Model)}");
        if (!string.IsNullOrWhiteSpace(SessionLogListVm.Text)) parts.Add($"text={Uri.EscapeDataString(SessionLogListVm.Text)}");
        var qs = string.Join("&", parts);
        var path = $"/sessions/{Uri.EscapeDataString(sessionId)}";
        return string.IsNullOrEmpty(qs) ? path : $"{path}?{qs}";
    }

    private static string FormatTimestamp(string? value)
        => DateTimeOffset.TryParse(value, out var dto) ? dto.ToLocalTime().ToString("g") : value ?? "";
}

