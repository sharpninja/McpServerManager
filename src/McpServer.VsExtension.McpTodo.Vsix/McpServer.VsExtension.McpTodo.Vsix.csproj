    <Reference Include="WindowsBase" />
    <Reference Include="System" />
    <Reference Include="System.Collections" />
    <Reference Include="System.Core" />
    <Reference Include="System.Net.Http" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.VSSDK.BuildTools" Version="17.14.2120" />
    <PackageReference Include="Microsoft.VisualStudio.Shell.15.0" Version="17.14.40264" />
    <PackageReference Include="Microsoft.VisualStudio.Imaging" Version="17.14.40264" />
    <PackageReference Include="Microsoft.VisualStudio.ImageCatalog" Version="17.14.40260" />
    <PackageReference Include="System.Text.Json" Version="9.0.5" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="CopilotCliHelper.cs" />
    <Compile Include="Properties\AssemblyInfo.cs" />
    <Compile Include="McpServerMcpTodoPackage.cs" />
    <Compile Include="McpServerMcpTodoToolWindowCommand.cs" />
    <Compile Include="McpServerMcpTodoToolWindowControl.xaml.cs">
      <DependentUpon>McpServerMcpTodoToolWindowControl.xaml</DependentUpon>
    </Compile>
    <Compile Include="McpServerMcpTodoToolWindowPane.cs" />
    <Compile Include="McpTodoClient.cs" />
