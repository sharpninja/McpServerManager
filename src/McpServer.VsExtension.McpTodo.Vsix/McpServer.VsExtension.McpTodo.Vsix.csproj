    <Compile Include="ViewModels\TodoToolWindowViewModel.cs" />
  </ItemGroup>
  <ItemGroup>
    <None Include="source.extension.vsixmanifest">
      <SubType>Designer</SubType>
    </None>
  </ItemGroup>
  <ItemGroup>
    <VSCTCompile Include="McpServer.VsExtension.McpTodo.vsct">
      <ResourceName>Menus.ctmenu</ResourceName>
    </VSCTCompile>
  </ItemGroup>
  <ItemGroup>
    <Page Include="McpServerMcpTodoToolWindowControl.xaml">
      <SubType>Designer</SubType>
      <Generator>MSBuild:Compile</Generator>
    </Page>
  </ItemGroup>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <Import Project="$(VSToolsPath)\VSSDK\Microsoft.VsSDK.targets" Condition="Exists('$(VSToolsPath)\VSSDK\Microsoft.VsSDK.targets')" />
  <!-- NuGet restore auto-imports nuget.g.targets via Microsoft.Common.targets; manual import removed to avoid MSB4011. -->
  <!-- Include transitive NuGet runtime dependencies in VSIX (System.Text.Json requires these on net472) -->
  <Target Name="IncludeTransitiveDepsInVsix" BeforeTargets="GetVsixSourceItems">
    <ItemGroup>
      <VSIXSourceItem Include="@(ReferenceCopyLocalPaths)"
                      Condition="'%(ReferenceCopyLocalPaths.Extension)' == '.dll'
                                  AND '%(ReferenceCopyLocalPaths.NuGetPackageId)' != ''
                                  AND '%(ReferenceCopyLocalPaths.NuGetPackageId)' != 'Microsoft.VSSDK.BuildTools'
                                  AND !$([System.String]::Copy('%(ReferenceCopyLocalPaths.NuGetPackageId)').StartsWith('Microsoft.VisualStudio.'))
                                  AND '%(ReferenceCopyLocalPaths.FileName)' != 'Newtonsoft.Json'">
        <VSIXSubPath></VSIXSubPath>
      </VSIXSourceItem>
    </ItemGroup>
  </Target>
    <!-- Embed the VSCT-compiled .cto as a managed resource (WPF targets conflict with native VSSDK MergeCtoResource) -->
  <Target Name="EmbedCtoResource" AfterTargets="MergeCtoResource" BeforeTargets="CoreCompile">
    <ItemGroup>
      <EmbeddedResource Include="$(IntermediateOutputPath)$(AssemblyName).cto"
                        LogicalName="Menus.ctmenu"
                        WithCulture="false"
                        Type="Non-Resx"
                        Condition="Exists('$(IntermediateOutputPath)$(AssemblyName).cto')" />
    </ItemGroup>
  </Target>
  <!-- Inject CodeBase into pkgdef so VS can locate the assembly at runtime -->
  <Target Name="InjectCodeBase" AfterTargets="Build" Condition="Exists('$(OutputPath)$(TargetName).pkgdef')">
    <Exec Command='pwsh -NoProfile -File "$(MSBuildProjectDirectory)/InjectCodeBase.ps1" -PkgdefPath "$(OutputPath)$(TargetName).pkgdef" -DllName "$(TargetFileName)"' />
  </Target>
</Project>
