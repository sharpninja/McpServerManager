<UserControl x:Class="McpServer.VsExtension.McpTodo.McpServerMcpTodoToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vs="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
             xmlns:catalog="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.ImageCatalog"
             xmlns:theming="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Imaging"
             mc:Ignorable="d" d:DesignHeight="400" d:DesignWidth="350"
             Background="{DynamicResource {x:Static vs:VsBrushes.ToolWindowBackgroundKey}}"
             Foreground="{DynamicResource {x:Static vs:VsBrushes.ToolWindowTextKey}}">
  <UserControl.Resources>
    <!-- Grouped view over the ViewModel's FilteredItems -->
    <CollectionViewSource x:Key="GroupedEntries" Source="{Binding FilteredItems}">
      <CollectionViewSource.GroupDescriptions>
        <PropertyGroupDescription PropertyName="PriorityGroup"/>
      </CollectionViewSource.GroupDescriptions>
    </CollectionViewSource>
    <!-- Button style matching VS theme -->
    <Style TargetType="Button">
      <Setter Property="Background" Value="{DynamicResource {x:Static vs:VsBrushes.ButtonFaceKey}}"/>
      <Setter Property="Foreground" Value="{DynamicResource {x:Static vs:VsBrushes.ButtonTextKey}}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vs:VsBrushes.AccentBorderKey}}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="6,2"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Padding="{TemplateBinding Padding}"
                    SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background"
                        Value="{DynamicResource {x:Static vs:VsBrushes.CommandBarMouseOverBackgroundBeginKey}}"/>
                <Setter TargetName="Bd" Property="BorderBrush"
                        Value="{DynamicResource {x:Static vs:VsBrushes.CommandBarHoverOverSelectedIconBorderKey}}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background"
                        Value="{DynamicResource {x:Static vs:VsBrushes.CommandBarMouseDownBackgroundBeginKey}}"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Background"
                        Value="{DynamicResource {x:Static vs:VsBrushes.ToolWindowBackgroundKey}}"/>
                <Setter TargetName="Bd" Property="BorderBrush"
                        Value="{DynamicResource {x:Static vs:VsBrushes.PanelBorderKey}}"/>
                <Setter Property="Foreground"
                        Value="{DynamicResource {x:Static vs:VsBrushes.GrayTextKey}}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <!-- ComboBox toggle button (dropdown arrow area) -->
    <ControlTemplate x:Key="VsComboBoxToggleButton" TargetType="ToggleButton">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition/>
          <ColumnDefinition Width="18"/>
        </Grid.ColumnDefinitions>
        <Border x:Name="MainBorder" Grid.ColumnSpan="2"
                Background="{DynamicResource {x:Static vs:VsBrushes.ComboBoxBackgroundKey}}"
                BorderBrush="{DynamicResource {x:Static vs:VsBrushes.ComboBoxBorderKey}}"
                BorderThickness="1" CornerRadius="1"/>
        <Border Grid.Column="1"
                Background="{DynamicResource {x:Static vs:VsBrushes.ComboBoxBackgroundKey}}"
                BorderBrush="{DynamicResource {x:Static vs:VsBrushes.ComboBoxBorderKey}}"
                BorderThickness="1,0,0,0" CornerRadius="0,1,1,0">
          <Path Data="M0,0 L4,4 8,0"
                Stroke="{DynamicResource {x:Static vs:VsBrushes.ComboBoxGlyphKey}}"
                StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
      </Grid>
      <ControlTemplate.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter TargetName="MainBorder" Property="Background"
                  Value="{DynamicResource {x:Static vs:VsBrushes.ComboBoxMouseOverBackgroundBeginKey}}"/>
          <Setter TargetName="MainBorder" Property="BorderBrush"
                  Value="{DynamicResource {x:Static vs:VsBrushes.ComboBoxMouseOverBorderKey}}"/>
        </Trigger>
      </ControlTemplate.Triggers>
    </ControlTemplate>
    <!-- Fully-themed ComboBox template -->
    <Style TargetType="ComboBox">
      <Setter Property="Foreground" Value="{DynamicResource {x:Static vs:VsBrushes.WindowTextKey}}"/>
      <Setter Property="Background" Value="{DynamicResource {x:Static vs:VsBrushes.ComboBoxBackgroundKey}}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vs:VsBrushes.ComboBoxBorderKey}}"/>
      <Setter Property="SnapsToDevicePixels" Value="True"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBox">
            <Grid>
              <ToggleButton Template="{StaticResource VsComboBoxToggleButton}"
                            Focusable="False" ClickMode="Press"
                            IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"/>
              <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                Margin="6,3,22,3" VerticalAlignment="Center" HorizontalAlignment="Left">
                <ContentPresenter.Resources>
                  <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static vs:VsBrushes.WindowTextKey}}"/>
                  </Style>
                </ContentPresenter.Resources>
              </ContentPresenter>
              <Popup x:Name="Popup" Placement="Bottom"
                     IsOpen="{TemplateBinding IsDropDownOpen}"
                     AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                <Grid x:Name="DropDown" SnapsToDevicePixels="True"
                      MinWidth="{TemplateBinding ActualWidth}"
                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                  <Border Background="{DynamicResource {x:Static vs:VsBrushes.WindowKey}}"
                          BorderBrush="{DynamicResource {x:Static vs:VsBrushes.ComboBoxPopupBorderKey}}"
                          BorderThickness="1">
                    <ScrollViewer SnapsToDevicePixels="True">
                      <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                    </ScrollViewer>
                  </Border>
                </Grid>
              </Popup>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <!-- Themed ComboBoxItem with hover highlight -->
    <Style TargetType="ComboBoxItem">
      <Setter Property="Foreground" Value="{DynamicResource {x:Static vs:VsBrushes.WindowTextKey}}"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Padding" Value="6,3"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBoxItem">
            <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
              <ContentPresenter/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{DynamicResource {x:Static vs:VsBrushes.HighlightKey}}"/>
                <Setter Property="Foreground" Value="{DynamicResource {x:Static vs:VsBrushes.HighlightTextKey}}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <!-- TextBox style -->
    <Style TargetType="TextBox">
      <Setter Property="Background" Value="{DynamicResource {x:Static vs:VsBrushes.WindowKey}}"/>
      <Setter Property="Foreground" Value="{DynamicResource {x:Static vs:VsBrushes.WindowTextKey}}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vs:VsBrushes.ComboBoxBorderKey}}"/>
      <Setter Property="CaretBrush" Value="{DynamicResource {x:Static vs:VsBrushes.WindowTextKey}}"/>
    </Style>
    <!-- ListViewItem style -->
    <Style TargetType="ListViewItem">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{DynamicResource {x:Static vs:VsBrushes.WindowTextKey}}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="6,3"/>
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="{DynamicResource {x:Static vs:VsBrushes.HighlightKey}}"/>
          <Setter Property="Foreground" Value="{DynamicResource {x:Static vs:VsBrushes.HighlightTextKey}}"/>
        </Trigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="{DynamicResource {x:Static vs:VsBrushes.CommandBarMouseOverBackgroundBeginKey}}"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <!-- GroupItem container style -->
    <Style TargetType="GroupItem">
      <Setter Property="Margin" Value="0,2,0,4"/>
    </Style>
  </UserControl.Resources>
  <Grid Margin="4">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <Border Grid.Row="0" Padding="4,3"
            Background="{DynamicResource {x:Static vs:VsBrushes.CommandBarGradientBeginKey}}"
            BorderBrush="{DynamicResource {x:Static vs:VsBrushes.PanelBorderKey}}"
            BorderThickness="0,0,0,1">
      <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
        <Button Content="New" Command="{Binding NewTodoCommand}" Margin="2" ToolTip="Create a new TODO"/>
        <Button Content="Refresh" Command="{Binding RefreshCommand}" Margin="2"/>
        <Button Content="Copy ID" Command="{Binding CopyIdCommand}" Margin="2"/>
        <Button Content="Stop" Command="{Binding StopCommand}" Margin="2"
                IsEnabled="{Binding IsStopEnabled}" ToolTip="Stop the running Copilot operation"/>
        <Rectangle Width="1" Height="20" Margin="6,0"
                   Fill="{DynamicResource {x:Static vs:VsBrushes.PanelBorderKey}}"/>
        <ComboBox MinWidth="90" Margin="2" VerticalAlignment="Center"
                  SelectedValue="{Binding FilterPriority}" SelectedValuePath="Tag">
          <ComboBox.Resources>
            <!-- Override system colors used by the default ComboBox popup template -->
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"
                             Color="{DynamicResource {x:Static vs:VsColors.WindowKey}}"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}"
                             Color="{DynamicResource {x:Static vs:VsColors.WindowTextKey}}"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                             Color="{DynamicResource {x:Static vs:VsColors.HighlightKey}}"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
                             Color="{DynamicResource {x:Static vs:VsColors.HighlightTextKey}}"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"
                             Color="{DynamicResource {x:Static vs:VsColors.ComboBoxBackgroundKey}}"/>
          </ComboBox.Resources>
          <ComboBoxItem Content="All" Tag="" IsSelected="True"/>
          <ComboBoxItem Content="High" Tag="high"/>
          <ComboBoxItem Content="Medium" Tag="medium"/>
          <ComboBoxItem Content="Low" Tag="low"/>
        </ComboBox>
        <ComboBox MinWidth="70" Margin="2" VerticalAlignment="Center"
                  ToolTip="Text filter scope"
                  SelectedValue="{Binding FilterTextScope}" SelectedValuePath="Tag">
          <ComboBox.Resources>
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"
                             Color="{DynamicResource {x:Static vs:VsColors.WindowKey}}"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}"
                             Color="{DynamicResource {x:Static vs:VsColors.WindowTextKey}}"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                             Color="{DynamicResource {x:Static vs:VsColors.HighlightKey}}"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
                             Color="{DynamicResource {x:Static vs:VsColors.HighlightTextKey}}"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"
                             Color="{DynamicResource {x:Static vs:VsColors.ComboBoxBackgroundKey}}"/>
          </ComboBox.Resources>
          <ComboBoxItem Content="TITLE" Tag="title" IsSelected="True"/>
          <ComboBoxItem Content="ID" Tag="id"/>
          <ComboBoxItem Content="ALL" Tag="all"/>
        </ComboBox>
        <TextBox MinWidth="120" Margin="2" Padding="4,2"
                 VerticalAlignment="Center" ToolTip="Filter by text"
                 Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"/>
        <Button Content="Clear filters" Command="{Binding ClearFiltersCommand}" Margin="2"/>
      </WrapPanel>
    </Border>
    <TextBlock Grid.Row="1" Margin="6,4"
               Text="{Binding StatusText}"
               Foreground="{DynamicResource {x:Static vs:VsBrushes.GrayTextKey}}"
               TextWrapping="Wrap"/>
    <ListView x:Name="TodoEntriesList" Grid.Row="2" Margin="6,2,6,4" Padding="2"
              Background="{DynamicResource {x:Static vs:VsBrushes.WindowKey}}"
              Foreground="{DynamicResource {x:Static vs:VsBrushes.WindowTextKey}}"
              BorderBrush="{DynamicResource {x:Static vs:VsBrushes.ComboBoxBorderKey}}"
              DisplayMemberPath="DisplayLine" SelectedValuePath="Item"
              ItemsSource="{Binding Source={StaticResource GroupedEntries}}"
              SelectedItem="{Binding SelectedEntry}"
              PreviewMouseRightButtonDown="OnTodoEntriesListPreviewMouseRightButtonDown">
      <ListView.InputBindings>
        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding OpenItemCommand}"/>
      </ListView.InputBindings>
      <ListView.ContextMenu>
        <ContextMenu
            DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
            Background="{DynamicResource {x:Static vs:VsBrushes.WindowKey}}"
            Foreground="{DynamicResource {x:Static vs:VsBrushes.WindowTextKey}}"
            BorderBrush="{DynamicResource {x:Static vs:VsBrushes.ComboBoxBorderKey}}"
            theming:ImageThemingUtilities.ImageBackgroundColor="{DynamicResource {x:Static vs:VsColors.WindowKey}}">
          <MenuItem Header="Open" Command="{Binding OpenItemCommand}">
            <MenuItem.Icon>
              <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.OpenFile}"/>
            </MenuItem.Icon>
          </MenuItem>
          <MenuItem Header="Copilot Status"
                    Command="{Binding CopilotStatusCommand}"
                    CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
            <MenuItem.Icon>
              <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.StatusInformation}"/>
            </MenuItem.Icon>
          </MenuItem>
          <MenuItem Header="Copilot Implement"
                    Command="{Binding CopilotImplementCommand}"
                    CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
            <MenuItem.Icon>
              <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.Run}"/>
            </MenuItem.Icon>
          </MenuItem>
          <MenuItem Header="Copilot Plan"
                    Command="{Binding CopilotPlanCommand}"
                    CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
            <MenuItem.Icon>
              <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.Checklist}"/>
            </MenuItem.Icon>
          </MenuItem>
          <Separator/>
          <MenuItem Header="Copy ID" Command="{Binding CopyIdCommand}">
            <MenuItem.Icon>
              <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.Copy}"/>
            </MenuItem.Icon>
          </MenuItem>
        </ContextMenu>
      </ListView.ContextMenu>
      <ListView.GroupStyle>
        <GroupStyle>
          <GroupStyle.HeaderTemplate>
            <DataTemplate>
              <Border Background="{DynamicResource {x:Static vs:VsBrushes.ToolWindowBackgroundKey}}"
                      BorderBrush="{DynamicResource {x:Static vs:VsBrushes.PanelBorderKey}}"
                      BorderThickness="0,0,0,1" Padding="6,4">
                <TextBlock FontWeight="Bold"
                           Text="{Binding Name}"
                           Foreground="{DynamicResource {x:Static vs:VsBrushes.ToolWindowTextKey}}"/>
              </Border>
            </DataTemplate>
          </GroupStyle.HeaderTemplate>
        </GroupStyle>
      </ListView.GroupStyle>
    </ListView>
  </Grid>
</UserControl>
