<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:McpServerManager.Core.ViewModels"
             xmlns:conv="using:McpServerManager.Core.Converters"
             xmlns:controls="using:McpServerManager.Android.Controls"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="720"
             x:Class="McpServerManager.Android.Views.PhoneTodoView"
             x:Name="TodoRoot"
             x:DataType="vm:TodoListViewModel"
             FontSize="20">

    <UserControl.Resources>
        <conv:DoneToBackgroundBrushConverter x:Key="DoneToBackgroundBrush"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="FontSize" Value="21"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="FontSize" Value="21"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="FontSize" Value="21"/>
        </Style>
        <Style Selector="ToggleButton">
            <Setter Property="FontSize" Value="21"/>
        </Style>
        <Style Selector="TextBlock">
            <Setter Property="FontSize" Value="20"/>
        </Style>
        <Style Selector="SelectableTextBlock">
            <Setter Property="FontSize" Value="20"/>
        </Style>
    </UserControl.Styles>

    <Grid ClipToBounds="True">
        <!-- List screen -->
        <Grid x:Name="ListScreen" RowDefinitions="Auto,Auto,Auto,*" IsVisible="True">
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6" Margin="6,6,6,4">
                <Button Content="↻ Refresh" Click="OnListRefreshClick" Padding="10,6"/>
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="6,0,6,4"
                    Padding="8"
                    CornerRadius="6"
                    Background="{DynamicResource SystemAltHighColor}">
                <StackPanel Spacing="6">
                    <TextBox Text="{Binding FilterText, Mode=TwoWay}" Watermark="Filter todos..."/>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{x:Static vm:TodoListViewModel.PriorityOptions}"
                                  SelectedIndex="{Binding SelectedPriorityIndex}"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{x:Static vm:TodoListViewModel.ScopeOptions}"
                                  SelectedIndex="{Binding SelectedScopeIndex}"/>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Button Grid.Column="0"
                                Content="Clear"
                                Command="{Binding ClearFiltersCommand}"
                                Padding="10,6"/>
                        <ToggleButton Grid.Column="1"
                                      Content="Include Completed"
                                      IsChecked="{Binding IncludeCompleted}"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Center"
                                      Padding="10,6"/>
                    </Grid>
                </StackPanel>
            </Border>

            <SelectableTextBlock Grid.Row="2"
                                 Text="{Binding StatusText}"
                                 Margin="10,0,10,4"
                                 FontSize="19"
                                 Foreground="{DynamicResource SubtleForeground}"
                                 TextTrimming="CharacterEllipsis"/>

            <Border Grid.Row="3" Margin="6,0,6,6" Background="{DynamicResource SystemAltHighColor}" CornerRadius="6">
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding GroupedItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:TodoListGroup">
                                <StackPanel Margin="0,0,0,6">
                                    <Border Background="{DynamicResource SystemAccentColor}"
                                            Padding="8,5" CornerRadius="4" Margin="4,4,4,2">
                                        <SelectableTextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="20" Foreground="White"/>
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:TodoListEntry">
                                                <Button Click="OnTodoRowClick"
                                                        Tag="{Binding}"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Stretch"
                                                        Padding="0"
                                                        Margin="4,0,4,2">
                                                    <Border Padding="8"
                                                            CornerRadius="4"
                                                            Background="{Binding Item, Converter={StaticResource DoneToBackgroundBrush}}">
                                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                            <StackPanel Grid.Column="0" Spacing="2">
                                                                <TextBlock Text="{Binding Item.Id}"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="20"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding Item.Title}"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="20"
                                                                           Foreground="{DynamicResource SubtleForeground}"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Right">
                                                                <TextBlock Text="{Binding Item.Priority}"
                                                                           FontSize="18"
                                                                           Foreground="{DynamicResource SubtleForeground}"
                                                                           HorizontalAlignment="Right"/>
                                                                <TextBlock Text="{Binding Item.Section}"
                                                                           FontSize="18"
                                                                           Foreground="{DynamicResource SubtleForeground}"
                                                                           HorizontalAlignment="Right"
                                                                           MaxWidth="110"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Formatted detail screen -->
        <Grid x:Name="DetailScreen" RowDefinitions="Auto,Auto,Auto,Auto,*" IsVisible="False">
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="8" Margin="6,6,6,4">
                <Button Grid.Column="0" Content="← Back" Click="OnDetailBackClick" Padding="10,6"/>
                <SelectableTextBlock Grid.Column="1"
                                     Text="{Binding EditorTitle}"
                                     FontWeight="Bold"
                                     FontSize="21"
                                     VerticalAlignment="Center"
                                     TextTrimming="CharacterEllipsis"/>
            </Grid>

            <ScrollViewer Grid.Row="1"
                          Margin="6,0,6,4"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Content="Edit" Click="OnDetailEditMarkdownClick" Padding="10,6"/>
                    <Button Content="Refresh" Click="OnDetailRefreshClick" Padding="10,6"/>
                    <ToggleButton x:Name="DetailDoneToggle"
                                  Content="Done"
                                  Click="OnDetailToggleDoneClick"
                                  Padding="10,6"/>
                    <Button Content="Copy ID" Click="OnDetailCopyIdClick" Padding="10,6"/>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="6" Margin="6,0,6,4">
                <Button Grid.Column="0"
                        Content="Plan"
                        Click="OnDetailPlanClick"
                        Padding="10,6"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="Status"
                        Click="OnDetailStatusClick"
                        Padding="10,6"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"/>
                <Button Grid.Column="2"
                        Content="Implement"
                        Click="OnDetailImplementClick"
                        Padding="10,6"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"/>
            </Grid>

            <SelectableTextBlock Grid.Row="3"
                                 Text="{Binding StatusText}"
                                 Margin="10,0,10,4"
                                 FontSize="19"
                                 Foreground="{DynamicResource SubtleForeground}"
                                 TextTrimming="CharacterEllipsis"/>

            <Border Grid.Row="4" Margin="6,0,6,6" Padding="8" Background="{DynamicResource SystemAltHighColor}" CornerRadius="6">
                <ScrollViewer>
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="DetailTitleText"
                                   FontSize="25"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="DetailSubtitleText"
                                   FontSize="19"
                                   Foreground="{DynamicResource SubtleForeground}"
                                   TextWrapping="Wrap"/>
                        <WrapPanel x:Name="DetailMetaChipsPanel"
                                   Orientation="Horizontal"
                                   HorizontalAlignment="Left"/>
                        <TextBlock x:Name="DetailEmptyText"
                                   IsVisible="False"
                                   FontSize="19"
                                   Foreground="{DynamicResource SubtleForeground}"
                                   TextWrapping="Wrap"/>
                        <StackPanel x:Name="DetailFieldCardsPanel" Spacing="8"/>
                        <StackPanel x:Name="DetailSectionCardsPanel" Spacing="8"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Markdown edit screen -->
        <Grid x:Name="EditScreen" RowDefinitions="Auto,Auto,*" IsVisible="False">
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="6" Margin="6,6,6,4">
                <Button Grid.Column="0" Content="← Back" Click="OnEditBackClick" Padding="10,6"/>
                <SelectableTextBlock Grid.Column="1"
                                     Text="{Binding EditorTitle}"
                                     FontWeight="Bold"
                                     FontSize="21"
                                     VerticalAlignment="Center"
                                     TextTrimming="CharacterEllipsis"/>
                <Button Grid.Column="2" Content="Refresh" Click="OnEditRefreshClick" Padding="10,6"/>
                <Button Grid.Column="3" Content="Save" Click="OnEditSaveClick" Padding="10,6"/>
            </Grid>

            <SelectableTextBlock Grid.Row="1"
                                 Text="{Binding StatusText}"
                                 Margin="10,0,10,4"
                                 FontSize="19"
                                 Foreground="{DynamicResource SubtleForeground}"
                                 TextTrimming="CharacterEllipsis"/>

            <Border Grid.Row="2" Margin="6,0,6,6" CornerRadius="6" Background="{DynamicResource SystemAltHighColor}">
                <controls:AndroidPlainTextEditor x:Name="Editor"
                                                 FontSize="20"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
