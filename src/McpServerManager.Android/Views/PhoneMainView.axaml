<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:McpServerManager.Core.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="using:McpServerManager.Android.Views"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
             x:Class="McpServerManager.Android.Views.PhoneMainView"
             x:DataType="vm:MainWindowViewModel"
             FontSize="20">

    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="FontSize" Value="21"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="FontSize" Value="21"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="FontSize" Value="21"/>
        </Style>
        <Style Selector="ToggleButton">
            <Setter Property="FontSize" Value="21"/>
        </Style>
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="22"/>
        </Style>
        <Style Selector="TabControl">
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="TabControl /template/ Border#PART_SelectedContentHost">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="TextBlock">
            <Setter Property="FontSize" Value="20"/>
        </Style>
        <Style Selector="SelectableTextBlock">
            <Setter Property="FontSize" Value="20"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="*,Auto" ClipToBounds="True">
        <TabControl x:Name="MainTabControl" Grid.Row="0" TabStripPlacement="Bottom" SelectedIndex="0"
                    SelectionChanged="MainTabControl_OnSelectionChanged">
            <TabItem Header="Voice">
                <views:SimplifiedVoiceView DataContext="{Binding VoiceConversationViewModel}"/>
            </TabItem>
            <TabItem Header="Todos">
                <views:PhoneTodoView DataContext="{Binding TodoViewModel}"/>
            </TabItem>
            <TabItem Header="Session Log">
                <views:PhoneSessionLogView/>
            </TabItem>
            <TabItem Header="Settings">
                <views:PhoneSettingsView DataContext="{Binding SettingsViewModel}"/>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <views:AnimatedStatusBar Grid.Row="1" IsBusy="{Binding IsBusy}" IdleBrush="{DynamicResource StatusBarBrush}">
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto,Auto,Auto" RowSpacing="4" ColumnSpacing="6">
                <ComboBox Grid.Row="0"
                          Grid.Column="0"
                          Grid.ColumnSpan="3"
                          IsEnabled="{Binding !VoiceConversationViewModel.IsSessionActive}"
                          ItemsSource="{Binding WorkspaceConnections}"
                          SelectedItem="{Binding SelectedWorkspaceConnection, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:CompileBindings="False">
                            <SelectableTextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Row="0"
                        Grid.Column="3"
                        Content="Logout"
                        Command="{Binding LogoutCommand}"
                        VerticalAlignment="Center"
                        FontSize="19"
                        Padding="8,4"/>
                <SelectableTextBlock x:Name="StatusMessageText"
                                     Grid.Row="1" Grid.Column="0"
                                     Grid.ColumnSpan="2"
                                     Text="{Binding StatusViewModel.Status}"
                                     FontWeight="Bold"
                                     FontSize="19"
                                     VerticalAlignment="Center"
                                     TextTrimming="CharacterEllipsis"
                                     PointerPressed="StatusMessageText_OnPointerPressed"/>
                <Ellipse Grid.Row="1"
                         Grid.Column="2"
                         Width="10"
                         Height="10"
                         Fill="{Binding WorkspaceHealthIndicatorBrush}"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"
                         ToolTip.Tip="{Binding WorkspaceHealthIndicatorTooltip}"/>
                <SelectableTextBlock Grid.Row="1" Grid.Column="3" Text="{Binding AppVersionDisplay}" FontSize="18" VerticalAlignment="Center" Foreground="{DynamicResource SubtleForeground}"/>
            </Grid>
        </views:AnimatedStatusBar>

        <!-- Modal-style status dialog for full error text -->
        <Border x:Name="StatusDialogOverlay"
                Grid.RowSpan="2"
                IsVisible="False"
                Background="#80000000"
                PointerPressed="StatusDialogOverlay_OnPointerPressed">
            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="12" MaxWidth="520">
                <Border Background="{DynamicResource ThemeBackgroundBrush}"
                        BorderBrush="{DynamicResource ItemBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        PointerPressed="StatusDialogContent_OnPointerPressed">
                    <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="8">
                        <TextBlock Grid.Row="0" Text="Status Message" FontWeight="Bold" FontSize="22"/>
                        <TextBlock Grid.Row="1"
                                   Text="Full text from the status bar"
                                   Foreground="{DynamicResource SubtleForeground}"
                                   FontSize="18"/>
                        <Border Grid.Row="2"
                                MinWidth="280"
                                MaxWidth="480"
                                MaxHeight="360"
                                Padding="8"
                                Background="Transparent"
                                BorderBrush="{DynamicResource ItemBorderBrush}"
                                BorderThickness="1">
                            <ScrollViewer>
                                <SelectableTextBlock x:Name="StatusDialogText"
                                                     TextWrapping="Wrap"
                                                     FontSize="20"/>
                            </ScrollViewer>
                        </Border>
                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                            <Button Content="Close" Click="CloseStatusDialog_OnClick"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
