<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:McpServerManager.Core.ViewModels"
             xmlns:conv="using:McpServerManager.Core.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="using:McpServerManager.Android.Views"
             mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
             x:Class="McpServerManager.Android.Views.TabletMainView"
             x:DataType="vm:MainWindowViewModel">

    <Grid RowDefinitions="*,Auto" Background="{DynamicResource ThemeBackgroundBrush}">
        <Grid x:Name="ShellGrid" Grid.Row="0" Margin="6,6,6,4" RowDefinitions="*" ColumnDefinitions="*">
            <Border x:Name="MainTabsBorder" Classes="phone-outline-card">
                <TabControl x:Name="MainTabControl"
                            Classes="shell-tabs"
                            SelectionChanged="OnMainTabSelectionChanged">
                <TabItem Header="Request Tracker" Classes="shell-tab">
                    <views:McpServerManagerTabletView/>
                </TabItem>
                <TabItem Header="Todos" Classes="shell-tab">
                    <views:TodoListView DataContext="{Binding TodoViewModel}"/>
                </TabItem>
                <TabItem Header="Workspaces" Classes="shell-tab">
                    <views:WorkspaceView DataContext="{Binding WorkspaceViewModel}"/>
                </TabItem>
                <TabItem Header="Logs" Classes="shell-tab">
                    <views:LogView DataContext="{Binding LogViewModel}"/>
                </TabItem>
            </TabControl>
            </Border>

            <GridSplitter x:Name="VoiceFlyoutSplitter"
                          IsVisible="False"
                          Classes="phone-splitter"
                          ResizeDirection="Columns"
                          PointerReleased="OnVoiceFlyoutSplitterPointerReleased"
                          PointerCaptureLost="OnVoiceFlyoutSplitterPointerCaptureLost"/>

            <Border x:Name="VoiceFlyoutBorder"
                    IsVisible="False"
                    Classes="phone-outline-card"
                    MinWidth="320"
                    MinHeight="240">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Classes="phone-toolbar-card" Padding="10,8">
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Voice Chat" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="Pinned right in landscape, docked bottom in portrait."
                                           Foreground="{DynamicResource SubtleForeground}"
                                           FontSize="12"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          x:Name="VoicePinToggleButton"
                                          Content="Pinned"
                                          IsChecked="True"
                                          Checked="OnVoicePinToggleChanged"
                                          Unchecked="OnVoicePinToggleChanged"
                                          Padding="10,4"/>
                            <Button Grid.Column="2"
                                    x:Name="VoiceFlyoutCloseButton"
                                    Content="Close"
                                    Click="OnVoiceFlyoutCloseClick"
                                    Padding="10,4"/>
                        </Grid>
                    </Border>

                    <views:VoiceConversationView x:Name="VoiceFlyoutView"
                                                 Grid.Row="1"
                                                 DataContext="{Binding VoiceConversationViewModel}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <views:AnimatedStatusBar Grid.Row="1" Margin="6,0,6,6" IsBusy="{Binding IsBusy}" IdleBrush="{DynamicResource StatusBarBrush}">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                <ScrollViewer Grid.Column="0"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <SelectableTextBlock x:Name="StatusMessageText"
                                         Text="{Binding StatusViewModel.Status}"
                                         FontWeight="Bold"
                                         VerticalAlignment="Center"
                                         PointerPressed="StatusMessageText_OnPointerPressed"
                                         PointerReleased="StatusMessageText_OnPointerReleased"
                                         PointerCaptureLost="StatusMessageText_OnPointerCaptureLost"/>
                </ScrollViewer>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                            IsVisible="{Binding StatusViewModel.IsCopilotRunning}">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                             Fill="{Binding StatusViewModel.CopilotHeartbeatState, Converter={x:Static conv:HeartbeatStateToBrushConverter.Instance}}"/>
                    <TextBlock Text="{Binding StatusViewModel.CopilotActivityText}" FontSize="11"
                               VerticalAlignment="Center" Opacity="0.8"/>
                </StackPanel>
                <ComboBox Grid.Column="2"
                          MinWidth="220"
                          MaxWidth="340"
                          ItemsSource="{Binding WorkspaceConnections}"
                          SelectedItem="{Binding SelectedWorkspaceConnection, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:CompileBindings="False">
                            <SelectableTextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Ellipse Grid.Column="3"
                         Width="12"
                         Height="12"
                         Fill="{Binding WorkspaceHealthIndicatorBrush}"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"
                         ToolTip.Tip="{Binding WorkspaceHealthIndicatorTooltip}"/>
                <SelectableTextBlock Grid.Column="4"
                                     Classes="subtle-text"
                                     Text="{Binding AppVersionDisplay}"
                                     VerticalAlignment="Center"/>
                <ToggleButton Grid.Column="5"
                              x:Name="VoiceFlyoutToggleButton"
                              Content="Voice"
                              Checked="OnVoiceFlyoutToggleChanged"
                              Unchecked="OnVoiceFlyoutToggleChanged"
                              VerticalAlignment="Center"
                              Padding="10,4"/>
                <Button Grid.Column="6"
                        Content="Logout"
                        Command="{Binding LogoutCommand}"
                        VerticalAlignment="Center"
                        Padding="8,4"/>
            </Grid>
        </views:AnimatedStatusBar>

        <!-- Modal-style status dialog for full error text -->
        <Border x:Name="StatusDialogOverlay"
                Grid.RowSpan="2"
                IsVisible="False"
                Background="#80000000"
                PointerPressed="StatusDialogOverlay_OnPointerPressed">
            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20" MaxWidth="700">
                <Border Background="{DynamicResource ThemeBackgroundBrush}"
                        Classes="phone-outline-card"
                        Padding="14"
                        MinWidth="420"
                        PointerPressed="StatusDialogContent_OnPointerPressed">
                    <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="8">
                        <TextBlock Grid.Row="0" Text="Status Message" FontWeight="Bold" FontSize="17"/>
                        <TextBlock Grid.Row="1"
                                   Text="Full text from the status bar"
                                   Foreground="{DynamicResource SubtleForeground}"
                                   FontSize="12"/>
                        <Border Grid.Row="2"
                                MaxHeight="420"
                                Padding="8"
                                Background="Transparent"
                                BorderBrush="{DynamicResource ItemBorderBrush}"
                                BorderThickness="1">
                            <ScrollViewer>
                                <SelectableTextBlock x:Name="StatusDialogText"
                                                     TextWrapping="Wrap"
                                                     FontSize="14"/>
                            </ScrollViewer>
                        </Border>
                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                            <Button Content="Close" Click="CloseStatusDialog_OnClick"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>

</UserControl>
