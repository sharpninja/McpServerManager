<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:McpServerManager.Core.ViewModels"
             xmlns:models="using:McpServerManager.UI.Core.Models"
             mc:Ignorable="d"
             x:Class="McpServerManager.Android.Views.VoiceConversationView"
             x:DataType="vm:VoiceConversationViewModel"
             d:DesignWidth="900"
             d:DesignHeight="700">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="8" Margin="8">

        <!-- Row 0: Session controls -->
        <Border Classes="phone-outline-card" Padding="10">
            <StackPanel Spacing="6">
                <StackPanel Spacing="2">
                    <SelectableTextBlock Text="{Binding SessionId}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <SelectableTextBlock Text="{Binding StatusText}" Classes="subtle-text" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                    <Button Content="Start Session" Command="{Binding CreateSessionCommand}"/>
                    <Button Content="Refresh" Command="{Binding RefreshStatusCommand}"/>
                    <Button Content="End Session" Command="{Binding EndSessionCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Row 1: Language + Last Turn -->
        <Border Classes="phone-outline-card" Padding="10">
            <Grid ColumnDefinitions="Auto,100,Auto,*,Auto" ColumnSpacing="8">
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Language"/>
                <TextBox Grid.Column="1" Text="{Binding Language, Mode=TwoWay}" PlaceholderText="en-US"/>
                <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Last Turn"/>
                <SelectableTextBlock Grid.Column="3"
                                     Text="{Binding LastTurnId}"
                                     VerticalAlignment="Center"
                                     TextTrimming="CharacterEllipsis"/>
                <SelectableTextBlock Grid.Column="4"
                                     VerticalAlignment="Center"
                                     Text="{Binding LastLatencyMs, StringFormat='{}{0} ms'}"/>
            </Grid>
        </Border>

        <!-- Row 2: Manual Transcript Input -->
        <Border Classes="phone-outline-card" Padding="10">
            <StackPanel Spacing="8">
                <TextBlock Text="Manual Transcript Input" FontWeight="SemiBold"/>

                <!-- Wake Phrase: label + combo on one line, checkbox below -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Wake Phrase"/>
                    <ComboBox Grid.Column="1"
                              x:Name="WakePhraseComboBox"
                              HorizontalAlignment="Stretch"
                              SelectionChanged="OnWakePhraseSelectionChanged"/>
                </Grid>
                <CheckBox x:Name="AutoListenOnWakeCheckBox"
                          Content="Auto listen + send on wake"
                          IsCheckedChanged="OnAutoListenOnWakeCheckedChanged"/>

                <!-- Text input -->
                <TextBox MinHeight="60"
                         MaxHeight="120"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Text="{Binding TranscriptInput, Mode=TwoWay}"
                         PlaceholderText="Type transcript text here..."/>

                <!-- Action buttons: 4-column grid -->
                <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="4" RowSpacing="4">
                    <Grid.Styles>
                        <Style Selector="Button">
                            <Setter Property="MinHeight" Value="36"/>
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                    </Grid.Styles>
                    <Button Grid.Row="0" Grid.Column="0" Content="Listen" Click="OnListenFillInputClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="4,6"/>
                    <Button Grid.Row="0" Grid.Column="1" Content="Lstn+Send" Click="OnListenAndSendClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="4,6"/>
                    <Button Grid.Row="0" Grid.Column="2" Content="Send Turn" Command="{Binding SubmitTurnCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="4,6"/>
                    <Button Grid.Row="1" Grid.Column="0" Content="Wake Start" Click="OnWakeStartClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="4,6"/>
                    <Button Grid.Row="1" Grid.Column="1" Content="Wake Stop" Click="OnWakeStopClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="4,6"/>
                    <Button Grid.Row="1" Grid.Column="2" Content="Sim Wake" Click="OnSimWakeClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="4,6"/>
                    <Button Grid.Row="2" Grid.Column="0" Content="Interrupt" Command="{Binding InterruptCommand}" Click="OnInterruptClicked" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="4,6"/>
                    <Button Grid.Row="2" Grid.Column="1" Content="ESC" Command="{Binding SendEscapeCommand}" Click="OnInterruptClicked" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="4,6"/>
                    <Button Grid.Row="2" Grid.Column="2" Content="Clear" Command="{Binding ClearTurnInputCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="4,6"/>
                    <Button Grid.Row="2" Grid.Column="3" Content="Refresh" Command="{Binding RefreshTranscriptCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="4,6"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Row 3: Assistant response -->
        <Border Classes="phone-outline-card" Padding="10">
            <StackPanel Spacing="8">
                <TextBlock Text="Assistant Display Text" FontWeight="SemiBold"/>
                <Border BorderBrush="{DynamicResource ItemBorderBrush}" BorderThickness="1" Padding="8" MinHeight="48">
                    <ScrollViewer MaxHeight="100">
                        <SelectableTextBlock Text="{Binding AssistantDisplayText}" TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>

                <TextBlock Text="Assistant Speak Text" FontWeight="SemiBold"/>
                <Border BorderBrush="{DynamicResource ItemBorderBrush}" BorderThickness="1" Padding="8" MinHeight="48">
                    <ScrollViewer MaxHeight="100">
                        <SelectableTextBlock Text="{Binding AssistantSpeakText}" TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Speak Reply" Click="OnSpeakReplyClick"/>
                    <Button Content="Stop Audio" Click="OnStopAudioClick"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Row 4: Transcript History -->
        <Border Classes="phone-outline-card" Padding="10">
            <StackPanel Spacing="8">
                <TextBlock Text="Transcript History" FontWeight="SemiBold"/>
                <ListBox ItemsSource="{Binding TranscriptItems}" SelectionMode="Single" MaxHeight="250">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:McpVoiceTranscriptEntry">
                            <Border Padding="6" Margin="0,0,0,6" BorderBrush="{DynamicResource ItemBorderBrush}" BorderThickness="1">
                                <Grid RowDefinitions="Auto,Auto" RowSpacing="4">
                                    <SelectableTextBlock Grid.Row="0"
                                                         FontWeight="SemiBold"
                                                         Text="{Binding Role, StringFormat='{}{0}'}"/>
                                    <SelectableTextBlock Grid.Row="0"
                                                         HorizontalAlignment="Right"
                                                         Classes="subtle-text"
                                                         Text="{Binding TimestampUtc}"
                                                         TextTrimming="CharacterEllipsis"/>
                                    <SelectableTextBlock Grid.Row="1"
                                                         TextWrapping="Wrap"
                                                         Text="{Binding Text}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Row 5: Last Tool Calls -->
        <Border Classes="phone-outline-card" Padding="10">
            <StackPanel Spacing="8">
                <TextBlock Text="Last Tool Calls" FontWeight="SemiBold"/>
                <ListBox ItemsSource="{Binding LastToolCalls}" MaxHeight="200">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:McpVoiceToolCallRecord">
                            <Border Padding="6" Margin="0,0,0,6" BorderBrush="{DynamicResource ItemBorderBrush}" BorderThickness="1">
                                <StackPanel Spacing="3">
                                    <SelectableTextBlock FontWeight="SemiBold"
                                                         Text="{Binding ToolName, StringFormat='{}{0}'}"/>
                                    <SelectableTextBlock Classes="subtle-text"
                                                         Text="{Binding Status, StringFormat='Status: {0}'}"/>
                                    <SelectableTextBlock Classes="subtle-text"
                                                         Text="{Binding ResultSummary}"
                                                         TextWrapping="Wrap"/>
                                    <SelectableTextBlock Foreground="IndianRed"
                                                         Text="{Binding Error}"
                                                         TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Row 6: Busy indicator -->
        <Border Classes="phone-outline-card" Padding="8" IsVisible="{Binding IsBusy}">
            <SelectableTextBlock Text="Working..." FontWeight="SemiBold"/>
        </Border>

    </StackPanel>
    </ScrollViewer>
</UserControl>
