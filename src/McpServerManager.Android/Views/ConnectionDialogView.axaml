<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:McpServerManager.Core.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="600"
             x:Class="McpServerManager.Android.Views.ConnectionDialogView"
             x:DataType="vm:ConnectionViewModel"
             FontSize="17">

    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="FontSize" Value="18"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="FontSize" Value="18"/>
        </Style>
        <Style Selector="SelectableTextBlock">
            <Setter Property="FontSize" Value="17"/>
        </Style>
    </UserControl.Styles>

    <Border x:Name="RootCard"
            Classes="phone-card"
            VerticalAlignment="Center"
            HorizontalAlignment="Stretch"
            Margin="12"
            Padding="16">
    <StackPanel VerticalAlignment="Center" Spacing="12">
        <SelectableTextBlock Text="Connect to Server"
                             FontSize="28"
                             FontWeight="SemiBold"/>

        <SelectableTextBlock Text="Host" FontSize="18"/>
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
            <TextBox x:Name="HostTextBox"
                     Grid.Column="0"
                     Text="{Binding Host, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                     PlaceholderText="e.g. 10.0.2.2"
                     IsEnabled="{Binding !IsConnecting}"/>
            <Button Grid.Column="1"
                    Command="{Binding ScanQrCodeCommand}"
                    IsVisible="{Binding CanScanQrCode}"
                    IsEnabled="{Binding !IsConnecting}"
                    ToolTip.Tip="Scan QR code for hostname"
                    Padding="8"
                    VerticalAlignment="Stretch">
                <!-- QR Code icon -->
                <PathIcon Data="M3,11H5V13H3V11M11,5H13V9H11V5M9,11H13V15H11V13H9V11M15,11H17V13H19V11H21V13H19V15H21V19H19V21H17V19H13V21H11V17H15V19H17V17H19V15H17V13H15V11M17,3H21V7H19V5H17V3M3,3H7V5H5V7H3V3M3,17H5V19H7V21H3V17M19,19V21H21V19H19M1,1H9V9H1V1M3,3V7H7V3H3M15,1H23V9H15V1M17,3V7H21V3H17M1,15H9V23H1V15M3,17V21H7V17H3Z"/>
            </Button>
        </Grid>

        <SelectableTextBlock Text="Port" FontSize="18"/>
        <TextBox x:Name="PortTextBox"
                 Text="{Binding Port, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                 PlaceholderText="e.g. 7147"
                 IsEnabled="{Binding !IsConnecting}"/>

        <SelectableTextBlock Text="{Binding ErrorMessage}"
                   Foreground="Red" TextWrapping="Wrap"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

        <Border x:Name="OidcPanel"
                Classes="phone-section-card"
                Padding="12"
                IsVisible="{Binding IsOidcSignInRequired}">
            <StackPanel Spacing="8">
                <SelectableTextBlock Text="Sign In Required"
                                     FontSize="18"
                                     FontWeight="SemiBold"/>

                <SelectableTextBlock Text="Use the code below to authorize this device."
                                     Foreground="{DynamicResource SubtleForeground}"
                                     TextWrapping="Wrap"/>

                <SelectableTextBlock Text="User Code"
                                     FontSize="16"
                                     IsVisible="{Binding OidcUserCode, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <TextBox Text="{Binding OidcUserCode}"
                         IsReadOnly="True"
                         IsVisible="{Binding OidcUserCode, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <SelectableTextBlock Text="Verification URL"
                                     FontSize="16"
                                     IsVisible="{Binding OidcVerificationUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <SelectableTextBlock Text="{Binding OidcVerificationUrl}"
                                     TextWrapping="Wrap"
                                     IsVisible="{Binding OidcVerificationUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <Button x:Name="OpenSignInPageButton"
                        Content="Open Sign-In Page"
                        Command="{Binding OpenOidcVerificationUrlCommand}"
                        IsVisible="{Binding OidcCanOpenBrowser}"
                        IsEnabled="{Binding OidcCanOpenBrowser}"/>

                <SelectableTextBlock Text="{Binding OidcStatusMessage}"
                                     Foreground="{DynamicResource SubtleForeground}"
                                     TextWrapping="Wrap"
                                     IsVisible="{Binding OidcStatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            </StackPanel>
        </Border>

        <Button x:Name="ConnectButton"
                Content="Connect"
                Command="{Binding ConnectCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                IsEnabled="{Binding !IsConnecting}"
                Margin="0,8,0,0"/>

        <Button x:Name="CancelButton"
                Content="Cancel"
                Command="{Binding CancelConnectCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                IsVisible="{Binding IsConnecting}"
                Margin="0,4,0,0"/>

        <Button x:Name="LogoutRetryButton"
                Content="Logout &amp; Retry"
                Command="{Binding LogoutAndRetryCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                IsEnabled="{Binding !IsConnecting}"
                IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Margin="0,4,0,0"/>

        <Button x:Name="LogoutButton"
                Content="Logout"
                Command="{Binding LogoutCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                IsEnabled="{Binding !IsConnecting}"
                IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Margin="0,4,0,0"/>

        <SelectableTextBlock Text="Connecting..."
                             Foreground="{DynamicResource SubtleForeground}"
                             HorizontalAlignment="Center"
                             IsVisible="{Binding IsConnecting}"/>
    </StackPanel>
    </Border>
</UserControl>
