<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:McpServerManager.Core.ViewModels"
             xmlns:svc="using:McpServerManager.Core.Services"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="McpServerManager.Android.Views.LogView"
             x:Name="LogRoot"
             x:DataType="vm:LogViewModel">

  <Grid RowDefinitions="Auto,Auto,*">

    <!-- Toolbar -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4" Margin="4">
      <ComboBox ItemsSource="{Binding LevelFilterOptions}" SelectedItem="{Binding SelectedLevelFilter}"
                MinWidth="120" Padding="8,4"/>
      <ToggleButton IsChecked="{Binding IsPaused}" Content="{Binding PauseButtonText}" Padding="8,4"/>
      <Button Content="⎘ Copy" Command="{Binding CopySelectedCommand}" Padding="8,4"/>
      <Button Content="⎘ Copy All" Command="{Binding CopyAllCommand}" Padding="8,4"/>
      <Button Content="✕ Clear" Command="{Binding ClearLogCommand}" Padding="8,4"/>
    </StackPanel>

    <!-- Status -->
    <SelectableTextBlock Grid.Row="1" Text="{Binding StatusText}" Margin="8,0,8,4"
               FontSize="12" Foreground="Gray"/>

    <!-- Log list (long-press for context menu on Android) -->
    <ListBox Grid.Row="2" x:Name="LogListBox"
             ItemsSource="{Binding LogEntries}"
             SelectedItem="{Binding SelectedEntry}"
             SelectionMode="Single"
             FontFamily="Cascadia Code,Consolas,Menlo,monospace"
             FontSize="14">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="svc:LogEntry">
          <Border Margin="2" Padding="4" Background="Transparent">
            <TextBlock Text="{Binding Display}" TextWrapping="NoWrap"/>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
      <ListBox.ContextMenu>
        <ContextMenu x:CompileBindings="False">
          <MenuItem Header="Copy"
                    Command="{Binding DataContext.CopySelectedCommand, ElementName=LogRoot}"/>
          <MenuItem Header="Copy All"
                    Command="{Binding DataContext.CopyAllCommand, ElementName=LogRoot}"/>
          <Separator/>
          <MenuItem Header="Clear"
                    Command="{Binding DataContext.ClearLogCommand, ElementName=LogRoot}"/>
        </ContextMenu>
      </ListBox.ContextMenu>
    </ListBox>

  </Grid>
</UserControl>
