<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RequestTracker.Core.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:RequestTracker.Core.Models"
             xmlns:jsonModels="using:RequestTracker.Core.Models.Json"
             xmlns:conv="using:RequestTracker.Core.Converters"
             xmlns:beh="using:RequestTracker.Core.Behaviors"
             mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
             x:Class="RequestTracker.Android.Views.TabletMainView"
             x:Name="Root"
             x:DataType="vm:MainWindowViewModel">

    <UserControl.Resources>
        <conv:PathToWslConverter x:Key="PathToWsl"/>
        <conv:EqualityToBrushConverter x:Key="EqualityToBrush"/>
        <conv:EmptyStringToAllConverter x:Key="EmptyStringToAll"/>
        <conv:FileNodeToArchiveVisibleConverter x:Key="FileNodeToArchiveVisible"/>
    </UserControl.Resources>

    <Grid x:Name="MainGrid" ColumnDefinitions="225, 4, *" RowDefinitions="*, Auto" ClipToBounds="True">
        <!-- Tree View -->
        <TreeView Grid.Column="0" Grid.Row="0"
                  ItemsSource="{Binding Nodes}" SelectedItem="{Binding SelectedNode}"
                  VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <TreeView.ItemTemplate>
                <TreeDataTemplate ItemsSource="{Binding Children}" DataType="models:FileNode">
                    <TextBlock Text="{Binding Name}"/>
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
            <TreeView.ItemContainerTheme>
                <ControlTheme TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}" x:DataType="models:FileNode">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    <Setter Property="ContextMenu">
                        <Setter.Value>
                            <ContextMenu x:CompileBindings="False">
                                <MenuItem Header="Open"
                                          Command="{Binding DataContext.OpenTreeItemCommand, ElementName=Root}"
                                          CommandParameter="{Binding}"/>
                                <MenuItem Header="Archive"
                                          Command="{Binding DataContext.ArchiveTreeItemCommand, ElementName=Root}"
                                          CommandParameter="{Binding}"
                                          IsVisible="{Binding Converter={StaticResource FileNodeToArchiveVisible}}"/>
                            </ContextMenu>
                        </Setter.Value>
                    </Setter>
                </ControlTheme>
            </TreeView.ItemContainerTheme>
        </TreeView>

        <!-- Column Splitter -->
        <GridSplitter Grid.Column="1" Grid.Row="0" ResizeDirection="Columns" Background="LightGray"/>

        <!-- Viewer Panel (no chat button for Android) -->
        <Grid Grid.Column="2" Grid.Row="0" RowDefinitions="Auto, *" ClipToBounds="True">
             <!-- Navigation Toolbar -->
             <Grid Grid.Row="0" ColumnDefinitions="Auto, Auto, Auto, *" Margin="5">
                <Button Grid.Column="0" Command="{Binding NavigateBackCommand}" Margin="0,0,5,0" Width="30" ToolTip.Tip="Back">
                    <PathIcon Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" Width="10" Height="10"/>
                </Button>
                <Button Grid.Column="1" Command="{Binding NavigateForwardCommand}" Margin="0,0,5,0" Width="30" ToolTip.Tip="Forward">
                    <PathIcon Data="M4,11V13H16L10.5,18.5L11.92,19.92L19.84,12L11.92,4.08L10.5,5.5L16,11H4Z" Width="10" Height="10"/>
                </Button>
                <Button Grid.Column="2" Command="{Binding RefreshCommand}" Margin="0,0,5,0" Width="30" ToolTip.Tip="Refresh">
                    <PathIcon Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" Width="10" Height="10"/>
                </Button>
                <TextBox Grid.Column="3" Text="{Binding SelectedNodePathDisplay, Mode=OneWay}" IsReadOnly="True" VerticalContentAlignment="Center"/>
             </Grid>

             <!-- JSON Tree View -->
             <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Margin="5" IsVisible="{Binding IsJsonVisible}"
                     VerticalAlignment="Stretch" HorizontalAlignment="Stretch" MinHeight="320">
                <Grid RowDefinitions="Auto, Auto, 200, 4, *"
                      VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                    <!-- Summary -->
                    <Border Grid.Row="0" Padding="8" Margin="0,0,0,4">
                        <ItemsControl ItemsSource="{Binding JsonLogSummary.SummaryLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="16" Margin="0,1"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                    <!-- Search -->
                    <Grid Grid.Row="1" ColumnDefinitions="Auto, *" Margin="0,0,0,4">
                        <TextBlock Grid.Column="0" Text="Search:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1" Text="{Binding SearchQuery}" Watermark="Search..."/>
                    </Grid>
                    <!-- Search results -->
                    <Border Grid.Row="2" MinHeight="80" BorderBrush="#ddd" BorderThickness="0,0,0,1" Padding="4" Margin="0,0,0,4">
                        <Grid RowDefinitions="Auto, Auto, *">
                            <TextBlock Grid.Row="0" Text="Search index (double-tap to open)" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,4"/>
                            <Border Grid.Row="1" BorderBrush="#C0C0C0" BorderThickness="0,0,0,1">
                                <Grid ColumnDefinitions="3*,4*,2*,2*" Margin="4,2">
                                    <TextBlock Grid.Column="0" Text="Request ID" FontWeight="SemiBold" FontSize="15" FontFamily="Consolas, Monospace"/>
                                    <TextBlock Grid.Column="1" Text="Display" FontWeight="SemiBold" FontSize="15" FontFamily="Consolas, Monospace"/>
                                    <TextBlock Grid.Column="2" Text="Model" FontWeight="SemiBold" FontSize="15" FontFamily="Consolas, Monospace"/>
                                    <TextBlock Grid.Column="3" Text="Timestamp" FontWeight="SemiBold" FontSize="15" FontFamily="Consolas, Monospace"/>
                                </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding FilteredSearchEntries}" x:CompileBindings="False">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Spacing="0"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="jsonModels:SearchableEntry">
                                            <Border BorderBrush="#C0C0C0" BorderThickness="0,0,0,1"
                                                    beh:TappedBehavior.Command="{Binding DataContext.SearchRowDoubleTappedCommand, ElementName=Root}"
                                                    beh:TappedBehavior.CommandParameter="{Binding}">
                                                <Border.Background>
                                                    <MultiBinding Converter="{StaticResource EqualityToBrush}">
                                                        <Binding Path="."/>
                                                        <Binding Path="DataContext.SelectedSearchEntry" ElementName="Root"/>
                                                    </MultiBinding>
                                                </Border.Background>
                                                <Grid ColumnDefinitions="3*,4*,2*,2*" Margin="4,2">
                                                    <SelectableTextBlock Grid.Column="0" Text="{Binding RequestId}" FontFamily="Consolas, Monospace" FontSize="15" TextTrimming="CharacterEllipsis"/>
                                                    <SelectableTextBlock Grid.Column="1" Text="{Binding DisplayText}" FontFamily="Consolas, Monospace" FontSize="15" TextTrimming="CharacterEllipsis"/>
                                                    <SelectableTextBlock Grid.Column="2" Text="{Binding Model}" FontFamily="Consolas, Monospace" FontSize="15" TextTrimming="CharacterEllipsis"/>
                                                    <SelectableTextBlock Grid.Column="3" Text="{Binding TimestampDisplay}" FontFamily="Consolas, Monospace" FontSize="15" TextTrimming="CharacterEllipsis"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    <GridSplitter Grid.Row="3" ResizeDirection="Rows" Background="LightGray" Height="4"/>
                    <!-- JSON Tree -->
                    <Border Grid.Row="4" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" MinHeight="180">
                        <TreeView ItemsSource="{Binding JsonTree}" SelectedItem="{Binding SelectedJsonNode}"
                                  VerticalAlignment="Stretch" HorizontalAlignment="Stretch" MinHeight="180">
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate ItemsSource="{Binding Children}" DataType="jsonModels:JsonTreeNode">
                                    <StackPanel Orientation="Horizontal" Spacing="5" Background="Transparent" x:CompileBindings="False"
                                                beh:DoubleTappedBehavior.Command="{Binding DataContext.JsonNodeDoubleTappedCommand, ElementName=Root}"
                                                beh:DoubleTappedBehavior.CommandParameter="{Binding}">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#007acc"/>
                                        <TextBlock Text=":" Foreground="Gray"/>
                                        <TextBlock Text="{Binding Value}" Foreground="#ce9178"/>
                                        <TextBlock Text="{Binding Type}" Foreground="Gray" FontStyle="Italic" FontSize="14" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    </StackPanel>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                            <TreeView.ItemContainerTheme>
                                <ControlTheme TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}" x:DataType="jsonModels:JsonTreeNode">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                </ControlTheme>
                            </TreeView.ItemContainerTheme>
                        </TreeView>
                    </Border>
                </Grid>
             </Border>

             <!-- Markdown View -->
             <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Margin="5" IsVisible="{Binding IsMarkdownVisible}">
                <Grid RowDefinitions="Auto, *">
                    <TextBlock Text="Loading…" IsVisible="{Binding ShowMarkdownLoadingPlaceholder}"
                               VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray" Margin="12"/>
                    <Border Grid.Row="1" IsVisible="{Binding IsPreviewOpenedInBrowser}" Padding="0">
                        <Grid RowDefinitions="Auto, *">
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="8,6">
                                <Button Content="Show raw text" Command="{Binding ToggleShowRawMarkdownCommand}"/>
                                <Button Content="Archive" Command="{Binding ArchiveCommand}"/>
                            </StackPanel>
                            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <TextBox Margin="12" IsReadOnly="True" Text="{Binding CurrentPreviewMarkdownText}" TextWrapping="Wrap" Background="Transparent" BorderThickness="0"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
             </Border>

             <!-- Request Details View -->
             <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Margin="5" IsVisible="{Binding IsRequestDetailsVisible}">
                <Grid RowDefinitions="Auto, *">
                    <Grid Grid.Row="0" ColumnDefinitions="Auto, Auto, Auto, *" Margin="5" VerticalAlignment="Center">
                        <Button Grid.Column="0" Content="← Back" Command="{Binding CloseRequestDetailsCommand}" Margin="0,0,10,0"/>
                        <Button Grid.Column="1" Content="← Prev" Command="{Binding NavigateToPreviousRequestCommand}" Margin="0,0,10,0"/>
                        <Button Grid.Column="2" Content="Next →" Command="{Binding NavigateToNextRequestCommand}" Margin="0,0,10,0"/>
                    </Grid>
                    <ContentControl Grid.Row="1" Content="{Binding SelectedUnifiedRequest}"/>
                </Grid>
             </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Padding="8,6">
            <Grid ColumnDefinitions="*,Auto">
                <SelectableTextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding AppVersionDisplay}" VerticalAlignment="Center" Foreground="Gray"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
