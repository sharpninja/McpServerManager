<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:RequestTracker.Core.Models.Json;assembly=RequestTracker.Core"
             xmlns:conv="clr-namespace:RequestTracker.Core.Converters;assembly=RequestTracker.Core"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
             x:Class="RequestTracker.Android.Views.RequestDetailsView"
             x:DataType="models:UnifiedRequestEntry">

  <UserControl.Resources>
      <conv:ObjectToJsonConverter x:Key="ObjectToJson"/>
      <conv:CountToVisibilityConverter x:Key="CountToVisibility"/>
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="Expander">
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0,2"/>
      <Setter Property="IsExpanded" Value="True"/>
    </Style>
    <Style Selector="Expander /template/ Border#ExpanderContent">
      <Setter Property="Padding" Value="4"/>
    </Style>
  </UserControl.Styles>

  <ScrollViewer>
    <StackPanel Spacing="2" Margin="8">
      <!-- Header -->
      <SelectableTextBlock Text="{Binding QueryTitle}" FontSize="21" FontWeight="Bold" TextWrapping="Wrap"/>
      <SelectableTextBlock Text="{Binding RequestId}" FontSize="15" Foreground="{DynamicResource SubtleForeground}" TextTrimming="CharacterEllipsis"/>
      <SelectableTextBlock Text="{Binding TimestampLocalDisplay}" FontSize="15" Foreground="{DynamicResource SubtleForeground}"/>

      <!-- Metadata Badges -->
      <WrapPanel Orientation="Horizontal">
        <WrapPanel.Styles>
          <Style Selector="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="{DynamicResource BadgeBrush}"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="0,0,4,4"/>
          </Style>
          <Style Selector="TextBlock">
            <Setter Property="FontSize" Value="13"/>
          </Style>
        </WrapPanel.Styles>
        <Border><SelectableTextBlock Text="{Binding Model}"/></Border>
        <Border IsVisible="{Binding ModelProvider, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <SelectableTextBlock Text="{Binding ModelProvider}"/>
        </Border>
        <Border IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <SelectableTextBlock Text="{Binding Status}"/>
        </Border>
        <Border><SelectableTextBlock Text="{Binding TokenCount, StringFormat='Tokens: {0}'}"/></Border>
        <Border IsVisible="{Binding IsPremium}"><SelectableTextBlock Text="Premium" Foreground="DarkGoldenrod"/></Border>
      </WrapPanel>

      <Border Height="1" Background="{DynamicResource DividerBrush}"/>

      <!-- Query -->
      <Expander Header="Query" IsExpanded="True" HorizontalAlignment="Stretch">
        <Border Background="{DynamicResource ContentBgBrush}" Padding="2" CornerRadius="4">
          <SelectableTextBlock Text="{Binding QueryText}" TextWrapping="Wrap" FontSize="16"/>
        </Border>
      </Expander>

      <!-- Interpretation -->
      <Expander Header="Interpretation" IsExpanded="True" HorizontalAlignment="Stretch"
                IsVisible="{Binding Interpretation, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <Border Background="{DynamicResource InterpretationBgBrush}" Padding="2" CornerRadius="4">
          <SelectableTextBlock Text="{Binding Interpretation}" TextWrapping="Wrap" FontSize="16"/>
        </Border>
      </Expander>

      <!-- Response -->
      <Expander Header="Response" IsExpanded="True" HorizontalAlignment="Stretch">
        <Border Background="{DynamicResource ContentBgBrush}" Padding="2" CornerRadius="4">
          <SelectableTextBlock Text="{Binding Response}" TextWrapping="Wrap" FontSize="16"/>
        </Border>
      </Expander>

      <!-- Processing Dialog -->
      <Expander Header="{Binding ProcessingDialog.Count, StringFormat='Processing Dialog ({0})'}"
                HorizontalAlignment="Stretch">
        <ItemsControl ItemsSource="{Binding ProcessingDialog}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="models:UnifiedProcessingDialogItem">
              <StackPanel Margin="0,0,0,4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <SelectableTextBlock Text="{Binding Role}" FontWeight="SemiBold" FontSize="15"/>
                  <SelectableTextBlock Text="{Binding TimestampDisplay}" FontSize="15" Foreground="{DynamicResource SubtleForeground}"/>
                </StackPanel>
                <SelectableTextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="16" Margin="0,2,0,0"/>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Expander>

      <!-- Actions -->
      <Expander Header="{Binding Actions.Count, StringFormat='Actions ({0})'}"
                HorizontalAlignment="Stretch">
        <ItemsControl ItemsSource="{Binding Actions}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="models:UnifiedAction">
              <StackPanel Margin="0,0,0,4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <SelectableTextBlock Text="{Binding Type}" FontWeight="SemiBold" FontSize="15"/>
                  <SelectableTextBlock Text="{Binding Status}" FontSize="15" Foreground="{DynamicResource SubtleForeground}"/>
                </StackPanel>
                <SelectableTextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="16" Margin="0,2,0,0"/>
                <SelectableTextBlock Text="{Binding FilePath}" FontSize="14" Foreground="{DynamicResource SubtleForeground}" TextTrimming="CharacterEllipsis"
                           IsVisible="{Binding FilePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Expander>

      <!-- Context -->
      <Expander Header="Context" HorizontalAlignment="Stretch">
        <ItemsControl ItemsSource="{Binding ContextList}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <SelectableTextBlock Text="{Binding}" Margin="0,1" FontSize="16" TextWrapping="Wrap"/>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Expander>

      <!-- Tags/Notes -->
      <Expander Header="Tags &amp; Notes" HorizontalAlignment="Stretch">
        <StackPanel Spacing="2">
          <SelectableTextBlock Text="{Binding FailureNote, StringFormat='Failure Note: {0}'}"
                     IsVisible="{Binding FailureNote, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                     Foreground="Red" FontSize="16"/>
          <ItemsControl ItemsSource="{Binding Tags}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <SelectableTextBlock Text="{Binding}" FontSize="16" TextWrapping="Wrap" Margin="0,1"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Expander>

      <!-- Original JSON -->
      <Expander Header="Original JSON" HorizontalAlignment="Stretch" x:CompileBindings="False">
        <Border Background="{DynamicResource ContentBgBrush}" Padding="2" CornerRadius="4">
          <SelectableTextBlock Text="{Binding OriginalEntry, Converter={StaticResource ObjectToJson}}"
                     TextWrapping="Wrap" FontSize="15"/>
        </Border>
      </Expander>

    </StackPanel>
  </ScrollViewer>
</UserControl>
