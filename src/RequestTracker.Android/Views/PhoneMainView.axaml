<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RequestTracker.Core.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:RequestTracker.Core.Models"
             xmlns:jsonModels="using:RequestTracker.Core.Models.Json"
             xmlns:conv="using:RequestTracker.Core.Converters"
             xmlns:beh="using:RequestTracker.Core.Behaviors"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
             x:Class="RequestTracker.Android.Views.PhoneMainView"
             x:Name="Root"
             x:DataType="vm:MainWindowViewModel">

    <UserControl.Resources>
        <conv:EqualityToBrushConverter x:Key="EqualityToBrush"/>
        <conv:EmptyStringToAllConverter x:Key="EmptyStringToAll"/>
    </UserControl.Resources>

    <Grid RowDefinitions="180, 4, *, Auto" ClipToBounds="True">
        <!-- Session List grouped by agent (children of All JSON node) -->
        <ScrollViewer Grid.Row="0">
            <StackPanel>
                <!-- All JSON header -->
                <Border Background="{DynamicResource SystemAccentColor}" Padding="8,6"
                        beh:TappedBehavior.Command="{Binding TreeItemTappedCommand}"
                        beh:TappedBehavior.CommandParameter="{Binding Nodes[0]}">
                    <TextBlock Text="All JSON" FontWeight="Bold" FontSize="15" Foreground="White"/>
                </Border>
            <ItemsControl ItemsSource="{Binding Nodes[0].Children}" x:CompileBindings="False">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:FileNode">
                        <StackPanel>
                            <!-- Group Header (agent name) -->
                            <Border Background="#E0E0E0" Padding="8,4"
                                    beh:TappedBehavior.Command="{Binding DataContext.TreeItemTappedCommand, ElementName=Root}"
                                    beh:TappedBehavior.CommandParameter="{Binding}">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"/>
                            </Border>
                            <!-- Sessions in group -->
                            <ItemsControl ItemsSource="{Binding Children}" IsVisible="{Binding IsExpanded}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="models:FileNode">
                                        <Border Padding="16,6,8,6" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1"
                                                beh:TappedBehavior.Command="{Binding DataContext.TreeItemTappedCommand, ElementName=Root}"
                                                beh:TappedBehavior.CommandParameter="{Binding}">
                                            <TextBlock Text="{Binding Name}" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Splitter -->
        <Border Grid.Row="1" Background="LightGray"/>

        <!-- Viewer Pane -->
        <Grid Grid.Row="2" ClipToBounds="True">
            <!-- JSON view -->
            <Grid IsVisible="{Binding IsJsonVisible}" RowDefinitions="Auto, Auto, *, Auto, *">
                <Border Grid.Row="0" Padding="4" Margin="0,0,0,2">
                    <ItemsControl ItemsSource="{Binding JsonLogSummary.SummaryLines}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="13" Margin="0,1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
                <Grid Grid.Row="1" ColumnDefinitions="Auto, *" Margin="4">
                    <TextBlock Grid.Column="0" Text="Search:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
                    <TextBox Grid.Column="1" Text="{Binding SearchQuery}" Watermark="Search..." FontSize="13"/>
                </Grid>
                <Border Grid.Row="2" MinHeight="80" Padding="4">
                    <ItemsControl ItemsSource="{Binding FilteredSearchEntries}" x:CompileBindings="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Spacing="2"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="jsonModels:SearchableEntry">
                                <Border BorderBrush="#C0C0C0" BorderThickness="0,0,0,1" Padding="4"
                                        beh:TappedBehavior.Command="{Binding DataContext.SearchRowTappedCommand, ElementName=Root}"
                                        beh:TappedBehavior.CommandParameter="{Binding}"
                                        beh:DoubleTappedBehavior.Command="{Binding DataContext.SearchRowDoubleTappedCommand, ElementName=Root}"
                                        beh:DoubleTappedBehavior.CommandParameter="{Binding}">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding DisplayText}" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Model}" FontSize="11" Foreground="Gray"/>
                                            <TextBlock Text="{Binding TimestampDisplay}" FontSize="11" Foreground="Gray"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
                <Border Grid.Row="3" Height="2" Background="LightGray" Margin="0,2"/>
                <Border Grid.Row="4" MinHeight="100">
                    <TreeView ItemsSource="{Binding JsonTree}" SelectedItem="{Binding SelectedJsonNode}">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Children}" DataType="jsonModels:JsonTreeNode">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#007acc" FontSize="13"/>
                                    <TextBlock Text=":" Foreground="Gray"/>
                                    <TextBlock Text="{Binding Value}" Foreground="#ce9178" FontSize="13"/>
                                </StackPanel>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                        <TreeView.ItemContainerTheme>
                            <ControlTheme TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}" x:DataType="jsonModels:JsonTreeNode">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            </ControlTheme>
                        </TreeView.ItemContainerTheme>
                    </TreeView>
                </Border>
            </Grid>

            <!-- Markdown view -->
            <Grid IsVisible="{Binding IsMarkdownVisible}">
                <TextBox IsReadOnly="True" Text="{Binding CurrentPreviewMarkdownText}" TextWrapping="Wrap"
                         Background="Transparent" BorderThickness="0" Margin="4"/>
            </Grid>

            <!-- Request Details -->
            <Grid IsVisible="{Binding IsRequestDetailsVisible}" RowDefinitions="Auto, *">
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="4">
                    <Button Content="← Back" Command="{Binding CloseRequestDetailsCommand}"/>
                    <Button Content="← Prev" Command="{Binding NavigateToPreviousRequestCommand}"/>
                    <Button Content="Next →" Command="{Binding NavigateToNextRequestCommand}"/>
                </StackPanel>
                <ContentControl Grid.Row="1" Content="{Binding SelectedUnifiedRequest}"/>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Padding="8,4" Background="#f5f5f5">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1" Text="{Binding AppVersionDisplay}" FontSize="10" VerticalAlignment="Center" Foreground="Gray"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
