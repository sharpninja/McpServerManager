<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RequestTracker.Core.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:RequestTracker.Core.Models"
             xmlns:jsonModels="using:RequestTracker.Core.Models.Json"
             xmlns:conv="using:RequestTracker.Core.Converters"
             xmlns:beh="using:RequestTracker.Core.Behaviors"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
             x:Class="RequestTracker.Android.Views.PhoneMainView"
             x:Name="Root"
             x:DataType="vm:MainWindowViewModel">

    <UserControl.Resources>
        <conv:EqualityToBrushConverter x:Key="EqualityToBrush"/>
        <conv:EmptyStringToAllConverter x:Key="EmptyStringToAll"/>
    </UserControl.Resources>

    <Grid RowDefinitions="*, Auto">
        <!-- NavigationView for section switching -->
        <ui:NavigationView Grid.Row="0"
                           PaneDisplayMode="LeftMinimal"
                           IsBackButtonVisible="False"
                           IsSettingsVisible="False"
                           beh:NavigationViewItemInvokedBehavior.Command="{Binding PhoneNavigateSectionCommand}">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Tag="Sessions">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ui:FontIcon Glyph="&#xE8B7;" FontSize="16"/>
                        <TextBlock Text="Sessions"/>
                    </StackPanel>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Tag="Viewer">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ui:FontIcon Glyph="&#xE8A5;" FontSize="16"/>
                        <TextBlock Text="Viewer"/>
                    </StackPanel>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Tag="History">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ui:FontIcon Glyph="&#xE81C;" FontSize="16"/>
                        <TextBlock Text="History"/>
                    </StackPanel>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.Content>
                <Grid>
                    <!-- Sessions Section -->
                    <Grid IsVisible="{Binding IsPhoneSessionsVisible}">
                        <TreeView ItemsSource="{Binding Nodes}" SelectedItem="{Binding SelectedNode}"
                                  VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate ItemsSource="{Binding Children}" DataType="models:FileNode">
                                    <TextBlock Text="{Binding Name}" FontSize="16" Padding="4"/>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                            <TreeView.ItemContainerTheme>
                                <ControlTheme TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}" x:DataType="models:FileNode">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                </ControlTheme>
                            </TreeView.ItemContainerTheme>
                        </TreeView>
                    </Grid>

                    <!-- Viewer Section -->
                    <Grid IsVisible="{Binding IsPhoneViewerVisible}" RowDefinitions="Auto, *">
                        <!-- Toolbar -->
                        <Grid Grid.Row="0" ColumnDefinitions="Auto, Auto, Auto, *" Margin="5">
                            <Button Grid.Column="0" Command="{Binding NavigateBackCommand}" Margin="0,0,5,0" Width="40">
                                <PathIcon Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" Width="12" Height="12"/>
                            </Button>
                            <Button Grid.Column="1" Command="{Binding NavigateForwardCommand}" Margin="0,0,5,0" Width="40">
                                <PathIcon Data="M4,11V13H16L10.5,18.5L11.92,19.92L19.84,12L11.92,4.08L10.5,5.5L16,11H4Z" Width="12" Height="12"/>
                            </Button>
                            <Button Grid.Column="2" Command="{Binding RefreshCommand}" Margin="0,0,5,0" Width="40">
                                <PathIcon Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" Width="12" Height="12"/>
                            </Button>
                        </Grid>

                        <!-- Content area -->
                        <ScrollViewer Grid.Row="1">
                            <Grid>
                                <!-- JSON view -->
                                <Grid IsVisible="{Binding IsJsonVisible}" RowDefinitions="Auto, Auto, *, Auto, *">
                                    <!-- Summary -->
                                    <Border Grid.Row="0" Padding="8" Margin="0,0,0,4">
                                        <ItemsControl ItemsSource="{Binding JsonLogSummary.SummaryLines}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" FontSize="14" Margin="0,1"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                    <!-- Search -->
                                    <Grid Grid.Row="1" ColumnDefinitions="Auto, *" Margin="4">
                                        <TextBlock Grid.Column="0" Text="Search:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding SearchQuery}" Watermark="Search..." FontSize="14"/>
                                    </Grid>
                                    <!-- Search Results (compact for phone) -->
                                    <Border Grid.Row="2" MinHeight="120" Padding="4">
                                        <ItemsControl ItemsSource="{Binding FilteredSearchEntries}" x:CompileBindings="False">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><StackPanel Spacing="2"/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="jsonModels:SearchableEntry">
                                                    <Border BorderBrush="#C0C0C0" BorderThickness="0,0,0,1" Padding="4"
                                                            beh:TappedBehavior.Command="{Binding DataContext.SearchRowTappedCommand, ElementName=Root}"
                                                            beh:TappedBehavior.CommandParameter="{Binding}"
                                                            beh:DoubleTappedBehavior.Command="{Binding DataContext.SearchRowDoubleTappedCommand, ElementName=Root}"
                                                            beh:DoubleTappedBehavior.CommandParameter="{Binding}">
                                                        <StackPanel Spacing="2">
                                                            <TextBlock Text="{Binding DisplayText}" FontSize="14" TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding RequestId}" FontSize="11" Foreground="Gray" TextTrimming="CharacterEllipsis"/>
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <TextBlock Text="{Binding Model}" FontSize="11" Foreground="Gray"/>
                                                                <TextBlock Text="{Binding TimestampDisplay}" FontSize="11" Foreground="Gray"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                    <!-- Separator -->
                                    <Border Grid.Row="3" Height="2" Background="LightGray" Margin="0,4"/>
                                    <!-- JSON Tree -->
                                    <Border Grid.Row="4" MinHeight="200">
                                        <TreeView ItemsSource="{Binding JsonTree}" SelectedItem="{Binding SelectedJsonNode}">
                                            <TreeView.ItemTemplate>
                                                <TreeDataTemplate ItemsSource="{Binding Children}" DataType="jsonModels:JsonTreeNode">
                                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#007acc" FontSize="14"/>
                                                        <TextBlock Text=":" Foreground="Gray"/>
                                                        <TextBlock Text="{Binding Value}" Foreground="#ce9178" FontSize="14"/>
                                                    </StackPanel>
                                                </TreeDataTemplate>
                                            </TreeView.ItemTemplate>
                                            <TreeView.ItemContainerTheme>
                                                <ControlTheme TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}" x:DataType="jsonModels:JsonTreeNode">
                                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                                </ControlTheme>
                                            </TreeView.ItemContainerTheme>
                                        </TreeView>
                                    </Border>
                                </Grid>

                                <!-- Markdown view -->
                                <Grid IsVisible="{Binding IsMarkdownVisible}" RowDefinitions="Auto, *">
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="8,6" IsVisible="{Binding IsPreviewOpenedInBrowser}">
                                        <Button Content="Raw text" Command="{Binding ToggleShowRawMarkdownCommand}"/>
                                        <Button Content="Archive" Command="{Binding ArchiveCommand}"/>
                                    </StackPanel>
                                    <TextBox Grid.Row="1" IsReadOnly="True" Text="{Binding CurrentPreviewMarkdownText}" TextWrapping="Wrap"
                                             Background="Transparent" BorderThickness="0" Margin="8"/>
                                </Grid>

                                <!-- Request Details -->
                                <Grid IsVisible="{Binding IsRequestDetailsVisible}" RowDefinitions="Auto, *">
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="5">
                                        <Button Content="← Back" Command="{Binding CloseRequestDetailsCommand}"/>
                                        <Button Content="← Prev" Command="{Binding NavigateToPreviousRequestCommand}"/>
                                        <Button Content="Next →" Command="{Binding NavigateToNextRequestCommand}"/>
                                    </StackPanel>
                                    <ContentControl Grid.Row="1" Content="{Binding SelectedUnifiedRequest}"/>
                                </Grid>
                            </Grid>
                        </ScrollViewer>
                    </Grid>

                    <!-- History Section -->
                    <Grid IsVisible="{Binding IsPhoneHistoryVisible}">
                        <ListBox ItemsSource="{Binding ChangeLog}" Background="Transparent"/>
                    </Grid>
                </Grid>
            </ui:NavigationView.Content>
        </ui:NavigationView>

        <!-- Status Bar -->
        <Border Grid.Row="1" Padding="8,4" Background="#f5f5f5">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1" Text="{Binding AppVersionDisplay}" FontSize="11" VerticalAlignment="Center" Foreground="Gray"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
