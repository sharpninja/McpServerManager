<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:RequestTracker.Core.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="RequestTracker.Desktop.Views.WorkspaceView"
             x:Name="WorkspaceRoot"
             x:DataType="vm:WorkspaceViewModel">

  <Grid RowDefinitions="Auto,Auto,Auto,*">
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4" Margin="4">
      <Button Content="+ New" Command="{Binding NewWorkspaceCommand}" Padding="8,4"/>
      <Button Content="Refresh" Command="{Binding RefreshCommand}" Padding="8,4"/>
      <Button Content="Reload" Command="{Binding OpenSelectedWorkspaceCommand}" Padding="8,4"/>
      <Button Content="Copy Key" Command="{Binding CopySelectedKeyCommand}" Padding="8,4"/>
      <Button Content="Status" Command="{Binding GetSelectedStatusCommand}" Padding="8,4"/>
      <Button Content="Init" Command="{Binding InitSelectedWorkspaceCommand}" Padding="8,4"/>
      <Button Content="Start" Command="{Binding StartSelectedWorkspaceCommand}" Padding="8,4"/>
      <Button Content="Stop" Command="{Binding StopSelectedWorkspaceCommand}" Padding="8,4"/>
      <Button Content="Delete" Command="{Binding DeleteSelectedCommand}" Padding="8,4"/>
    </StackPanel>

    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="4,0,4,4">
      <TextBox Grid.Column="0"
               Text="{Binding FilterText, Mode=TwoWay}"
               Watermark="Filter workspaces..."/>
      <Button Grid.Column="1"
              Content="Clear"
              Command="{Binding ClearFiltersCommand}"
              Margin="4,0,0,0"
              Padding="8,4"/>
    </Grid>

    <SelectableTextBlock Grid.Row="2"
                         Text="{Binding StatusText}"
                         Margin="8,0,8,4"
                         FontSize="12"
                         Foreground="Gray"/>

    <Grid x:Name="ContentGrid" Grid.Row="3"
          ColumnDefinitions="1*,4,2*" RowDefinitions="*">
      <Border x:Name="ListPanel" Grid.Column="0" Background="{DynamicResource SystemAltHighColor}" Margin="4">
        <ListBox ItemsSource="{Binding FilteredItems}"
                 SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                 Margin="0">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:WorkspaceListEntry">
              <Border Padding="6" Margin="0,0,0,3" CornerRadius="4" Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <StackPanel Spacing="1">
                    <TextBlock Text="{Binding Key}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Title}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Subtitle}"
                               FontSize="11"
                               Foreground="{DynamicResource SystemBaseMediumColor}"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>

      <GridSplitter x:Name="WorkspaceSplitter"
                    Grid.Column="1"
                    Background="Gray"
                    Opacity="0.4"
                    ResizeDirection="Columns"/>

      <Border x:Name="EditorPanel" Grid.Column="2" Padding="8">
        <ScrollViewer>
          <StackPanel Spacing="8">
            <SelectableTextBlock Text="{Binding EditorModeText}" FontWeight="SemiBold"/>

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Key"/>
              <TextBox Grid.Row="0" Grid.Column="1"
                       Text="{Binding EditorKey}"
                       IsReadOnly="True"/>

              <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Name"/>
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EditorName, Mode=TwoWay}"/>

              <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Workspace Path"/>
              <TextBox Grid.Row="2" Grid.Column="1"
                       Text="{Binding EditorWorkspacePath, Mode=TwoWay}"
                       IsReadOnly="{Binding IsEditingExisting}"/>

              <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Todo Path"/>
              <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding EditorTodoPath, Mode=TwoWay}"/>

              <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Workspace Port"/>
              <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding EditorWorkspacePortText, Mode=TwoWay}"/>

              <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="Tunnel Provider"/>
              <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding EditorTunnelProvider, Mode=TwoWay}"/>

              <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Text="Run As"/>
              <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding EditorRunAs, Mode=TwoWay}"/>
            </Grid>

            <TextBlock Text="{Binding ProcessStatusText}" TextWrapping="Wrap" Foreground="Gray"/>

            <StackPanel Orientation="Horizontal" Spacing="4">
              <Button Content="Save" Command="{Binding SaveEditorCommand}" Padding="12,4"/>
              <Button Content="Reload Selected" Command="{Binding OpenSelectedWorkspaceCommand}" Padding="12,4"/>
              <Button Content="New Draft" Command="{Binding NewWorkspaceCommand}" Padding="12,4"/>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</UserControl>
